# E-commerce Site Config
PUBLIC_SITE_URL=https://flexformfitness.vercel.app

# Firebase Admin Credentials
# Option 1: Unified Service Account JSON string (recommended for Vercel deployment)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Option 2: Individual variables (optional fallback)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Stripe Config
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API (Emails)
RESEND_API_KEY=re_...

# Admin Authentication
ADMIN_SECRET_TOKEN=generate-a-secure-random-token-here

# Firebase Client Configuration (Para el SDK del navegador)
PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
PUBLIC_FIREBASE_APP_ID=your-app-id
PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Vercel Deploy Hook para reconstrucción automática de la tienda (Auto-rebuild)
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_.../xxxxxx

# Upstash Redis Config (Rate Limiting)
# Obtén estas credenciales registrándote gratis en https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_auth_token_here
