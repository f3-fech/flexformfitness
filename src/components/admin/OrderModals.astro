---
// Support modals for viewing user details, order details, and registering shipping status
---

<!-- MODAL: USER DETAILS -->
<div id="user-details-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white w-full h-full lg:w-[96vw] lg:h-[94vh] lg:rounded-3xl shadow-2xl overflow-hidden animate-fade-in flex flex-col">
    <!-- Title Bar -->
    <div class="px-8 py-5 bg-slate-50 border-b border-slate-200 flex justify-between items-center select-none shrink-0">
      <span class="text-xs font-black tracking-widest text-slate-800 uppercase font-mono">Detalles del Usuario</span>
      <button type="button" id="close-user-details-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
    </div>
    
    <!-- Content Area -->
    <div id="user-details-content" class="p-8 lg:p-10 overflow-y-auto flex-grow flex flex-col gap-6 text-xs text-slate-700">
      <!-- Dynamically populated via JavaScript -->
    </div>

    <!-- Footer -->
    <div class="px-8 py-5 bg-slate-50 border-t border-slate-200 flex justify-end gap-3 shrink-0">
      <button type="button" id="close-user-details-btn" class="px-5 py-2.5 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs">Cerrar</button>
    </div>
  </div>
</div>

<!-- MODAL: ORDER DETAILS -->
<div id="order-details-modal" class="fixed inset-0 z-50 flex items-center justify-center p-2 sm:p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-3xl shadow-2xl overflow-hidden animate-fade-in flex flex-col max-h-[90vh]">
    <!-- Title Bar -->
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex justify-between items-center select-none shrink-0">
      <span class="text-xs font-black tracking-widest text-slate-800 uppercase font-mono">Detalles del Pedido</span>
      <button type="button" id="close-order-details-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
    </div>
    
    <!-- Content Area -->
    <div id="order-details-content" class="p-6 overflow-y-auto flex-grow flex flex-col gap-6 text-xs text-slate-700">
      <!-- Dynamically populated via JavaScript -->
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3 shrink-0">
      <button type="button" id="close-order-details-btn" class="px-5 py-2.5 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs">Cerrar</button>
    </div>
  </div>
</div>

<!-- MODAL: SHIP ORDER (SHIPPING DETAILS) -->
<div id="ship-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-md shadow-2xl overflow-hidden animate-fade-in">
    <div class="p-6 border-b border-slate-200 flex justify-between items-center bg-slate-50">
      <h3 class="text-lg font-black italic tracking-wide text-slate-900 uppercase">Registrar Envío</h3>
      <button type="button" id="close-ship-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
    </div>
    
    <form id="ship-form" class="p-6 flex flex-col gap-4 text-xs">
      <input type="hidden" name="orderId" id="form-ship-order-id" />

      <div>
        <label for="form-ship-status" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Estado de Envío</label>
        <select name="shippingStatus" id="form-ship-status" class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-950 focus:outline-none focus:border-rose-600 font-semibold shadow-3xs">
          <option value="shipped" selected>Enviado (En tránsito)</option>
          <option value="delivered">Entregado</option>
          <option value="cancelled">Cancelado</option>
          <option value="returned">Devuelto</option>
        </select>
      </div>

      <div>
        <label for="form-ship-tracking" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Código de Seguimiento (Tracking Number)</label>
        <input type="text" name="trackingNumber" id="form-ship-tracking" required placeholder="Ej: ES29103984102" class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono" />
      </div>

      <div class="pt-4 border-t border-slate-200 flex justify-end gap-3">
        <button type="button" id="cancel-ship-modal" class="px-4 py-2 bg-slate-50 hover:bg-slate-100 text-slate-650 rounded-xl text-xs font-bold uppercase transition-colors">Cancelar</button>
        <button type="submit" id="save-ship-btn" class="px-5 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs">Confirmar Envío</button>
      </div>
    </form>
  </div>
</div>
