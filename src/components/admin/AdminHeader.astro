---
interface Props {
  logoUrl?: string;
  adminEmail?: string;
}

const { logoUrl, adminEmail } = Astro.props;
---

<header class="w-full bg-white border-b border-slate-200 py-4 px-6 md:px-8">
  <div class="w-full flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      {logoUrl ? (
        <img src={logoUrl} alt="FLEX FORM FITNESS" class="h-8 w-auto object-contain" />
      ) : (
        <div class="flex flex-col">
          <span class="text-xl md:text-2xl font-black italic tracking-tighter text-slate-950 uppercase leading-none">
            FLEX <span class="text-rose-600">FORM</span>
          </span>
          <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5">
            FITNESS · ADMIN
          </span>
        </div>
      )}
    </a>

    <!-- Logged in user info & logout -->
    <div class="flex items-center gap-3">
      <span class="text-xs text-slate-500 font-semibold hidden sm:inline mr-1">
        Admin: {adminEmail || 'Activo'}
      </span>
      <button
        type="button"
        id="publish-changes-btn"
        class="px-4 py-2 border rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-3xs flex items-center gap-2"
      >
        <span class="w-2 h-2 rounded-full transition-all" id="publish-badge"></span>
        <span id="publish-btn-text">Publicado</span>
      </button>

      <!-- Notification Bell -->
      <div class="relative">
        <button
          type="button"
          id="admin-notif-btn"
          class="p-2.5 border border-slate-200 text-slate-600 hover:bg-slate-55 rounded-xl transition-all relative cursor-pointer focus:outline-none flex items-center justify-center active:scale-95"
          aria-label="Notificaciones"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
          </svg>
          <span id="admin-notif-badge" class="absolute -top-1 -right-1 bg-rose-600 text-white text-[9px] font-extrabold w-4 h-4 rounded-full flex items-center justify-center border border-white hidden">0</span>
        </button>

        <!-- Dropdown Box -->
        <div id="admin-notif-dropdown" class="absolute right-0 mt-2.5 w-80 bg-white border border-slate-200 rounded-2xl shadow-xl z-55 hidden flex-col transition-all duration-200">
          <div class="px-4 py-3.5 border-b border-slate-100 bg-slate-50 rounded-t-2xl flex justify-between items-center">
            <span class="text-3xs font-extrabold uppercase text-slate-400 tracking-wider">Notificaciones</span>
          </div>
          <!-- Notif List -->
          <div id="admin-notif-list" class="max-h-64 overflow-y-auto divide-y divide-slate-100 text-2xs text-slate-700">
            <div class="py-6 px-4 text-center text-slate-400 font-medium">Cargando notificaciones...</div>
          </div>
        </div>
      </div>

      <a
        href="/admin/logout"
        class="px-4 py-2 bg-white border border-slate-200 hover:bg-rose-600 hover:border-rose-600 hover:text-white text-slate-700 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-3xs"
      >
        Cerrar Sesión
      </a>
    </div>
  </div>
</header>
