---
import type { GeneralSettings } from '../../lib/settings';
import type { ProductCollection } from '../../types';
import type Stripe from 'stripe';
import CouponTab from './CouponTab.astro';

interface Props {
  settings: GeneralSettings;
  collections: ProductCollection[];
  promotionCodes: Stripe.PromotionCode[];
}

const { settings, collections, promotionCodes } = Astro.props;

const popularCountries = ['ES', 'FR', 'DE', 'IT', 'PT', 'GB', 'US', 'CA', 'MX'];
const otherCountries = settings.markets.filter((c) => !popularCountries.includes(c));

const subCollectionsHombre = collections.filter((c) => {
  if (c.slug === 'hombre' || c.slug === 'mujer') return false;
  if (c.parentCategory) return c.parentCategory === 'Hombre';
  const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
  return isMen;
}).sort((a, b) => (a.indexOrder ?? 999) - (b.indexOrder ?? 999));

const subCollectionsMujer = collections.filter((c) => {
  if (c.slug === 'hombre' || c.slug === 'mujer') return false;
  if (c.parentCategory) return c.parentCategory === 'Mujer';
  const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
  const isWomen = c.slug.includes('mujer') || c.title.toLowerCase().includes('mujer') || c.title.toLowerCase().includes('women');
  return isWomen && !isMen;
}).sort((a, b) => (a.indexOrder ?? 999) - (b.indexOrder ?? 999));
---

<section id="section-settings" class="w-full hidden">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Configuración General</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
    <!-- Left Side: Sub-navigation sidebar menu -->
    <div class="md:col-span-1 flex flex-col gap-1 bg-white border border-slate-200 p-4 rounded-2xl shadow-sm h-fit">
      <button
        type="button"
        id="subtab-shipping-btn"
        class="w-full text-left px-4 py-3 rounded-xl font-bold text-xs uppercase tracking-wider transition-all focus:outline-none flex items-center gap-2.5 bg-red-50 text-rose-600"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.75a1.125 1.125 0 0 1-1.125-1.125V15h9.75M8.25 18.75a1.5 1.5 0 0 0 3 0M12 18.75a1.5 1.5 0 0 0-3 0m3 0h3.75a1.125 1.125 0 0 0 1.125-1.125V18m-4.875-13.5v10.125c0 .621.504 1.125 1.125 1.125H18M15 4.5V15h4.5M19.5 18a2.25 2.25 0 0 0-2.25-2.25h-1.5A2.25 2.25 0 0 0 13.5 18m6 0a2.25 2.25 0 0 1-2.25 2.25h-1.5A2.25 2.25 0 0 1 13.5 18" /></svg>
        Envíos y Mercados
      </button>
      <button
        type="button"
        id="subtab-admins-btn"
        class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm-3.75 7.875c0-1.242 1.343-2.25 3-2.25s3 1.008 3 2.25H6.75Z" /></svg>
        Administradores
      </button>
      <button
        type="button"
        id="subtab-branding-btn"
        class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 3.395-1.622m-3.395 1.622a15.999 15.999 0 0 1-1.622-3.395m3.42-3.42L15 4.5M10.97 8.53 4.5 15" /></svg>
        Identidad de Marca
      </button>
      <button
        type="button"
        id="subtab-megamenu-btn"
        class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        Editor de Mega Menú
      </button>
      <button
        type="button"
        id="subtab-coupons-btn"
        class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a2.25 2.25 0 0 0 3.181 0l5.178-5.178a2.25 2.25 0 0 0 0-3.181l-9.58-9.581A2.25 2.25 0 0 0 9.568 3Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" /></svg>
        Códigos Descuento
      </button>
    </div>

    <!-- Right Side: Forms/Content Panel -->
    <div class="md:col-span-3 flex flex-col gap-6 text-xs text-slate-705">
      
      <!-- SUBSECTION: SHIPPING & MARKETS -->
      <form id="form-sub-shipping" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm">
        <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
          <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Envíos y Mercados</h3>
          <p class="text-slate-400 text-3xs normal-case leading-normal">Configura el costo de los envíos estándar, el umbral para envío gratuito y los códigos de país habilitados en Stripe.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="settings-shipping-price" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Envío Estándar ($/€, Ej: 4.99)</label>
            <input
              type="number"
              step="0.01"
              id="settings-shipping-price"
              value={(settings.shippingPrice / 100).toFixed(2)}
              required
              class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono text-sm"
            />
          </div>
          <div>
            <label for="settings-free-shipping-min" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Límite Envío Gratis ($/€, Ej: 50.00)</label>
            <input
              type="number"
              step="0.01"
              id="settings-free-shipping-min"
              value={(settings.freeShippingMin / 100).toFixed(2)}
              required
              class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono text-sm"
            />
          </div>
          <div class="md:col-span-2 flex flex-col gap-4">
            <div>
              <span class="block font-semibold mb-2 text-slate-500 uppercase tracking-wider">Selección de Países (Mercados de Stripe)</span>
              
              <!-- Regional Quick Select Buttons -->
              <div class="flex flex-wrap gap-2 mb-3">
                <button
                  type="button"
                  id="preset-europe-btn"
                  class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-slate-200 cursor-pointer"
                >
                  🇪🇺 Europa (UE)
                </button>
                <button
                  type="button"
                  id="preset-northamerica-btn"
                  class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-slate-200 cursor-pointer"
                >
                  🌎 Norteamérica (US, CA, MX)
                </button>
                <button
                  type="button"
                  id="preset-clear-btn"
                  class="px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 hover:text-rose-700 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-rose-100 cursor-pointer"
                >
                  ✕ Deseleccionar Todo
                </button>
              </div>
              
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 p-3.5 bg-slate-50 border border-slate-200 rounded-2xl max-h-[180px] overflow-y-auto">
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="ES" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('ES')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">ES (España)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="FR" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('FR')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">FR (Francia)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="DE" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('DE')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">DE (Alemania)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="IT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('IT')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">IT (Italia)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="PT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('PT')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">PT (Portugal)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="GB" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('GB')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">GB (R. Unido)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="US" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('US')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">US (EE.UU.)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="CA" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('CA')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">CA (Canadá)</span>
                </label>
                <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-all cursor-pointer">
                  <input type="checkbox" name="country-checkbox" value="MX" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('MX')} />
                  <span class="text-2xs font-extrabold uppercase text-slate-700 font-mono">MX (México)</span>
                </label>
              </div>
            </div>

            <!-- Auxiliary manual input for other countries -->
            <div>
              <label for="settings-other-markets" class="block font-semibold mb-1 text-slate-400 uppercase tracking-wider text-3xs">Otros Países Adicionales (Separados por comas, ej: JP, AU, CH)</label>
              <input
                type="text"
                id="settings-other-markets"
                value={otherCountries.join(', ')}
                placeholder="Ej: JP, AU, CH"
                class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono text-sm"
              />
            </div>
          </div>
        </div>

        <div class="flex justify-end pt-4 border-t border-slate-100">
          <button
            type="submit"
            id="save-shipping-btn"
            class="px-6 py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-2xs font-extrabold uppercase tracking-wider transition-all active:scale-95 shadow-sm"
          >
            Guardar Envíos y Mercados
          </button>
        </div>
      </form>

      <!-- SUBSECTION: ADMINISTRATORS -->
      <form id="form-sub-admins" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
        <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
          <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Administradores del Sistema</h3>
          <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Delega o revoca permisos de acceso de administrador secundarios por correo electrónico.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-1 flex flex-col gap-3">
            <label for="new-admin-email" class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Agregar Administrador</label>
            <div class="flex gap-2">
              <input
                type="email"
                id="new-admin-email"
                placeholder="admin@flexform.com"
                class="flex-1 px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 text-xs font-medium"
              />
              <button
                type="button"
                id="add-admin-btn"
                class="px-4 py-2 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shrink-0"
              >
                Añadir
              </button>
            </div>
            <p class="text-slate-400 text-3xs leading-normal font-medium">
              Los administradores delegados podrán acceder a todo el panel usando su propia cuenta de Firebase Auth / Google.
            </p>
          </div>

          <div class="md:col-span-2 flex flex-col gap-2">
            <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Administradores Autorizados</span>
            <div class="flex flex-col gap-2 max-h-[220px] overflow-y-auto pr-1" id="admins-list-container">
              <!-- Super Admin (Read-only) -->
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200">
                <div class="flex flex-col">
                  <span class="font-bold text-slate-800 font-mono">{import.meta.env.SUPERADMIN_EMAIL || process.env.SUPERADMIN_EMAIL || 'admin@flexform.com'}</span>
                  <span class="text-3xs text-rose-600 font-extrabold uppercase tracking-wider mt-0.5">Superadministrador Principal (.env)</span>
                </div>
                <span class="text-2xs text-slate-400 italic px-2">Solo lectura</span>
              </div>

              <!-- Dynamic Admins list -->
              {settings.admins && settings.admins.map((adminEmail) => (
                <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-colors admin-row" data-email={adminEmail}>
                  <span class="font-bold text-slate-800 font-mono">{adminEmail}</span>
                  <button
                    type="button"
                    class="remove-admin-btn text-rose-500 hover:text-rose-600 hover:bg-rose-50 p-2.5 rounded-xl transition-colors font-bold text-base"
                    title="Eliminar administrador"
                  >
                    ×
                  </button>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 text-3xs font-extrabold uppercase tracking-widest border border-emerald-100 select-none">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Autoguardado Activo
          </span>
        </div>
      </form>

      <!-- SUBSECTION: BRANDING (LOGO & FAVICON & HERO VIDEO) -->
      <form id="form-sub-branding" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
        <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
          <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Identidad de Marca</h3>
          <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Introduce las URLs para el logotipo, el favicon y el video de portada de tu sitio.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="settings-logo" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Logotipo</label>
            <input
              type="text"
              id="settings-logo"
              value={settings.logoUrl || ''}
              placeholder="Ej: /logo.png o https://..."
              class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono text-sm"
            />
          </div>
          <div>
            <label for="settings-favicon" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Favicon</label>
            <input
              type="text"
              id="settings-favicon"
              value={settings.faviconUrl || ''}
              placeholder="Ej: /favicon.ico o https://..."
              class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono text-sm"
            />
          </div>
        </div>

        <!-- Carrusel Hero Dinámico -->
        <div class="border-t border-slate-100 pt-4 flex flex-col gap-4">
          <div class="flex justify-between items-center pb-2 border-b border-slate-100">
            <div>
              <h4 class="font-extrabold uppercase text-slate-900 tracking-wider text-xs">Diapositivas del Carrusel Hero</h4>
              <p class="text-slate-400 text-3xs normal-case leading-normal font-medium mt-0.5">Añade, elimina o reordena las diapositivas del carrusel de la página de inicio.</p>
            </div>
            <button
              type="button"
              id="add-hero-slide-btn"
              class="px-3.5 py-2 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-3xs font-extrabold uppercase tracking-wider transition-colors cursor-pointer"
            >
              + Añadir Diapositiva
            </button>
          </div>

          <!-- Contenedor de diapositivas dinámicas -->
          <div id="hero-slides-list-container" class="flex flex-col gap-6">
            {settings.heroSlides && settings.heroSlides.map((slide, index) => (
              <div class="hero-slide-card border border-slate-200 rounded-2xl p-5 bg-slate-50 flex flex-col gap-4 relative group" data-id={slide.id}>
                <!-- Header of the card -->
                <div class="flex justify-between items-center border-b border-slate-200/80 pb-2">
                  <div class="flex items-center gap-3">
                    <span class="text-3xs font-black uppercase text-slate-500 bg-slate-200/60 px-2.5 py-1 rounded-lg slide-index-label">Diapositiva #{index + 1}</span>
                    <div class="flex gap-1">
                      <button type="button" class="move-slide-up-btn text-slate-500 hover:text-slate-900 bg-white hover:bg-slate-100 border border-slate-200 w-6 h-6 rounded-lg flex items-center justify-center font-bold text-xs cursor-pointer" title="Subir">↑</button>
                      <button type="button" class="move-slide-down-btn text-slate-500 hover:text-slate-900 bg-white hover:bg-slate-100 border border-slate-200 w-6 h-6 rounded-lg flex items-center justify-center font-bold text-xs cursor-pointer" title="Bajar">↓</button>
                    </div>
                    <label class="flex items-center gap-1.5 cursor-pointer ml-2">
                      <input type="checkbox" class="slide-show-title w-3.5 h-3.5 rounded text-rose-600 border-slate-300 focus:ring-rose-600 cursor-pointer" checked={slide.showTitleOverlay !== false} />
                      <span class="text-3xs font-extrabold uppercase text-slate-500 select-none">Mostrar Título (FLEX FORM FITNESS)</span>
                    </label>
                  </div>
                  <button type="button" class="delete-slide-btn text-rose-600 hover:text-rose-700 hover:bg-rose-50 px-2.5 py-1.5 rounded-xl transition-colors font-extrabold text-2xs uppercase tracking-wider cursor-pointer">
                    Eliminar
                  </button>
                </div>

                <!-- Media (Desktop vs Mobile) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <!-- Versión Desktop -->
                  <div class="flex flex-col gap-2 bg-white p-3.5 rounded-xl border border-slate-200/60">
                    <div class="flex justify-between items-center mb-1">
