---
import type { ProductCollection } from '../../types';

interface Props {
  collections: ProductCollection[];
}

const { collections } = Astro.props;
---

<!-- MODAL: PRODUCT FORM (CREATE / EDIT) -->
<div id="product-modal" class="fixed inset-0 z-50 flex items-center justify-center p-2 sm:p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-[95vw] h-[95vh] sm:h-[92vh] flex flex-col shadow-2xl overflow-hidden animate-fade-in">
    <div class="p-6 border-b border-slate-200 flex justify-between items-center bg-slate-50">
      <h3 id="modal-title" class="text-lg font-black italic tracking-wide text-slate-900 uppercase">Nuevo Producto</h3>
      <button type="button" id="close-product-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
    </div>
    
    <form id="product-form" class="p-6 overflow-y-auto flex-grow flex flex-col gap-6 text-xs">
      <!-- Hidden mode/id fields -->
      <input type="hidden" name="id" id="form-product-id" />

      <!-- Language Editor Selector Dropdown -->
      <div class="flex items-center justify-between bg-slate-50 border border-slate-200/80 p-3.5 rounded-2xl mb-1 shadow-3xs">
        <div class="flex flex-col">
          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Idioma de Edición / Editing Language</span>
          <span class="text-[10px] text-slate-500 font-medium">Usa este desplegable para guardar la versión traducida al Inglés</span>
        </div>
        <select id="form-product-lang" class="px-3 py-1.5 rounded-xl border border-slate-200 text-xs font-bold bg-white text-slate-800 focus:outline-none focus:border-rose-600 cursor-pointer shadow-3xs">
          <option value="es">🇪🇸 Español (Predeterminado)</option>
          <option value="en">🇺🇸 English (Traducción)</option>
        </select>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        <!-- Left Column: General Info -->
        <div class="lg:col-span-5 flex flex-col gap-4">
          <h4 class="text-xs font-bold text-slate-900 border-b border-slate-100 pb-2 mb-1 uppercase tracking-wider">Información General</h4>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2 sm:col-span-1">
              <label for="form-title" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Nombre del Producto</label>
              <input type="text" name="title" id="form-title" required class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-semibold" />
            </div>
            <div class="col-span-2 sm:col-span-1">
              <label for="form-slug" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Slug (para URL)</label>
              <input type="text" name="slug" id="form-slug" required class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono" />
            </div>
          </div>

          <div>
            <label for="form-description" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Descripción</label>
            <textarea name="description" id="form-description" rows="5" required class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 leading-normal font-semibold"></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="form-price" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Precio base (USD, Ej: 29.99)</label>
              <input type="number" step="0.01" name="price" id="form-price" required class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-mono" />
            </div>
            <div>
              <label for="form-stock" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Stock General (Auto-calculado)</label>
              <input type="number" name="stock" id="form-stock" readonly class="w-full px-3 py-2 rounded-xl bg-slate-100 border border-slate-200 text-slate-500 cursor-not-allowed focus:outline-none font-mono" />
            </div>
          </div>

          <!-- SECTION: GENDER SELECTION (MANDATORY) -->
          <div class="border-t border-slate-200 pt-4 flex flex-col gap-3">
            <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5 font-mono">
              Género Destinatario <span class="text-rose-600 font-black">*</span>
            </h4>
            <div class="grid grid-cols-3 gap-2.5">
              <label class="flex items-center justify-center gap-2 p-2.5 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100 cursor-pointer transition-all select-none text-center">
                <input type="radio" name="product-gender-assoc" value="hombre" class="w-3.5 h-3.5 text-rose-650 border-slate-300 focus:ring-rose-500 cursor-pointer" />
                <span class="font-bold text-slate-800 text-[10px] uppercase tracking-wider">Hombre</span>
              </label>
              
              <label class="flex items-center justify-center gap-2 p-2.5 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100 cursor-pointer transition-all select-none text-center">
                <input type="radio" name="product-gender-assoc" value="mujer" class="w-3.5 h-3.5 text-rose-650 border-slate-300 focus:ring-rose-500 cursor-pointer" />
                <span class="font-bold text-slate-800 text-[10px] uppercase tracking-wider">Mujer</span>
              </label>

              <label class="flex items-center justify-center gap-2 p-2.5 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100 cursor-pointer transition-all select-none text-center">
                <input type="radio" name="product-gender-assoc" value="unisex" class="w-3.5 h-3.5 text-rose-650 border-slate-300 focus:ring-rose-500 cursor-pointer" />
                <span class="font-bold text-slate-800 text-[10px] uppercase tracking-wider">Unisex</span>
              </label>
            </div>
            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-wider block">Indica de manera obligatoria a qué género va dirigido el producto.</p>
          </div>

          <!-- SECTION: COLLECTIONS CHECKBOXES -->
          <div class="border-t border-slate-200 pt-4 flex flex-col gap-3">
            <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5 font-mono">
              Otras Colecciones
            </h4>
            <div id="product-collections-container" class="flex flex-col gap-2 max-h-[280px] overflow-y-auto pr-1 bg-slate-50 border border-slate-200 rounded-xl p-3 shadow-3xs">
              <!-- Dynamically populated collection checkboxes from JS -->
            </div>
            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-wider block">Selecciona las colecciones en las que deseas incluir este producto.</p>
          </div>
        </div>

        <!-- Right Column: Multimedia and Variants -->
        <div class="lg:col-span-7 flex flex-col gap-5 border-t lg:border-t-0 lg:border-l border-slate-200 pt-6 lg:pt-0 lg:pl-6">
          
          <!-- SECTION: MULTIMEDIA (SHOPIFY STYLE) -->
          <div class="flex flex-col gap-3 border-b border-slate-150 pb-4">
            <div class="flex justify-between items-center">
              <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5">
                <svg class="w-4 h-4 text-rose-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                </svg>
                Multimedia
              </h4>
              <button
                type="button"
                id="add-media-btn"
                class="px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 border border-rose-100 font-bold rounded-xl text-3xs uppercase tracking-wider transition-all active:scale-95 flex items-center gap-1"
              >
                Añadir Imagen
              </button>
            </div>
            
            <div id="media-container" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 min-h-[110px] p-3 bg-slate-50 border border-dashed border-slate-200 rounded-2xl">
              <!-- Dynamic media cards rendered here -->
            </div>
            <span class="text-[9px] text-slate-400 font-bold uppercase tracking-wider block -mt-1">Arrastra las imágenes para reordenar. La primera es la principal (Portada).</span>
          </div>

          <!-- SECTION: VARIANTS -->
          <div class="flex flex-col gap-4">
            <div class="flex justify-between items-center border-b border-slate-100 pb-2 mb-1">
              <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5">
                <svg class="w-4 h-4 text-rose-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.5 1.5 0 002.122 0l4.318-4.318a1.5 1.5 0 000-2.122L11.16 3.659A2.25 2.25 0 009.568 3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                </svg>
                Variantes de Producto
              </h4>
              <button
                type="button"
                id="add-color-branch"
                class="px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 border border-rose-100 font-bold rounded-xl text-3xs uppercase tracking-wider transition-all active:scale-95 flex items-center gap-1"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Añadir Color
              </button>
            </div>
            
            <div id="variant-tree-container" class="flex flex-col gap-5 max-h-[45vh] overflow-y-auto pr-1">
              <!-- Color branches generated dynamically -->
            </div>
          </div>
        </div>
      </div>

      <div class="pt-4 border-t border-slate-200 flex justify-end gap-3 shrink-0">
        <button type="button" id="cancel-product-modal" class="px-4 py-2 bg-slate-50 hover:bg-slate-100 text-slate-600 rounded-xl text-xs font-bold uppercase transition-colors">Cancelar</button>
        <button type="submit" id="save-product-btn" class="px-5 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs">Guardar Producto</button>
      </div>
    </form>
  </div>
</div>

<!-- MODAL: IMAGE GALLERY (SHOPIFY STYLE) -->
<div id="gallery-modal" class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-4xl max-h-[85vh] flex flex-col shadow-2xl overflow-hidden animate-fade-in">
    <div class="p-5 border-b border-slate-200 flex justify-between items-center bg-slate-50">
      <h3 class="text-md font-black italic tracking-wide text-slate-900 uppercase flex items-center gap-2">
        <svg class="w-5 h-5 text-rose-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
        </svg>
        Galería de Imágenes
      </h3>
      <div class="flex items-center gap-3">
        <button type="button" id="gallery-upload-new-btn" class="px-3.5 py-1.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-3xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-2xs flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          Subir Nueva
        </button>
        <input type="file" id="gallery-file-input" accept="image/*" class="hidden" />
        <button type="button" id="close-gallery-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
      </div>
    </div>

    <div class="p-6 overflow-y-auto flex-grow bg-slate-50/50">
      <div id="gallery-loading" class="flex flex-col items-center justify-center py-20 gap-3 text-slate-500">
        <div class="animate-spin rounded-full h-8 w-8 border-2 border-slate-300 border-t-rose-600"></div>
        <span class="text-3xs font-bold uppercase tracking-widest text-slate-400 animate-pulse">Cargando galería...</span>
      </div>

      <div id="gallery-empty" class="hidden flex flex-col items-center justify-center py-20 gap-2 text-slate-400">
        <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 8.75h18a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
        </svg>
        <span class="text-3xs font-bold uppercase tracking-widest text-slate-400">No hay imágenes en la galería.</span>
      </div>

      <div id="gallery-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3.5">
        <!-- Render images dynamically -->
      </div>
    </div>

    <div class="p-5 border-t border-slate-200 flex justify-end gap-3 bg-slate-50">
      <button type="button" id="delete-gallery-img-btn" class="px-4 py-2 bg-red-50 hover:bg-red-100 text-red-650 rounded-xl text-xs font-bold uppercase transition-colors active:scale-95 mr-auto hidden">
        Eliminar Imagen
      </button>
      <button type="button" id="cancel-gallery-modal" class="px-4 py-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-600 rounded-xl text-xs font-bold uppercase transition-colors active:scale-95">
        Cancelar
      </button>
      <button type="button" id="insert-gallery-btn" class="px-5 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs active:scale-95" disabled>
        Insertar Imagen
      </button>
    </div>
  </div>
</div>

<!-- MODAL: VIDEO GALLERY (SHOPIFY STYLE) -->
<div id="video-gallery-modal" class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-4xl max-h-[85vh] flex flex-col shadow-2xl overflow-hidden animate-fade-in">
    <div class="p-5 border-b border-slate-200 flex justify-between items-center bg-slate-50">
      <h3 class="text-md font-black italic tracking-wide text-slate-900 uppercase flex items-center gap-2">
        <svg class="w-5 h-5 text-rose-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5-4.5 3v-6l4.5 3Z" />
        </svg>
        Galería de Videos
      </h3>
      <div class="flex items-center gap-3">
        <button type="button" id="video-gallery-upload-new-btn" class="px-3.5 py-1.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-3xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-2xs flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          Subir Nuevo
        </button>
        <input type="file" id="video-gallery-file-input" accept="video/mp4,video/webm" class="hidden" />
        <button type="button" id="close-video-gallery-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
      </div>
    </div>

    <div class="p-6 overflow-y-auto flex-grow bg-slate-50/50">
      <div id="video-gallery-loading" class="flex flex-col items-center justify-center py-20 gap-3 text-slate-500">
        <div class="animate-spin rounded-full h-8 w-8 border-2 border-slate-300 border-t-rose-600"></div>
        <span class="text-3xs font-bold uppercase tracking-widest text-slate-400 animate-pulse">Cargando galería de videos...</span>
      </div>

      <div id="video-gallery-empty" class="hidden flex flex-col items-center justify-center py-20 gap-2 text-slate-400">
        <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 8.75h18a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
        </svg>
        <span class="text-3xs font-bold uppercase tracking-widest text-slate-400">No hay videos en la galería.</span>
      </div>

      <div id="video-gallery-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3.5">
        <!-- Render videos dynamically -->
      </div>
    </div>

    <div class="p-5 border-t border-slate-200 flex justify-end gap-3 bg-slate-50">
      <button type="button" id="cancel-video-gallery-modal" class="px-4 py-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-600 rounded-xl text-xs font-bold uppercase transition-colors active:scale-95">
        Cancelar
      </button>
      <button type="button" id="insert-video-gallery-btn" class="px-5 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs active:scale-95" disabled>
        Seleccionar Video
      </button>
    </div>
  </div>
</div>

<!-- MODAL: IMAGE CROP/ALIGNMENT -->
<div id="crop-modal" class="fixed inset-0 z-[70] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
  <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-xl shadow-2xl overflow-hidden animate-fade-in flex flex-col max-h-[90vh]">
    <!-- Title Bar -->
    <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex justify-between items-center select-none shrink-0">
      <span class="text-xs font-extrabold tracking-widest text-slate-800 uppercase font-mono">Recortar Imagen de Portada (3:4)</span>
      <button type="button" id="close-crop-modal" class="w-5 h-5 flex items-center justify-center rounded bg-slate-100 hover:bg-rose-600 hover:text-white text-slate-500 text-xs font-bold transition-all">×</button>
    </div>
    
    <!-- Modal Body -->
    <div class="p-6 flex flex-col items-center gap-4 overflow-hidden flex-grow bg-slate-50/50">
      <!-- Cropper Container -->
      <div class="w-full flex-grow min-h-[320px] max-h-[450px] overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 flex items-center justify-center relative">
        <img id="crop-preview-img" class="max-w-full max-h-[400px] block" crossorigin="anonymous" src="" />
      </div>
      <p class="text-[9px] text-slate-400 select-none text-center">Arrastra el recuadro para mover el área de recorte o arrastra las esquinas para redimensionarla. El aspecto está fijado en 3:4.</p>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-2 shrink-0">
      <button type="button" id="cancel-crop-btn" class="px-4 py-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-650 hover:text-slate-900 rounded-xl text-xs font-bold uppercase transition-all select-none cursor-pointer">Cancelar</button>
      <button type="button" id="save-crop-btn" class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-xs font-bold uppercase transition-all select-none cursor-pointer">Recortar y Guardar</button>
    </div>
  </div>
</div>

<!-- Pass server collections to client side -->
<div id="collections-data-provider" data-collections={JSON.stringify(collections)} class="hidden"></div>
