---
import { db } from '../lib/firebase';
import type { Product, ProductCollection } from '../types';
import { getGeneralSettings } from '../lib/settings';
import { useTranslations } from '../lib/i18n';

let collections: ProductCollection[] = [];
try {
  const snap = await db.collection('collections').get();
  if (!snap.empty) {
    collections = snap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as ProductCollection);
  }
} catch (e) {
  console.error('Error loading collections for Navbar:', e);
}

let allProducts: Product[] = [];
try {
  const snap = await db.collection('products').orderBy('createdAt', 'desc').get();
  if (!snap.empty) {
    allProducts = snap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as Product);
  }
} catch (e) {
  console.error('Error loading products for Navbar search:', e);
}

// Helper to get color hex
const getColorHex = (colorName: string): string => {
  const name = colorName.toLowerCase().trim();
  const colorMap: Record<string, string> = {
    'negro': '#0f172a',
    'black': '#0f172a',
    'gris': '#94a3b8',
    'grey': '#94a3b8',
    'gray': '#94a3b8',
    'gris-oscuro': '#4b5563',
    'rosa': '#db2777',
    'pink': '#db2777',
    'rojo': '#dc2626',
    'red': '#dc2626',
    'azul': '#2563eb',
    'blue': '#2563eb',
    'verde': '#16a34a',
    'green': '#16a34a',
    'blanco': '#f8fafc',
    'white': '#f8fafc',
    'amarillo': '#ca8a04',
    'yellow': '#ca8a04',
    'lila': '#d8b4fe',
    'lavender': '#d8b4fe',
    'naranja': '#ea580c',
    'orange': '#ea580c',
    'marron': '#78350f',
    'brown': '#78350f',
    'beige': '#f5f5dc',
    'navy': '#1e3a8a',
    'marino': '#1e3a8a',
    'celeste': '#38bdf8',
    'unisex': '#64748b'
  };
  return colorMap[name] || '#cbd5e1';
};

interface SwatchColor {
  name: string;
  hex: string;
  image: string | null;
}

const getUniqueColors = (product: Product): SwatchColor[] => {
  if (!product.variants || product.variants.length === 0) return [];
  const colorMap = new Map<string, SwatchColor>();
  
  product.variants.forEach((v) => {
    const parts = v.name.split('/').map((p) => p.trim());
    const name = parts[0] || 'Base';
    
    if (!colorMap.has(name)) {
      const hex = v.colorHex || getColorHex(name);
      colorMap.set(name, {
        name: name,
        hex: hex,
        image: v.image || null
      });
    }
  });
  
  return Array.from(colorMap.values());
};

const minProducts = allProducts.map((p) => ({
  id: p.id,
  title: p.title,
  title_en: p.title_en || '',
  description: p.description,
  description_en: p.description_en || '',
  slug: p.slug,
  price: p.price,
  images: p.images || [],
  stock: p.stock || 0,
  uniqueColors: getUniqueColors(p)
}));

const user = Astro.locals.user;
const settings = await getGeneralSettings();

const { lang = 'es' } = Astro.params;
const t = useTranslations(lang);
const isEn = lang === 'en';

// Dynamic Mega Menu configuration
const megaMenu = settings.megaMenu;

// Column 1: Section 1
const s1Title = megaMenu?.section1?.title ? (isEn ? (megaMenu.section1.titleEn || megaMenu.section1.title) : megaMenu.section1.title) : (isEn ? "Our Collections" : "Nuestras Colecciones");
const s1Ids = megaMenu?.section1?.collectionIds;
const s1Collections = s1Ids 
  ? s1Ids.map(id => collections.find(c => c.id === id)).filter(Boolean) as ProductCollection[]
  : collections.slice(0, 5);

// Column 2: Section 2
const s2Title = megaMenu?.section2?.title ? (isEn ? (megaMenu.section2.titleEn || megaMenu.section2.title) : megaMenu.section2.title) : (isEn ? "More Categories" : "Más Categorías");
const s2Ids = megaMenu?.section2?.collectionIds;
const s2Collections = s2Ids 
  ? s2Ids.map(id => collections.find(c => c.id === id)).filter(Boolean) as ProductCollection[]
  : collections.slice(5);

// Promo 1: Lifestyle Image 1
const p1Image = megaMenu?.promo1?.imageUrl || "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600";
const p1Title = megaMenu?.promo1?.title 
  ? (isEn ? (megaMenu.promo1.titleEn || megaMenu.promo1.title) : megaMenu.promo1.title) 
  : (isEn ? "Men's Collection" : "Colección Hombre");
const p1Subtitle = megaMenu?.promo1?.subtitle 
  ? (isEn ? (megaMenu.promo1.subtitleEn || megaMenu.promo1.subtitle) : megaMenu.promo1.subtitle) 
  : (isEn ? "Explore New" : "Explorar Novedades");
const p1RawLink = megaMenu?.promo1?.linkUrl || 'hombre';
const p1Link = p1RawLink.startsWith('/') ? p1RawLink : `/${lang}/colecciones/${p1RawLink}`;

// Promo 2: Lifestyle Image 2
const p2Image = megaMenu?.promo2?.imageUrl || "https://images.unsplash.com/photo-1518310383802-640c2de311b2?w=600";
const p2Title = megaMenu?.promo2?.title 
  ? (isEn ? (megaMenu.promo2.titleEn || megaMenu.promo2.title) : megaMenu.promo2.title) 
  : (isEn ? "Women's Collection" : "Colección Mujer");
const p2Subtitle = megaMenu?.promo2?.subtitle 
  ? (isEn ? (megaMenu.promo2.subtitleEn || megaMenu.promo2.subtitle) : megaMenu.promo2.subtitle) 
  : (isEn ? "Explore New" : "Explorar Novedades");
const p2RawLink = megaMenu?.promo2?.linkUrl || 'mujer';
const p2Link = p2RawLink.startsWith('/') ? p2RawLink : `/${lang}/colecciones/${p2RawLink}`;
---

<!-- Announcement Bar -->
<div class="bg-slate-950 text-white py-2 px-3 text-center text-[9px] sm:text-[10px] md:text-xs font-bold tracking-wider sm:tracking-widest uppercase w-full">
  {t('announcement.free_shipping')} ${((settings.freeShippingMin || 5000) / 100).toFixed(0)}
</div>

<!-- Header / Navbar (Full Width) -->
<header class="w-full bg-white border-b border-slate-100 sticky top-0 z-50 relative">
  <div class="w-full flex justify-between items-center py-4 px-4 md:px-8">
    <div class="flex items-center gap-1.5 sm:gap-3 md:w-1/4 shrink-0">
      <!-- Hamburger Toggle Button -->
      <button type="button" id="mobile-menu-btn" class="md:hidden text-slate-800 focus:outline-none p-1 shrink-0" aria-label="Abrir Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>

      <!-- Mobile Search Icon (Magnifying Glass next to Hamburger) -->
      <button type="button" id="mobile-search-btn" class="md:hidden text-slate-700 hover:text-rose-650 transition-colors p-1 shrink-0 cursor-pointer focus:outline-none" aria-label={t('nav.search')}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </button>
      
      <!-- Logo (Centered absolutely on mobile, normal in flex flow on desktop) -->
      <a href={`/${lang}`} class="absolute left-1/2 -translate-x-1/2 md:static md:translate-x-0 flex items-center gap-1 group z-10">
        {settings.logoUrl ? (
          <img src={settings.logoUrl} alt="FLEX FORM FITNESS" class="h-6 sm:h-8 md:h-10 w-auto object-contain" />
        ) : (
          <div class="flex flex-col">
            <span class="text-base sm:text-2xl md:text-3xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
              FLEX <span class="text-rose-600">FORM</span>
            </span>
            <span class="text-[7.5px] sm:text-[9px] md:text-[10px] font-extrabold tracking-[0.18em] sm:tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5 group-hover:text-red-600 transition-colors">
              FITNESS
            </span>
          </div>
        )}
      </a>
    </div>

    <!-- Main Navigation Links -->
    <nav class="hidden md:flex items-center justify-center gap-8 md:w-2/4">
      <a href={`/${lang}`} class="text-xs font-bold tracking-widest text-slate-955 hover:text-red-600 uppercase transition-colors">
        {t('nav.home')}
      </a>
      <a href={`/${lang}/colecciones/hombre`} class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        {t('nav.men')}
      </a>
      <a href={`/${lang}/colecciones/mujer`} class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        {t('nav.women')}
      </a>
      
      <!-- Colecciones Mega Menu Dropdown -->
      <div class="py-2">
        <button type="button" id="collections-dropdown-btn" class="text-xs font-bold tracking-widest text-slate-600 hover:text-rose-600 uppercase transition-all flex items-center gap-1 focus:outline-none">
          {t('nav.collections')}
          <svg id="collections-dropdown-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        
        <!-- Mega Menu Dropdown Pane -->
        <div id="collections-mega-menu" class="absolute left-0 right-0 w-full top-full bg-white border-b border-slate-100 shadow-xl opacity-0 pointer-events-none transition-all duration-200 z-50 py-10 px-6 md:px-16">
          <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-10 text-left">
            
            <!-- Column 1: Colecciones Activas -->
            <div class="flex flex-col gap-4">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{s1Title}</span>
              <div class="flex flex-col gap-2.5">
                {s1Collections.length > 0 ? (
                  s1Collections.map((col) => (
                    <a 
                      href={`/${lang}/colecciones/${col.slug}`} 
                      class="text-xs font-bold tracking-wider uppercase text-slate-800 hover:text-rose-600 transition-colors flex items-center gap-2"
                    >
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                      </svg>
                      {isEn ? (col.title_en || col.title) : col.title}
                    </a>
                  ))
                ) : (
                  <span class="text-xs text-slate-400 italic">{t('nav.no_collections')}</span>
                )}
              </div>
            </div>

            <!-- Column 2: Más Colecciones / Sección 2 -->
            <div class="flex flex-col gap-4">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{s2Title}</span>
              <div class="flex flex-col gap-2.5">
                {s2Collections.length > 0 ? (
                  s2Collections.map((col) => (
                    <a 
                      href={`/${lang}/colecciones/${col.slug}`} 
                      class="text-xs font-bold tracking-wider uppercase text-slate-800 hover:text-rose-600 transition-colors flex items-center gap-2"
                    >
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                      </svg>
                      {isEn ? (col.title_en || col.title) : col.title}
                    </a>
                  ))
                ) : (
                  <div class="flex flex-col gap-2.5">
                    <a href={`/${lang}#catalogo`} class="text-xs font-bold tracking-wider uppercase text-slate-855 hover:text-rose-600 transition-colors flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12.75 15l3-3m0 0l-3-3m3 3h-7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      {t('nav.all_catalog')}
                    </a>
                    <a href="/admin/dashboard" class="text-xs font-bold tracking-wider uppercase text-slate-855 hover:text-rose-600 transition-colors flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"></path></svg>
                      {t('nav.admin_panel')}
                    </a>
                  </div>
                )}
              </div>
            </div>

            <!-- Column 3: Lifestyle Image 1 -->
            <div class="group/img relative aspect-[4/3] rounded-2xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100">
              <img 
                src={p1Image} 
                alt={p1Title} 
                class="w-full h-full object-cover object-center group-hover/img:scale-105 transition-transform duration-500" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-4">
                <span class="text-white text-xs font-black tracking-wider uppercase">{p1Title}</span>
                <span class="text-[10px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">{p1Subtitle}</span>
              </div>
              <a href={p1Link} class="absolute inset-0 z-10" aria-label={p1Title}></a>
            </div>

            <!-- Column 4: Lifestyle Image 2 -->
            <div class="group/img relative aspect-[4/3] rounded-2xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100">
              <img 
                src={p2Image} 
                alt={p2Title} 
                class="w-full h-full object-cover object-center group-hover/img:scale-105 transition-transform duration-500" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-4">
                <span class="text-white text-xs font-black tracking-wider uppercase">{p2Title}</span>
                <span class="text-[10px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">{p2Subtitle}</span>
              </div>
              <a href={p2Link} class="absolute inset-0 z-10" aria-label={p2Title}></a>
            </div>

          </div>
        </div>
      </div>

      <a href={`/${lang}#contacto`} class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        {t('nav.contact')}
      </a>
    </nav>

    <!-- Right Side Icons -->
    <div class="flex items-center justify-end gap-2 sm:gap-4 md:gap-6 md:w-1/4 shrink-0">
      
      <!-- Interactive Language Selector (Desktop only) -->
      <div class="relative group/lang py-1 hidden md:block">
        <button type="button" class="flex items-center gap-1 text-3xs md:text-2xs font-extrabold text-slate-700 hover:text-slate-950 focus:outline-none uppercase tracking-wider cursor-pointer">
          <span>{isEn ? "🇺🇸" : "🇪🇸"}</span>
          <span class="hidden sm:inline">{isEn ? "EN" : "ES"}</span>
          <svg class="w-2.5 h-2.5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div class="absolute right-0 top-full pt-1 opacity-0 pointer-events-none group-hover/lang:opacity-100 group-hover/lang:pointer-events-auto transition-all duration-200 z-50">
          <div class="bg-white border border-slate-100 shadow-lg rounded-xl py-2 px-1.5 min-w-[110px] flex flex-col gap-1">
            <button type="button" class="lang-switch-btn w-full text-left px-2.5 py-1.5 rounded-lg text-2xs font-bold hover:bg-slate-50 flex items-center gap-2 cursor-pointer text-slate-800" data-lang="es">
              <span>🇪🇸</span> Español
            </button>
            <button type="button" class="lang-switch-btn w-full text-left px-2.5 py-1.5 rounded-lg text-2xs font-bold hover:bg-slate-50 flex items-center gap-2 cursor-pointer text-slate-800" data-lang="en">
              <span>🇺🇸</span> English
            </button>
          </div>
        </div>
      </div>

      <!-- Search Icon (Desktop only) -->
      <button type="button" id="desktop-search-btn" class="hidden md:block text-slate-700 hover:text-rose-655 transition-colors p-1 cursor-pointer focus:outline-none" aria-label={t('nav.search')}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </button>

      <!-- Profile / Session Info (Dynamic client-side hydration container) -->
      <div id="nav-user-section" class="flex items-center gap-2 sm:gap-3">
        {user ? (
          <a href={`/${lang}/mi-cuenta`} class="text-slate-700 hover:text-rose-600 transition-colors relative flex items-center shrink-0" title={`Conectado como ${user.name}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-emerald-500 border border-white animate-pulse"></span>
          </a>
        ) : (
          <a href={`/${lang}/login`} class="text-slate-700 hover:text-rose-600 transition-colors relative flex items-center shrink-0" title={t('nav.signin')}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-slate-350 border border-white"></span>
          </a>
        )}
      </div>

      <!-- Cart Icon -->
      <a href={`/${lang}/carrito`} class="text-slate-700 hover:text-rose-600 transition-colors relative" aria-label={t('nav.cart')}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        <span id="cart-badge" class="absolute -top-1.5 -right-1.5 bg-rose-600 text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-bold hidden">0</span>
      </a>
    </div>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div id="mobile-drawer" class="fixed inset-0 bg-slate-900/60 z-50 transition-all duration-300 opacity-0 pointer-events-none md:hidden backdrop-blur-xs">
  <div class="w-4/5 max-w-sm h-[100dvh] bg-white flex flex-col justify-between shadow-2xl relative translate-x-[-100%] transition-transform duration-300" id="mobile-drawer-pane">
    
    <!-- Drawer Header -->
    <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50">
      <a href={`/${lang}`} class="flex items-center gap-2 group">
        {settings.logoUrl ? (
          <img src={settings.logoUrl} alt="FLEX FORM FITNESS" class="h-8 w-auto object-contain" />
        ) : (
          <div class="flex flex-col">
            <span class="text-xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
              FLEX <span class="text-rose-600">FORM</span>
            </span>
            <span class="text-[9px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5">
              FITNESS
            </span>
          </div>
        )}
      </a>
      <button type="button" id="close-mobile-drawer" class="text-slate-500 hover:text-slate-800 text-xl font-bold p-1">
        ×
      </button>
    </div>

    <!-- Drawer Navigation -->
    <div class="flex-grow overflow-y-auto p-6 flex flex-col gap-6 text-xs">
      <div class="flex flex-col gap-4">
        <a href={`/${lang}`} class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          {t('nav.home')}
        </a>
        <a href={`/${lang}/colecciones/hombre`} class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          {t('nav.men')}
        </a>
        <a href={`/${lang}/colecciones/mujer`} class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          {t('nav.women')}
        </a>
        <a href={`/${lang}#contacto`} class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          {t('nav.contact')}
        </a>
      </div>

      <!-- Expandable Collections accordion -->
      <div class="border-t border-slate-100 pt-5 flex flex-col gap-3">
        <button type="button" id="mobile-coll-trigger" class="flex justify-between items-center text-xs font-black tracking-widest text-slate-500 uppercase">
          <span>{t('nav.collections')}</span>
          <svg id="mobile-coll-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-coll-list" class="flex flex-col gap-5 pl-3 mt-1 hidden transition-all">
          <!-- Section 1 Group -->
          {s1Collections.length > 0 && (
            <div class="flex flex-col gap-2.5">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest block">{s1Title}</span>
              <div class="flex flex-col gap-2 pl-2 border-l border-slate-100">
                {s1Collections.map((col) => (
                  <a 
                    href={`/${lang}/colecciones/${col.slug}`} 
                    class="text-2xs font-bold uppercase text-slate-700 hover:text-rose-600 transition-colors flex items-center gap-2"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>
                    {isEn ? (col.title_en || col.title) : col.title}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Section 2 Group -->
          {s2Collections.length > 0 && (
            <div class="flex flex-col gap-2.5">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest block">{s2Title}</span>
              <div class="flex flex-col gap-2 pl-2 border-l border-slate-100">
                {s2Collections.map((col) => (
                  <a 
                    href={`/${lang}/colecciones/${col.slug}`} 
                    class="text-2xs font-bold uppercase text-slate-700 hover:text-rose-600 transition-colors flex items-center gap-2"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>
                    {isEn ? (col.title_en || col.title) : col.title}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Promo Images stacked in a single column -->
          <div class="flex flex-col gap-4 mt-2">
            <!-- Promo 1 -->
            <div class="group/img relative aspect-[16/10] rounded-xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100 max-w-[280px]">
              <img 
                src={p1Image} 
                alt={p1Title} 
                class="w-full h-full object-cover object-center" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-3">
                <span class="text-white text-3xs font-black tracking-wider uppercase">{p1Title}</span>
                <span class="text-[8px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">{p1Subtitle}</span>
              </div>
              <a href={p1Link} class="absolute inset-0 z-10" aria-label={p1Title}></a>
            </div>

            <!-- Promo 2 -->
            <div class="group/img relative aspect-[16/10] rounded-xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100 max-w-[280px]">
              <img 
                src={p2Image} 
                alt={p2Title} 
                class="w-full h-full object-cover object-center" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-3">
                <span class="text-white text-3xs font-black tracking-wider uppercase">{p2Title}</span>
                <span class="text-[8px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">{p2Subtitle}</span>
              </div>
              <a href={p2Link} class="absolute inset-0 z-10" aria-label={p2Title}></a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Drawer Footer (Dynamic client-side hydration container) -->
    <div id="mobile-drawer-user-section" class="p-6 border-t border-slate-100 bg-slate-50 flex flex-col gap-4 text-3xs font-extrabold tracking-widest uppercase">
      {user ? (
        <div class="flex flex-col gap-2.5">
          <div class="flex flex-col gap-2.5 p-3.5 bg-white rounded-xl border border-slate-100 shadow-3xs">
            <div class="flex items-center gap-2 truncate">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
              <span class="text-3xs font-bold text-slate-700 normal-case truncate max-w-[180px]">{user.name}</span>
            </div>
            <a href={`/${lang}/mi-cuenta`} class="block text-center text-3xs font-extrabold uppercase text-rose-600 hover:text-rose-700 bg-rose-50 py-2 rounded-lg transition-colors border border-rose-100">
              {isEn ? 'My Account' : 'Mi Cuenta'}
            </a>
          </div>
          <a href="/api/auth/logout" class="block text-center border border-slate-200 hover:border-rose-600 text-slate-600 hover:text-rose-600 py-2 rounded-lg transition-colors">
            {t('nav.signout')}
          </a>
        </div>
      ) : (
        <a href={`/${lang}/login`} class="block text-center bg-slate-900 hover:bg-rose-600 text-white py-2.5 rounded-lg transition-colors shadow-2xs">
          {t('nav.signin')}
        </a>
      )}
    </div>
  </div>
</div>

<!-- Full-screen Search Modal -->
<div id="search-modal" class="fixed inset-0 bg-white z-[100] w-screen h-screen min-h-screen flex flex-col opacity-0 pointer-events-none transition-all duration-300 overflow-y-auto">
  
  <!-- Sticky Header Bar -->
  <header class="w-full bg-white border-b border-slate-100 py-4 px-4 md:px-8 sticky top-0 z-[110] flex items-center justify-between">
    <div class="w-full max-w-7xl mx-auto flex items-center gap-4">
      <button type="button" id="close-search-modal" class="text-slate-700 hover:text-rose-600 transition-colors p-2 cursor-pointer focus:outline-none flex items-center" title={isEn ? "Back" : "Volver"}>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      </button>
      <input
        type="text"
        id="search-modal-input"
        placeholder={isEn ? "What are you looking for?" : "¿Qué estás buscando?"}
        class="w-full bg-transparent text-slate-900 text-base md:text-xl font-extrabold placeholder-slate-400 focus:outline-none"
      />
      <button type="button" id="search-modal-clear" class="text-slate-400 hover:text-slate-905 text-xl font-bold p-2 hidden cursor-pointer leading-none" title={isEn ? "Clear Search" : "Limpiar búsqueda"}>
        ×
      </button>
    </div>
  </header>

  <!-- Modal Main Content Area -->
  <main class="flex-grow w-full overflow-y-auto bg-slate-50/20 px-2 sm:px-4 md:px-8 py-10">
    <div class="w-full max-w-7xl mx-auto flex flex-col gap-6">
      
      <!-- Initial Placeholder / Prompt -->
      <div id="search-modal-prompt" class="flex flex-col items-center justify-center py-24 text-slate-400 gap-4 text-center">
        <svg class="w-12 h-12 text-slate-350 animate-pulse" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <div class="flex flex-col gap-1">
          <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider">{isEn ? "Search catalog" : "Buscar en el catálogo"}</h3>
          <p class="text-xs text-slate-450">{isEn ? "Type keywords to search products instantly." : "Escribe palabras clave para buscar productos al instante."}</p>
        </div>
      </div>

      <!-- Empty State -->
      <div id="search-modal-empty" class="hidden flex flex-col items-center justify-center py-20 text-slate-400 gap-4 text-center bg-slate-50 rounded-3xl border border-slate-100 p-8 max-w-md mx-auto">
        <svg class="w-12 h-12 text-slate-350" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div class="flex flex-col gap-1">
          <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider">{isEn ? "No results found" : "Sin resultados"}</h3>
          <p class="text-xs text-slate-500">{isEn ? "We couldn't find matches. Double check spelling." : "No encontramos coincidencias. Revisa la ortografía."}</p>
        </div>
      </div>

      <!-- Results Grid Container -->
      <div id="search-modal-results" class="hidden flex flex-col gap-6 w-full animate-fade-in">
        <div class="flex justify-between items-center border-b border-slate-100 pb-3">
          <span id="search-modal-status" class="text-3xs text-slate-500 font-extrabold uppercase tracking-widest"></span>
        </div>
        <div id="search-modal-grid" class="grid grid-cols-2 md:grid-cols-4 gap-2 sm:gap-3 md:gap-6 w-full">
          <!-- Dynamically populated exactly like product catalog grid -->
        </div>
      </div>
      
    </div>
  </main>

  <!-- Footer Info -->
  <footer class="w-full bg-slate-900 text-slate-500 py-6 px-4 md:px-8 border-t border-slate-850 mt-auto flex justify-between items-center text-4xs font-extrabold tracking-widest uppercase select-none">
    <span>FLEX FORM FITNESS</span>
    <span>&copy; {new Date().getFullYear()}</span>
  </footer>
</div>

<script id="navbar-products-data" type="application/json" set:html={JSON.stringify(minProducts)}></script>

<script>
  import { cartStore } from '../stores/cart';
  import { auth } from '../lib/firebaseClient';
  import { onAuthStateChanged } from 'firebase/auth';

  // Helper to read language dynamically from route pathname segment
  function getLang() {
    const segs = window.location.pathname.split('/');
    return (segs[1] === 'en' || segs[1] === 'es') ? segs[1] : 'es';
  }

  // Intercept logout clicks to sign out of Firebase Client SDK before hitting server-side logout
  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const logoutLink = target.closest('a[href="/api/auth/logout"]');
    if (logoutLink) {
      e.preventDefault();
      try {
        const { signOut } = await import('firebase/auth');
        await signOut(auth);
      } catch (err) {
        console.error('Error signing out client-side:', err);
      }
      window.location.href = '/api/auth/logout';
    }
  });

  // Language switching script
  document.querySelectorAll('.lang-switch-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetLang = btn.getAttribute('data-lang') || 'es';
      
      const pathname = window.location.pathname;
      const segments = pathname.split('/');
      
      if (segments[1] === 'es' || segments[1] === 'en') {
        segments[1] = targetLang;
      } else {
        segments.splice(1, 0, targetLang);
      }
      
      window.location.pathname = segments.join('/');
    });
  });

  // Listen to client-side auth state to update navbar dynamically on static pre-rendered routes
  onAuthStateChanged(auth, (usr) => {
    const desktopContainer = document.getElementById('nav-user-section');
    const mobileContainer = document.getElementById('mobile-drawer-user-section');
    const lang = getLang();
    const isEn = lang === 'en';
    
    if (usr) {
      const name = usr.displayName || usr.email?.split('@')[0] || 'Usuario';
      
      if (desktopContainer) {
        desktopContainer.innerHTML = `
          <a href="/${lang}/mi-cuenta" class="text-slate-700 hover:text-rose-600 transition-colors relative flex items-center shrink-0" title="${isEn ? 'Connected as' : 'Conectado como'} ${name}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-emerald-500 border border-white animate-pulse"></span>
          </a>
        `;
      }
      
      if (mobileContainer) {
        mobileContainer.innerHTML = `
          <div class="flex flex-col gap-2.5">
            <div class="flex flex-col gap-2.5 p-3.5 bg-white rounded-xl border border-slate-100 shadow-3xs">
              <div class="flex items-center gap-2 truncate">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
                <span class="text-3xs font-bold text-slate-700 normal-case truncate max-w-[180px]">${name}</span>
              </div>
              <a href="/${lang}/mi-cuenta" class="block text-center text-3xs font-extrabold uppercase text-rose-600 hover:text-rose-700 bg-rose-50 py-2 rounded-lg transition-colors border border-rose-100">
                ${isEn ? 'My Account' : 'Mi Cuenta'}
              </a>
            </div>
            <a href="/api/auth/logout" class="block text-center border border-slate-200 hover:border-rose-600 text-slate-600 hover:text-rose-600 py-2 rounded-lg transition-colors">
              ${isEn ? 'Sign Out' : 'Cerrar Sesión'}
            </a>
          </div>
        `;
      }
    } else {
      if (desktopContainer) {
        desktopContainer.innerHTML = `
          <a href="/${lang}/login" class="text-slate-700 hover:text-rose-600 transition-colors relative flex items-center shrink-0" title="${isEn ? 'Sign In' : 'Iniciar sesión'}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-slate-350 border border-white"></span>
          </a>
        `;
      }
      
      if (mobileContainer) {
        mobileContainer.innerHTML = `
          <div class="flex flex-col gap-3">
            <a href="/${lang}/login" class="block text-center bg-slate-900 hover:bg-rose-600 text-white py-2.5 rounded-lg transition-colors shadow-2xs">
              ${isEn ? 'Sign In' : 'Iniciar Sesión'}
            </a>
          </div>
        `;
      }
    }
  });

  // Update cart count badge in navbar dynamically
  cartStore.subscribe((cart) => {
    const count = Object.values(cart).reduce((sum, item) => sum + item.quantity, 0);
    const badge = document.getElementById('cart-badge');
    if (badge) {
      badge.textContent = String(count);
      if (count === 0) {
        badge.classList.add('hidden');
      } else {
        badge.classList.remove('hidden');
      }
    }
  });

  // Control click dropdown behavior for collections mega menu
  const btn = document.getElementById('collections-dropdown-btn');
  const dropdown = document.getElementById('collections-mega-menu');
  const arrow = document.getElementById('collections-dropdown-arrow');
  
  if (btn && dropdown) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isClosed = dropdown.classList.contains('opacity-0');
      
      if (isClosed) {
        dropdown.classList.remove('opacity-0', 'pointer-events-none');
        dropdown.classList.add('opacity-100', 'pointer-events-auto');
        if (arrow) arrow.classList.add('rotate-180', 'text-rose-600');
      } else {
        dropdown.classList.remove('opacity-100', 'pointer-events-auto');
        dropdown.classList.add('opacity-0', 'pointer-events-none');
        if (arrow) arrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!dropdown.contains(target) && !btn.contains(target)) {
        dropdown.classList.remove('opacity-100', 'pointer-events-auto');
        dropdown.classList.add('opacity-0', 'pointer-events-none');
        if (arrow) arrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });
  }

  // Control Mobile Drawer Open/Close
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const mobileDrawerPane = document.getElementById('mobile-drawer-pane');
  const closeDrawerBtn = document.getElementById('close-mobile-drawer');
  
  if (mobileBtn && mobileDrawer && mobileDrawerPane) {
    const openDrawer = () => {
      mobileDrawer.classList.remove('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.add('opacity-100', 'pointer-events-auto');
      mobileDrawerPane.classList.remove('translate-x-[-100%]');
      mobileDrawerPane.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    };

    const closeDrawer = () => {
      mobileDrawer.classList.add('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.remove('opacity-100', 'pointer-events-auto');
      mobileDrawerPane.classList.remove('translate-x-0');
      mobileDrawerPane.classList.add('translate-x-[-100%]');
      document.body.style.overflow = '';
    };

    mobileBtn.addEventListener('click', openDrawer);
    closeDrawerBtn?.addEventListener('click', closeDrawer);
    mobileDrawer.addEventListener('click', (e) => {
      if (e.target === mobileDrawer) closeDrawer();
    });
  }

  // Mobile Collections accordion toggle
  const collTrigger = document.getElementById('mobile-coll-trigger');
  const collList = document.getElementById('mobile-coll-list');
  const collArrow = document.getElementById('mobile-coll-arrow');

  if (collTrigger && collList) {
    collTrigger.addEventListener('click', () => {
      const isHidden = collList.classList.contains('hidden');
      if (isHidden) {
        collList.classList.remove('hidden');
        if (collArrow) collArrow.classList.add('rotate-180', 'text-rose-600');
      } else {
        collList.classList.add('hidden');
        if (collArrow) collArrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });
  }

  // Search Modal Client Logic
  (function() {
    const searchModal = document.getElementById('search-modal');
    const searchInput = document.getElementById('search-modal-input') as HTMLInputElement;
    const closeBtn = document.getElementById('close-search-modal');
    const clearBtn = document.getElementById('search-modal-clear');
    const promptState = document.getElementById('search-modal-prompt');
    const emptyState = document.getElementById('search-modal-empty');
    const resultsContainer = document.getElementById('search-modal-results');
    const resultsGrid = document.getElementById('search-modal-grid');
    const statusLabel = document.getElementById('search-modal-status');

    const productsDataEl = document.getElementById('navbar-products-data');
    const products = productsDataEl ? JSON.parse(productsDataEl.textContent || '[]') : [];

    const mobileSearchTrigger = document.getElementById('mobile-search-btn');
    const desktopSearchTrigger = document.getElementById('desktop-search-btn');
    const lang = getLang();
    const isEn = lang === 'en';

    function getObjectPosition(url: string | undefined): string {
      if (!url) return 'center';
      const match = url.match(/#pos=([a-zA-Z0-9%_-]+)/);
      if (match && match[1]) {
        return match[1].replace('_', ' ');
      }
      return 'center';
    }

    const openSearch = (e: Event) => {
      e.preventDefault();
      if (!searchModal || !searchInput) return;

      // Close mobile drawer if open
      const mobileDrawer = document.getElementById('mobile-drawer');
      const mobileDrawerPane = document.getElementById('mobile-drawer-pane');
      if (mobileDrawer && mobileDrawerPane && !mobileDrawer.classList.contains('opacity-0')) {
        mobileDrawer.classList.add('opacity-0', 'pointer-events-none');
        mobileDrawer.classList.remove('opacity-100', 'pointer-events-auto');
        mobileDrawerPane.classList.remove('translate-x-0');
        mobileDrawerPane.classList.add('translate-x-[-100%]');
      }

      // Reset state
      searchInput.value = '';
      clearBtn?.classList.add('hidden');
      promptState?.classList.remove('hidden');
      emptyState?.classList.add('hidden');
      resultsContainer?.classList.add('hidden');
      if (resultsGrid) resultsGrid.innerHTML = '';
      if (statusLabel) statusLabel.textContent = isEn ? '0 results' : '0 resultados';

      // Open animations
      searchModal.classList.remove('opacity-0', 'pointer-events-none');
      searchModal.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';

      setTimeout(() => searchInput.focus(), 120);
    };

    const closeSearch = () => {
      if (!searchModal) return;
      searchModal.classList.add('opacity-0', 'pointer-events-none');
      searchModal.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    };

    mobileSearchTrigger?.addEventListener('click', openSearch);
    desktopSearchTrigger?.addEventListener('click', openSearch);
    closeBtn?.addEventListener('click', closeSearch);
    
    clearBtn?.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.focus();
      searchInput.dispatchEvent(new Event('input'));
    });

    searchModal?.addEventListener('click', (e) => {
      if (e.target === searchModal) closeSearch();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
    });

    function setupCardInteractions(card: HTMLElement) {
      const slider = card.querySelector('.product-images-slider') as HTMLDivElement;
      const arrowLeft = card.querySelector('.slider-arrow-left') as HTMLButtonElement;
      const arrowRight = card.querySelector('.slider-arrow-right') as HTMLButtonElement;
      const swatches = card.querySelectorAll('.color-swatch-btn') as NodeListOf<HTMLButtonElement>;

      if (slider) {
        arrowLeft?.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          slider.scrollLeft -= slider.clientWidth;
        });

        arrowRight?.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          slider.scrollLeft += slider.clientWidth;
        });
      }

      swatches.forEach((swatch) => {
        swatch.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          const imgUrl = swatch.dataset.variantImage;
          if (!imgUrl || !slider) return;

          const slides = Array.from(slider.querySelectorAll('img'));
          const matchedIndex = slides.findIndex((img) => {
            const src = img.getAttribute('src') || '';
            return src === imgUrl || img.src === imgUrl;
          });

          if (matchedIndex !== -1) {
            slider.scrollLeft = matchedIndex * slider.clientWidth;
          } else {
            const firstImg = slides[0];
            if (firstImg) {
              firstImg.src = imgUrl;
              slider.scrollLeft = 0;
            }
          }
        });
      });
    }

    searchInput?.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase();

      if (query === '') {
        clearBtn?.classList.add('hidden');
        promptState?.classList.remove('hidden');
        emptyState?.classList.add('hidden');
        resultsContainer?.classList.add('hidden');
        if (resultsGrid) resultsGrid.innerHTML = '';
        if (statusLabel) statusLabel.textContent = isEn ? '0 results' : '0 resultados';
        return;
      }

      clearBtn?.classList.remove('hidden');

      const results = products.filter((p: any) => {
        const titleText = isEn ? (p.title_en || p.title) : p.title;
        return titleText.toLowerCase().includes(query);
      });

      if (statusLabel) {
        if (results.length === 1) {
          statusLabel.textContent = isEn ? '1 product found' : '1 producto encontrado';
        } else {
          statusLabel.textContent = isEn 
            ? `${results.length} products found` 
            : `${results.length} productos encontrados`;
        }
      }

      if (results.length === 0) {
        promptState?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        resultsContainer?.classList.add('hidden');
        if (resultsGrid) resultsGrid.innerHTML = '';
      } else {
        promptState?.classList.add('hidden');
        emptyState?.classList.add('hidden');
        resultsContainer?.classList.remove('hidden');

        if (resultsGrid) {
          resultsGrid.innerHTML = results.map((p: any) => {
            const imageList = p.images.length > 0 ? p.images : ['/images/default-product.jpg'];
            const imagesSliderHtml = imageList.map((imgUrl: string, imgIdx: number) => `
              <a
                href="/${lang}/productos/${p.slug}"
                class="block w-full h-full shrink-0 snap-start snap-always relative overflow-hidden"
                data-index="${imgIdx}"
                style="aspect-ratio: 3/4;"
              >
                <img
                  src="${imgUrl}"
                  alt="${isEn ? (p.title_en || p.title) : p.title} - Vista ${imgIdx + 1}"
                  class="w-full h-full object-cover group-hover:scale-[1.01] transition-opacity duration-300 opacity-0"
                  style="object-position: ${getObjectPosition(imgUrl)}"
                  loading="${imgIdx === 0 ? 'eager' : 'lazy'}"
                  onload="this.classList.remove('opacity-0')"
                />
              </a>
            `).join('');

            const arrowsHtml = imageList.length > 1 ? `
              <button
                type="button"
                class="slider-arrow-left absolute left-2 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-slate-800 flex items-center justify-center shadow-md opacity-0 group-hover/slider:opacity-100 transition-opacity active:scale-90 z-10 cursor-pointer hidden md:flex"
                title="${isEn ? 'Previous image' : 'Imagen anterior'}"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
              </button>
              <button
                type="button"
                class="slider-arrow-right absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-slate-800 flex items-center justify-center shadow-md opacity-0 group-hover/slider:opacity-100 transition-opacity active:scale-90 z-10 cursor-pointer hidden md:flex"
                title="${isEn ? 'Next image' : 'Siguiente imagen'}"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            ` : '';

            const swatchesHtml = p.uniqueColors && p.uniqueColors.length > 0 ? `
              <div class="flex items-center gap-1.5 mt-1">
                ${p.uniqueColors.map((color: any) => `
                  <button 
                    type="button"
                    class="color-swatch-btn w-4 h-4 rounded-full border border-slate-200/80 shadow-3xs hover:scale-110 active:scale-90 transition-transform cursor-pointer focus:outline-none" 
                    style="background-color: ${color.hex}"
                    title="${color.name}"
                    data-variant-image="${color.image || ''}"
                  ></button>
                `).join('')}
              </div>
            ` : '';

            const stockWarningHtml = p.stock <= 5 ? `
              <span class="absolute top-3 left-3 px-2 py-1 bg-rose-600 text-white text-[9px] font-bold uppercase tracking-wider z-10">
                ${isEn ? 'LAST ITEMS' : 'ÚLTIMAS UNIDADES'}
              </span>
            ` : '';

            return `
              <div class="product-card group flex flex-col justify-between w-full">
                <div class="relative aspect-[3/4] w-full bg-slate-50 border border-slate-100 overflow-hidden group/slider" style="aspect-ratio: 3/4; overflow: hidden;">
                  <div class="product-images-slider flex w-full h-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-none" style="scrollbar-width: none; -ms-overflow-style: none;">
                    ${imagesSliderHtml}
                  </div>
                  ${arrowsHtml}
                  ${stockWarningHtml}
                </div>

                <div class="mt-3 flex flex-col gap-1 w-full text-left">
                  <span class="text-slate-400 text-[9px] font-bold uppercase tracking-widest">FLEX FORM</span>
                  <a href="/${lang}/productos/${p.slug}" class="text-sm font-bold text-slate-900 hover:text-rose-600 transition-colors line-clamp-1">
                    ${isEn ? (p.title_en || p.title) : p.title}
                  </a>
                  <p class="text-slate-500 text-xs line-clamp-1">
                    ${isEn ? (p.description_en || p.description) : p.description}
                  </p>
                  ${swatchesHtml}
                  
                  <div class="flex justify-between items-center mt-2 pt-1.5 border-t border-slate-100">
                    <span class="text-sm font-extrabold text-slate-950">
                      $${(p.price / 100).toFixed(2)}
                    </span>
                    <a href="/${lang}/productos/${p.slug}" class="text-[10px] font-bold text-rose-600 group-hover:underline hover:text-rose-700 uppercase tracking-wider">
                      ${isEn ? 'View details' : 'Ver más'}
                    </a>
                  </div>
                </div>
              </div>
            `;
          }).join('');

          // Bind swatches and arrows events for all new cards
          resultsGrid.querySelectorAll('.product-card').forEach((cardEl) => {
            setupCardInteractions(cardEl as HTMLElement);
          });
        }
      }
    });
  })();
</script>
