---
import { db } from '../lib/firebase';
import type { ProductCollection } from '../types';
import { getGeneralSettings } from '../lib/settings';

let collections: ProductCollection[] = [];
try {
  const snap = await db.collection('collections').get();
  if (!snap.empty) {
    collections = snap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as ProductCollection);
  }
} catch (e) {
  console.error('Error loading collections for Navbar:', e);
}

const user = Astro.locals.user;
const settings = await getGeneralSettings();
---

<!-- Announcement Bar -->
<div class="bg-slate-950 text-white py-2.5 px-4 text-center text-3xs md:text-2xs font-bold tracking-widest uppercase w-full">
  ENVÍO GRATUITO PARA PEDIDOS SUPERIORES A ${(settings.freeShippingMin / 100).toFixed(0)}€
</div>

<!-- Header / Navbar (Full Width) -->
<header class="w-full bg-white border-b border-slate-100 py-4 px-4 md:px-8 sticky top-0 z-50 relative">
  <div class="w-full flex justify-between items-center">
    <div class="flex items-center gap-3 md:w-1/4 shrink-0">
      <!-- Hamburger Toggle Button -->
      <button type="button" id="mobile-menu-btn" class="md:hidden text-slate-800 focus:outline-none p-1 shrink-0" aria-label="Abrir Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        {settings.logoUrl ? (
          <img src={settings.logoUrl} alt="FLEX FORM FITNESS" class="h-8 md:h-10 w-auto object-contain" />
        ) : (
          <div class="flex flex-col">
            <span class="text-2xl md:text-3xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
              FLEX <span class="text-rose-600">FORM</span>
            </span>
            <span class="text-[9px] md:text-[10px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5 group-hover:text-red-600 transition-colors">
              FITNESS
            </span>
          </div>
        )}
      </a>
    </div>

    <!-- Main Navigation Links -->
    <nav class="hidden md:flex items-center justify-center gap-8 md:w-2/4">
      <a href="/" class="text-xs font-bold tracking-widest text-slate-955 hover:text-red-600 uppercase transition-colors">
        INICIO
      </a>
      <a href="/colecciones/hombre" class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        HOMBRE
      </a>
      <a href="/colecciones/mujer" class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        MUJER
      </a>
      
      <!-- Colecciones Mega Menu Dropdown -->
      <div class="py-2">
        <button type="button" id="collections-dropdown-btn" class="text-xs font-bold tracking-widest text-slate-600 hover:text-rose-600 uppercase transition-all flex items-center gap-1 focus:outline-none">
          COLECCIONES
          <svg id="collections-dropdown-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        
        <!-- Mega Menu Dropdown Pane -->
        <div id="collections-mega-menu" class="absolute left-0 right-0 w-full top-full bg-white border-b border-slate-100 shadow-xl opacity-0 pointer-events-none transition-all duration-200 z-50 py-10 px-6 md:px-16">
          <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-10 text-left">
            
            <!-- Column 1: Colecciones Activas -->
            <div class="flex flex-col gap-4">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Nuestras Colecciones</span>
              <div class="flex flex-col gap-2.5">
                {collections.length > 0 ? (
                  collections.slice(0, 5).map((col) => (
                    <a 
                      href={`/colecciones/${col.slug}`} 
                      class="text-xs font-bold tracking-wider uppercase text-slate-800 hover:text-rose-600 transition-colors flex items-center gap-2"
                    >
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                      </svg>
                      {col.title}
                    </a>
                  ))
                ) : (
                  <span class="text-xs text-slate-400 italic">No hay colecciones</span>
                )}
              </div>
            </div>

            <!-- Column 2: Más Colecciones -->
            <div class="flex flex-col gap-4">
              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Más Categorías</span>
              <div class="flex flex-col gap-2.5">
                {collections.length > 5 ? (
                  collections.slice(5).map((col) => (
                    <a 
                      href={`/colecciones/${col.slug}`} 
                      class="text-xs font-bold tracking-wider uppercase text-slate-800 hover:text-rose-600 transition-colors flex items-center gap-2"
                    >
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                      </svg>
                      {col.title}
                    </a>
                  ))
                ) : (
                  <div class="flex flex-col gap-2.5">
                    <a href="/#catalogo" class="text-xs font-bold tracking-wider uppercase text-slate-850 hover:text-rose-600 transition-colors flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12.75 15l3-3m0 0l-3-3m3 3h-7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      Ver Todo el Catálogo
                    </a>
                    <a href="/admin/dashboard" class="text-xs font-bold tracking-wider uppercase text-slate-850 hover:text-rose-600 transition-colors flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"></path></svg>
                      Gestionar Carpetas (Admin)
                    </a>
                  </div>
                )}
              </div>
            </div>

            <!-- Column 3: Lifestyle Image 1 (Men) -->
            <div class="group/img relative aspect-[4/3] rounded-2xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100">
              <img 
                src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600" 
                alt="Men Activewear" 
                class="w-full h-full object-cover object-center group-hover/img:scale-105 transition-transform duration-500" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-4">
                <span class="text-white text-xs font-black tracking-wider uppercase">Colección Hombre</span>
                <span class="text-[10px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">Explorar Novedades</span>
              </div>
              <a href="/colecciones/hombre" class="absolute inset-0 z-10" aria-label="Explorar Colección de Hombre"></a>
            </div>

            <!-- Column 4: Lifestyle Image 2 (Women) -->
            <div class="group/img relative aspect-[4/3] rounded-2xl overflow-hidden shadow-sm bg-slate-100 border border-slate-100">
              <img 
                src="https://images.unsplash.com/photo-1518310383802-640c2de311b2?w=600" 
                alt="Women Activewear" 
                class="w-full h-full object-cover object-center group-hover/img:scale-105 transition-transform duration-500" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex flex-col justify-end p-4">
                <span class="text-white text-xs font-black tracking-wider uppercase">Colección Mujer</span>
                <span class="text-[10px] text-slate-300 font-bold uppercase tracking-widest mt-0.5">Explorar Novedades</span>
              </div>
              <a href="/colecciones/mujer" class="absolute inset-0 z-10" aria-label="Explorar Colección de Mujer"></a>
            </div>

          </div>
        </div>
      </div>

      <a href="#contacto" class="text-xs font-bold tracking-widest text-slate-600 hover:text-red-600 uppercase transition-colors">
        CONTACTO
      </a>
    </nav>

    <!-- Right Side Icons -->
    <div class="flex items-center justify-end gap-4 md:gap-6 md:w-1/4 shrink-0">
      <!-- Language Selector -->
      <div class="flex items-center gap-1.5 text-3xs md:text-2xs font-bold text-slate-700 cursor-pointer hover:text-slate-950">
        <span>🇪🇸</span>
        <span>EUR / ES</span>
        <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
      </div>

      <!-- Search Icon -->
      <button type="button" class="text-slate-700 hover:text-red-600 transition-colors" aria-label="Buscar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </button>

      <!-- Profile / Session Info (Dynamic client-side hydration container) -->
      <div id="nav-user-section" class="flex items-center gap-3">
        {user ? (
          <div class="flex items-center gap-3">
            <span class="text-xs font-bold text-slate-800 hidden sm:inline flex-nowrap">
              Hola, {user.name}
            </span>
            <a href="/api/auth/logout" class="text-[9px] font-black tracking-widest text-slate-500 hover:text-rose-600 hover:border-rose-600 uppercase border border-slate-200 px-2.5 py-1.5 rounded-lg transition-all shrink-0" aria-label="Cerrar Sesión">
              SALIR
            </a>
          </div>
        ) : (
          <a href="/login" class="text-slate-700 hover:text-red-600 transition-colors" aria-label="Mi Cuenta">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </a>
        )}
      </div>

      <!-- Cart Icon -->
      <a href="/carrito" class="text-slate-700 hover:text-rose-600 transition-colors relative" aria-label="Carrito">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        <span id="cart-badge" class="absolute -top-1.5 -right-1.5 bg-rose-600 text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-bold hidden">0</span>
      </a>
    </div>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div id="mobile-drawer" class="fixed inset-0 bg-slate-900/60 z-50 transition-all duration-300 opacity-0 pointer-events-none md:hidden backdrop-blur-xs">
  <div class="w-4/5 max-w-sm h-full bg-white flex flex-col justify-between shadow-2xl relative translate-x-[-100%] transition-transform duration-300" id="mobile-drawer-pane">
    
    <!-- Drawer Header -->
    <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50">
      <a href="/" class="flex flex-col">
        <span class="text-xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
          FLEX <span class="text-rose-600">FORM</span>
        </span>
        <span class="text-[9px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5">
          FITNESS
        </span>
      </a>
      <button type="button" id="close-mobile-drawer" class="text-slate-500 hover:text-slate-800 text-xl font-bold p-1">
        ×
      </button>
    </div>

    <!-- Drawer Navigation -->
    <div class="flex-grow overflow-y-auto p-6 flex flex-col gap-6 text-xs">
      <div class="flex flex-col gap-4">
        <a href="/" class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          INICIO
        </a>
        <a href="/colecciones/hombre" class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          HOMBRE
        </a>
        <a href="/colecciones/mujer" class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          MUJER
        </a>
        <a href="#contacto" class="text-xs font-bold tracking-widest text-slate-900 hover:text-rose-600 uppercase">
          CONTACTO
        </a>
      </div>

      <!-- Expandable Collections accordion -->
      <div class="border-t border-slate-100 pt-5 flex flex-col gap-3">
        <button type="button" id="mobile-coll-trigger" class="flex justify-between items-center text-xs font-black tracking-widest text-slate-500 uppercase">
          <span>Colecciones</span>
          <svg id="mobile-coll-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-coll-list" class="flex flex-col gap-2.5 pl-3 mt-1 hidden transition-all">
          {collections.map((col) => (
            <a 
              href={`/colecciones/${col.slug}`} 
              class="text-xs font-bold uppercase text-slate-700 hover:text-rose-600 transition-colors flex items-center gap-2"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>
              {col.title}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Drawer Footer (Dynamic client-side hydration container) -->
    <div id="mobile-drawer-user-section" class="p-6 border-t border-slate-100 bg-slate-50 flex flex-col gap-4 text-3xs font-extrabold tracking-widest uppercase">
      {user ? (
        <div class="flex flex-col gap-3">
          <span class="text-slate-800">Hola, {user.name}</span>
          <a href="/api/auth/logout" class="block text-center border border-slate-200 hover:border-rose-600 text-slate-600 hover:text-rose-600 py-2.5 rounded-lg transition-colors">
            Cerrar Sesión
          </a>
        </div>
      ) : (
        <a href="/login" class="block text-center bg-slate-900 hover:bg-rose-600 text-white py-2.5 rounded-lg transition-colors shadow-2xs">
          Iniciar Sesión
        </a>
      )}
    </div>
  </div>
</div>

<script>
  import { cartStore } from '../stores/cart';
  import { auth } from '../lib/firebaseClient';
  import { onAuthStateChanged } from 'firebase/auth';

  // Intercept logout clicks to sign out of Firebase Client SDK before hitting server-side logout
  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const logoutLink = target.closest('a[href="/api/auth/logout"]');
    if (logoutLink) {
      e.preventDefault();
      try {
        const { signOut } = await import('firebase/auth');
        await signOut(auth);
      } catch (err) {
        console.error('Error signing out client-side:', err);
      }
      window.location.href = '/api/auth/logout';
    }
  });

  // Listen to client-side auth state to update navbar dynamically on static pre-rendered routes
  onAuthStateChanged(auth, (usr) => {
    const desktopContainer = document.getElementById('nav-user-section');
    const mobileContainer = document.getElementById('mobile-drawer-user-section');
    
    if (usr) {
      const name = usr.displayName || usr.email?.split('@')[0] || 'Usuario';
      
      if (desktopContainer) {
        desktopContainer.innerHTML = `
          <div class="flex items-center gap-3">
            <span class="text-xs font-bold text-slate-800 hidden sm:inline flex-nowrap">
              Hola, ${name}
            </span>
            <a href="/api/auth/logout" class="text-[9px] font-black tracking-widest text-slate-500 hover:text-rose-600 hover:border-rose-600 uppercase border border-slate-200 px-2.5 py-1.5 rounded-lg transition-all shrink-0" aria-label="Cerrar Sesión">
              SALIR
            </a>
          </div>
        `;
      }
      
      if (mobileContainer) {
        mobileContainer.innerHTML = `
          <div class="flex flex-col gap-3">
            <span class="text-slate-800">Hola, ${name}</span>
            <a href="/api/auth/logout" class="block text-center border border-slate-200 hover:border-rose-600 text-slate-600 hover:text-rose-600 py-2.5 rounded-lg transition-colors">
              Cerrar Sesión
            </a>
          </div>
        `;
      }
    } else {
      if (desktopContainer) {
        desktopContainer.innerHTML = `
          <a href="/login" class="text-slate-700 hover:text-red-600 transition-colors" aria-label="Mi Cuenta">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </a>
        `;
      }
      
      if (mobileContainer) {
        mobileContainer.innerHTML = `
          <a href="/login" class="block text-center bg-slate-900 hover:bg-rose-600 text-white py-2.5 rounded-lg transition-colors shadow-2xs">
            Iniciar Sesión
          </a>
        `;
      }
    }
  });

  // Update cart count badge in navbar dynamically
  cartStore.subscribe((cart) => {
    const count = Object.values(cart).reduce((sum, item) => sum + item.quantity, 0);
    const badge = document.getElementById('cart-badge');
    if (badge) {
      badge.textContent = String(count);
      if (count === 0) {
        badge.classList.add('hidden');
      } else {
        badge.classList.remove('hidden');
      }
    }
  });

  // Control click dropdown behavior for collections mega menu
  const btn = document.getElementById('collections-dropdown-btn');
  const dropdown = document.getElementById('collections-mega-menu');
  const arrow = document.getElementById('collections-dropdown-arrow');
  
  if (btn && dropdown) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isClosed = dropdown.classList.contains('opacity-0');
      
      if (isClosed) {
        // Open it
        dropdown.classList.remove('opacity-0', 'pointer-events-none');
        dropdown.classList.add('opacity-100', 'pointer-events-auto');
        if (arrow) arrow.classList.add('rotate-180', 'text-rose-600');
      } else {
        // Close it
        dropdown.classList.remove('opacity-100', 'pointer-events-auto');
        dropdown.classList.add('opacity-0', 'pointer-events-none');
        if (arrow) arrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });

    // Close when clicking anywhere outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!dropdown.contains(target) && !btn.contains(target)) {
        dropdown.classList.remove('opacity-100', 'pointer-events-auto');
        dropdown.classList.add('opacity-0', 'pointer-events-none');
        if (arrow) arrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });
  }

  // Control Mobile Drawer Open/Close
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const mobileDrawerPane = document.getElementById('mobile-drawer-pane');
  const closeDrawerBtn = document.getElementById('close-mobile-drawer');
  
  if (mobileBtn && mobileDrawer && mobileDrawerPane) {
    const openDrawer = () => {
      mobileDrawer.classList.remove('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.add('opacity-100', 'pointer-events-auto');
      mobileDrawerPane.classList.remove('translate-x-[-100%]');
      mobileDrawerPane.classList.add('translate-x-0');
    };

    const closeDrawer = () => {
      mobileDrawer.classList.add('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.remove('opacity-100', 'pointer-events-auto');
      mobileDrawerPane.classList.remove('translate-x-0');
      mobileDrawerPane.classList.add('translate-x-[-100%]');
    };

    mobileBtn.addEventListener('click', openDrawer);
    closeDrawerBtn?.addEventListener('click', closeDrawer);
    mobileDrawer.addEventListener('click', (e) => {
      if (e.target === mobileDrawer) closeDrawer();
    });
  }

  // Mobile Collections accordion toggle
  const collTrigger = document.getElementById('mobile-coll-trigger');
  const collList = document.getElementById('mobile-coll-list');
  const collArrow = document.getElementById('mobile-coll-arrow');

  if (collTrigger && collList) {
    collTrigger.addEventListener('click', () => {
      const isHidden = collList.classList.contains('hidden');
      if (isHidden) {
        collList.classList.remove('hidden');
        if (collArrow) collArrow.classList.add('rotate-180', 'text-rose-600');
      } else {
        collList.classList.add('hidden');
        if (collArrow) collArrow.classList.remove('rotate-180', 'text-rose-600');
      }
    });
  }
</script>
