---
import { db } from '../../../lib/firebase';
import type { Product } from '../../../types';
import SEO from '../../../components/SEO.astro';
import Navbar from '../../../components/Navbar.astro';
import { ProductSelector } from '../../../components/ProductSelector';

export const prerender = true;

import { mockProducts } from '../../../lib/mockData';

export async function getStaticPaths() {
  try {
    const productsSnap = await db.collection('products').get();
    
    if (productsSnap.empty) {
      return mockProducts.flatMap((product) => [
        { params: { lang: 'es', slug: product.slug }, props: { product } },
        { params: { lang: 'en', slug: product.slug }, props: { product } }
      ]);
    }

    return productsSnap.docs.flatMap((doc) => {
      const product = { id: doc.id, ...doc.data() } as Product;
      return [
        {
          params: { lang: 'es', slug: product.slug },
          props: { product },
        },
        {
          params: { lang: 'en', slug: product.slug },
          props: { product },
        }
      ];
    });
  } catch (error) {
    console.error('Error fetching static paths from Firestore. Using mock products fallback:', error);
    return mockProducts.flatMap((product) => [
      { params: { lang: 'es', slug: product.slug }, props: { product } },
      { params: { lang: 'en', slug: product.slug }, props: { product } }
    ]);
  }
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/404');
}

const { lang } = Astro.params;
const isEn = lang === 'en';

const getObjectPosition = (url: string | undefined): string => {
  if (!url) return 'center';
  const match = url.match(/#pos=([a-zA-Z0-9%_-]+)/);
  if (match && match[1]) {
    return match[1].replace('_', ' ');
  }
  return 'center';
};

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://flexformfitness.vercel.app';
const canonicalUrl = `${siteUrl}/${lang}/productos/${product.slug}`;

const productTitle = isEn ? (product.title_en || product.title) : product.title;
const productDescription = isEn ? (product.description_en || product.description) : product.description;

// Construct product schema JSON-LD for rich snippets
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  'name': productTitle,
  'image': product.images,
  'description': productDescription,
  'sku': product.variants[0]?.sku || product.id,
  'offers': {
    '@type': 'AggregateOffer',
    'priceCurrency': 'USD',
    'lowPrice': parseFloat((Math.min(product.price, ...product.variants.map((v) => v.price)) / 100).toFixed(2)),
    'highPrice': parseFloat((Math.max(product.price, ...product.variants.map((v) => v.price)) / 100).toFixed(2)),
    'offerCount': product.variants.length || 1,
    'price': parseFloat((product.price / 100).toFixed(2)),
    'availability': product.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    'url': canonicalUrl,
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <SEO
      title={isEn ? (product.seo_en?.title || product.seo?.title || `${productTitle} | FLEX FORM FITNESS`) : (product.seo?.title || `${productTitle} | FLEX FORM FITNESS`)}
      description={isEn ? (product.seo_en?.description || product.seo?.description || productDescription) : (product.seo?.description || productDescription)}
      image={product.images[0]}
      canonicalUrl={canonicalUrl}
      ogType="product"
      jsonLd={productJsonLd}
    />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 py-12 lg:py-16">
      <nav class="mb-8 text-sm font-medium text-slate-500 flex items-center gap-2">
        <a href={`/${lang}`} class="hover:text-brand-600">{isEn ? "Shop" : "Tienda"}</a>
        <span>/</span>
        <span class="text-slate-900 font-semibold">{productTitle}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Media Gallery -->
        <div id="product-gallery" data-images={JSON.stringify(product.images)} class="lg:col-span-7 flex flex-col-reverse sm:flex-row gap-5">
          <!-- Thumbnails list (vertical on desktop, horizontal on mobile) -->
          {product.images.length > 1 && (
            <div class="flex sm:flex-col gap-3 overflow-x-auto sm:overflow-x-hidden sm:overflow-y-auto shrink-0 w-full sm:w-[88px] max-h-[500px] pr-1.5 custom-scrollbar">
              {product.images.map((img, idx) => (
                <button
                  type="button"
                  data-index={idx}
                  class={`thumbnail-btn w-16 h-20 sm:w-[80px] sm:h-[106px] shrink-0 rounded-xl overflow-hidden bg-white border ${idx === 0 ? 'border-brand-600 ring-2 ring-brand-100 shadow-sm' : 'border-slate-200'} hover:border-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-300 transition-all duration-200 shadow-2xs`}
                >
                  <img src={img} alt={`${productTitle} vista ${idx + 1}`} class="w-full h-full object-cover" style={`object-position: ${getObjectPosition(img)}`} />
                </button>
              ))}
            </div>
          )}
          
          <!-- Main featured product image (large box, object-cover to occupy full space with rounded corners) -->
          <div class="flex-grow aspect-[3/4] w-full rounded-2xl overflow-hidden bg-white border border-slate-200 shadow-sm relative group" style="aspect-ratio: 3/4; overflow: hidden;">
            <img
              src={product.images[0]}
              alt={productTitle}
              class="w-full h-full object-cover transition-opacity duration-300 rounded-2xl opacity-0"
              style={`object-position: ${getObjectPosition(product.images[0])}`}
              id="main-product-image"
              onload="this.classList.remove('opacity-0')"
            />

            <!-- Left and Right Arrows (Desktop only, hidden on mobile) -->
            {product.images.length > 1 && (
              <>
                <button
                  type="button"
                  id="prev-image-btn"
                  class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 backdrop-blur-xs text-slate-800 border border-slate-200/50 shadow-md flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-brand-600 active:scale-95 z-10 hidden sm:flex opacity-0 group-hover:opacity-100 focus:opacity-100 focus:outline-none"
                  aria-label={isEn ? "Previous image" : "Imagen anterior"}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                  </svg>
                </button>
                <button
                  type="button"
                  id="next-image-btn"
                  class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 backdrop-blur-xs text-slate-800 border border-slate-200/50 shadow-md flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-brand-600 active:scale-95 z-10 hidden sm:flex opacity-0 group-hover:opacity-100 focus:opacity-100 focus:outline-none"
                  aria-label={isEn ? "Next image" : "Siguiente imagen"}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                  </svg>
                </button>
              </>
            )}
          </div>
        </div>

        <!-- Product Purchase Information -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          <div>
            <h1 class="text-3xl lg:text-4xl font-extrabold text-slate-950 tracking-tight">
              {productTitle}
            </h1>
            <p class="text-sm text-slate-400 mt-1">{isEn ? "Product ID" : "ID del Producto"}: {product.id}</p>
          </div>

          <div class="prose prose-slate max-w-none text-slate-600 leading-relaxed">
            <p>{productDescription}</p>
          </div>

          <!-- Interactive Client Component Selector -->
          <ProductSelector product={product} lang={lang} client:load />

          <!-- Extra details -->
          <div class="border-t border-slate-200/80 pt-6 flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center text-brand-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124l-.09-1.09a1.125 1.125 0 0 0-1.09-1.125H16.12" />
                </svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-slate-800">{isEn ? "Fast Home Shipping" : "Envío Rápido a Domicilio"}</h4>
                <p class="text-xs text-slate-500">{isEn ? "Receive your order in 2 to 5 business days with full tracking." : "Recibe tu pedido de 2 a 5 días hábiles con seguimiento completo."}</p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center text-brand-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0V10.5m-2.852 9h12.704a2.25 2.25 0 0 0 2.228-2.228V10.5A2.25 2.25 0 0 0 15 8.25H9a2.25 2.25 0 0 0-2.25 2.25v7.772a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-slate-800">{isEn ? "100% Safe Checkout" : "Pago Seguro Seguro 100%"}</h4>
                <p class="text-xs text-slate-500">{isEn ? "Transactions processed and encrypted via Stripe." : "Transacciones procesadas y cifradas a través de Stripe."}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="bg-white border-t border-slate-100 py-8 px-6 text-center text-sm text-slate-400 mt-20">
      <p>&copy; {new Date().getFullYear()} FlexForm Fitness. {isEn ? "All rights reserved." : "Todos los derechos reservados."}</p>
    </footer>
    <script>
      // Execute when DOM is ready
      function initGallery() {
        const gallery = document.getElementById('product-gallery');
        const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
        const prevBtn = document.getElementById('prev-image-btn');
        const nextBtn = document.getElementById('next-image-btn');

        if (!gallery || !mainImg) return;

        let images: string[] = [];
        try {
          images = JSON.parse(gallery.dataset.images || '[]');
        } catch (e) {
          console.error('Failed to parse gallery images:', e);
          return;
        }

        if (images.length === 0) return;

        let currentIndex = 0;

        function changeToImage(idx: number) {
          if (idx < 0) idx = images.length - 1;
          if (idx >= images.length) idx = 0;

          currentIndex = idx;
          const newSrc = images[idx];

          mainImg.classList.add('opacity-0');
          mainImg.src = newSrc;

          const match = newSrc.match(/#pos=([a-zA-Z0-9%_-]+)/);
          mainImg.style.objectPosition = match ? match[1].replace('_', ' ') : 'center';
        }

        function updateActiveThumbnail(src: string) {
          const thumbnails = gallery?.querySelectorAll('.thumbnail-btn');
          if (!thumbnails) return;

          let matchedIndex = -1;

          // Helper to normalize URL for comparison
          const getPathname = (urlStr: string) => {
            try {
              return new URL(urlStr, window.location.origin).pathname;
            } catch {
              return urlStr;
            }
          };

          const targetPath = getPathname(src);

          thumbnails.forEach((thumb, idx) => {
            const thumbImg = thumb.querySelector('img');
            if (thumbImg && getPathname(thumbImg.src) === targetPath) {
              matchedIndex = idx;
            }
          });

          if (matchedIndex !== -1) {
            currentIndex = matchedIndex;
            thumbnails.forEach((thumb, idx) => {
              if (idx === matchedIndex) {
                thumb.classList.remove('border-slate-200');
                thumb.classList.add('border-brand-600', 'ring-2', 'ring-brand-100', 'shadow-sm');
              } else {
                thumb.classList.remove('border-brand-600', 'ring-2', 'ring-brand-100', 'shadow-sm');
                thumb.classList.add('border-slate-200');
              }
            });

            // Scroll thumbnail into view if needed
            const activeThumb = thumbnails[matchedIndex] as HTMLElement;
            activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
          }
        }

        // Wire up thumbnail clicks
        const thumbnails = gallery.querySelectorAll('.thumbnail-btn');
        thumbnails.forEach((thumb) => {
          thumb.addEventListener('click', () => {
            const idx = parseInt(thumb.getAttribute('data-index') || '0', 10);
            changeToImage(idx);
          });
        });

        // Wire up desktop arrow buttons
        prevBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          changeToImage(currentIndex - 1);
        });

        nextBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          changeToImage(currentIndex + 1);
        });

        // Synchronize on main image load (triggered by variant clicks or thumbnail/arrow switches)
        mainImg.addEventListener('load', () => {
          mainImg.classList.remove('opacity-0');
          updateActiveThumbnail(mainImg.src);
        });

        // Initial setup for loaded image active state
        updateActiveThumbnail(mainImg.src);

        // Swipe gestures on mobile
        const mainImageContainer = mainImg.parentElement;
        if (mainImageContainer) {
          let touchStartX = 0;
          let touchStartY = 0;
          let touchStartTime = 0;

          mainImageContainer.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
            touchStartTime = Date.now();
          }, { passive: true });

          mainImageContainer.addEventListener('touchend', (e) => {
            const touchEndX = e.changedTouches[0].clientX;
            const touchEndY = e.changedTouches[0].clientY;
            const touchEndTime = Date.now();

            const diffX = touchEndX - touchStartX;
            const diffY = touchEndY - touchStartY;
            const duration = touchEndTime - touchStartTime;

            // Swipe: short duration, significant horizontal movement, mostly horizontal direction
            if (duration < 500 && Math.abs(diffX) > 45 && Math.abs(diffX) > Math.abs(diffY) * 1.4) {
              if (diffX > 0) {
                // Swipe right -> Previous
                changeToImage(currentIndex - 1);
              } else {
                // Swipe left -> Next
                changeToImage(currentIndex + 1);
              }
            }
          }, { passive: true });
        }
      }

      // Initialize on load and re-run on page transitions if applicable
      initGallery();
      document.addEventListener('astro:after-swap', initGallery);
    </script>

    <style is:global>
      /* Thin elegant scrollbar for the vertical thumbnail list */
      .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
        height: 5px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
      }
    </style>
  </body>
</html>
