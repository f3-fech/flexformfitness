---
import SEO from '../../components/SEO.astro';

export const prerender = true; // Pre-rendered static shell, client-side signup

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const isEn = lang === 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={isEn ? "Create Account | FLEX FORM FITNESS" : "Crear Cuenta | FLEX FORM FITNESS"}
      description={isEn ? "Create a FLEX FORM FITNESS account to easily purchase technical sportswear." : "Crea una cuenta en FLEX FORM FITNESS para realizar tus compras de ropa deportiva técnica con facilidad."}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;955&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
      <!-- Logo -->
      <a href={`/${lang}`} class="inline-flex flex-col group mb-6">
        <span class="text-3xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
          FLEX <span class="text-rose-600">FORM</span>
        </span>
        <span class="text-[10px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-1">
          FITNESS
        </span>
      </a>
      <h2 class="text-2xl font-extrabold text-slate-955 tracking-tight">
        {isEn ? "Create your account" : "Crea tu cuenta"}
      </h2>
      <p class="mt-1.5 text-sm text-slate-500">
        {isEn ? "Or " : "O "}
        <a href={`/${lang}/login`} class="font-bold text-rose-600 hover:underline">
          {isEn ? "sign in to your account" : "inicia sesión con tu cuenta"}
        </a>
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-white py-8 px-4 border border-slate-100 shadow-xl rounded-3xl sm:px-10">
        
        <!-- Error notification box -->
        <div id="error-box" class="hidden mb-6 p-4 rounded-xl bg-red-50 border border-red-100 text-red-700 text-xs font-semibold text-center leading-relaxed">
        </div>

        <!-- Success notification box -->
        <div id="success-box" class="hidden mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-800 text-xs font-semibold text-center leading-relaxed">
        </div>

        <!-- Google Auth Button -->
        <div class="w-full">
          <button
            type="button"
            id="google-btn"
            class="w-full inline-flex justify-center items-center py-3.5 px-4 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-sm font-bold text-slate-700 hover:text-slate-905 shadow-sm active:scale-98 transition-all duration-200 gap-3"
          >
            <!-- Google logo vector -->
            <svg class="w-5 h-5" viewBox="0 0 24 24" width="24" height="24">
              <path fill="#EA4335" d="M12 5.04c1.74 0 3.3.6 4.53 1.78l3.39-3.39C17.84 1.54 15.11 1 12 1 7.24 1 3.2 3.73 1.24 7.72l3.96 3.07C6.18 7.73 8.84 5.04 12 5.04z" />
              <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.03 3.68-8.64z" />
              <path fill="#FBBC05" d="M5.2 13.91c-.24-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29L1.24 6.26C.44 7.98 0 9.89 0 11.9s.44 3.92 1.24 5.64l3.96-3.63z" />
              <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.91l-3.77-2.92c-1.11.75-2.53 1.19-4.19 1.19-3.16 0-5.82-2.69-6.8-5.75L1.24 16.2C3.2 20.27 7.24 23 12 23z" />
            </svg>
            <span>{isEn ? "Register with Google" : "Registrarse con Google"}</span>
          </button>
        </div>

        <!-- Separator -->
        <div class="mt-6 relative">
          <div class="absolute inset-0 flex items-center" aria-hidden="true">
            <div class="w-full border-t border-slate-100"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase font-extrabold tracking-widest text-slate-400">
            <span class="bg-white px-3">{isEn ? "or register with email" : "o regístrate con correo"}</span>
          </div>
        </div>

        <!-- Signup Form -->
        <form id="signup-form" class="mt-6 flex flex-col gap-4">
          <div>
            <label for="name" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              {isEn ? "Full Name" : "Nombre Completo"}
            </label>
            <div class="mt-1.5">
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder={isEn ? "John Doe" : "Juan Pérez"}
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              {isEn ? "Email Address" : "Correo Electrónico"}
            </label>
            <div class="mt-1.5">
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="ejemplo@correo.com"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <div>
            <label for="password" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              {isEn ? "Password" : "Contraseña"}
            </label>
            <div class="mt-1.5">
              <input
                id="password"
                name="password"
                type="password"
                required
                placeholder={isEn ? "Min 6 characters" : "Mínimo 6 caracteres"}
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <div>
            <label for="confirm-password" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              {isEn ? "Confirm Password" : "Confirmar Contraseña"}
            </label>
            <div class="mt-1.5">
              <input
                id="confirm-password"
                name="confirm-password"
                type="password"
                required
                placeholder={isEn ? "Repeat your password" : "Repite tu contraseña"}
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <!-- Terms and Conditions Checkbox -->
          <div class="flex items-start gap-2.5 mt-2">
            <input
              type="checkbox"
              id="terms-optin"
              name="termsOptin"
              class="mt-1 w-4 h-4 rounded border-slate-200 text-rose-600 focus:ring-rose-500 cursor-pointer"
              required
            />
            <label for="terms-optin" class="text-xs text-slate-500 leading-normal select-none cursor-pointer">
              {isEn ? (
                <>I accept the <a href="#" class="text-rose-600 hover:underline">terms and conditions of use</a> and the <a href="#" class="text-rose-600 hover:underline">privacy policy</a>.</>
              ) : (
                <>Acepto los <a href="#" class="text-rose-600 hover:underline">términos y condiciones de uso</a> y la <a href="#" class="text-rose-600 hover:underline">política de privacidad</a>.</>
              )}
            </label>
          </div>

          <!-- Newsletter / Marketing Checkbox -->
          <div class="flex items-start gap-2.5 mt-2">
            <input
              type="checkbox"
              id="marketing-optin"
              name="marketingOptin"
              class="mt-1 w-4 h-4 rounded border-slate-200 text-rose-600 focus:ring-rose-500 cursor-pointer"
              checked
            />
            <label for="marketing-optin" class="text-xs text-slate-500 leading-normal select-none cursor-pointer">
              {isEn 
                ? "I want to receive exclusive offers, news, and promotional material by email." 
                : "Quiero recibir ofertas exclusivas, novedades y material promocional por correo electrónico."
              }
            </label>
          </div>

          <div class="mt-3">
            <button
              type="submit"
              id="submit-btn"
              disabled
              class="w-full py-3.5 px-4 rounded-xl bg-slate-955 hover:bg-rose-600 text-white font-bold text-sm tracking-wider uppercase transition-colors duration-200 shadow-md active:scale-98 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-slate-955"
            >
              <span>{isEn ? "Sign Up" : "Registrarse"}</span>
            </button>
          </div>
        </form>

      </div>
    </div>

    <!-- Client-side logic -->
    <script>
      import { auth, googleProvider } from '../../lib/firebaseClient';
      import { createUserWithEmailAndPassword, updateProfile, signInWithPopup, sendEmailVerification } from 'firebase/auth';
      import { actions } from 'astro:actions';

      const signupForm = document.getElementById('signup-form') as HTMLFormElement;
      const googleBtn = document.getElementById('google-btn') as HTMLButtonElement;
      const errorBox = document.getElementById('error-box') as HTMLDivElement;
      const successBox = document.getElementById('success-box') as HTMLDivElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const termsCheckbox = document.getElementById('terms-optin') as HTMLInputElement;

      function getIsEn() {
        return window.location.pathname.startsWith('/en');
      }

      function showError(message: string) {
        errorBox.textContent = message;
        errorBox.classList.remove('hidden');
        successBox.classList.add('hidden'); // Hide success box
      }

      function hideError() {
        errorBox.textContent = '';
        errorBox.classList.add('hidden');
      }

      function showSuccess(message: string) {
        successBox.innerHTML = message;
        successBox.classList.remove('hidden');
        errorBox.classList.add('hidden'); // Hide error box
      }

      // Handle server-side session exchange
      async function createSession(user: any) {
        const idToken = await user.getIdToken();
        
        const response = await fetch('/api/auth/session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (!response.ok) {
          const result = await response.json();
          throw new Error(result.message || (getIsEn() ? 'Error starting session on server' : 'Error al iniciar sesión en el servidor'));
        }

        // Redirect to homepage
        const pathSegments = window.location.pathname.split('/');
        const currentLang = pathSegments[1] || 'es';
        window.location.href = `/${currentLang}`;
      }

      // Email/Password Signup
      signupForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideError();
        
        const nameInput = document.getElementById('name') as HTMLInputElement;
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;
        
        const name = nameInput.value.trim();
        const email = emailInput.value.trim();
        const password = passwordInput.value;
        const confirmPassword = confirmPasswordInput.value;
        const isEn = getIsEn();
        
        // Passwords match validation
        if (password !== confirmPassword) {
          showError(isEn ? 'Passwords do not match.' : 'Las contraseñas no coinciden.');
          return;
        }

        if (password.length < 6) {
          showError(isEn ? 'Password must be at least 6 characters.' : 'La contraseña debe tener al menos 6 caracteres.');
          return;
        }
        
        // Disable inputs and show loading state
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = `<span>${isEn ? 'Creating account...' : 'Creando cuenta...'}</span>`;

        try {
          const userCredential = await createUserWithEmailAndPassword(auth, email, password);
          // Set display name in user profile
          await updateProfile(userCredential.user, { displayName: name });
          
          // Save marketing consent preference
          const consentCheckbox = document.getElementById('marketing-optin') as HTMLInputElement;
          const consent = consentCheckbox ? consentCheckbox.checked : false;
          try {
            await actions.saveMarketingConsent({
              email,
              consent,
              name,
              userId: userCredential.user.uid,
            });
          } catch (consentErr) {
            console.error('Error saving marketing consent upon signup:', consentErr);
          }
          
          // Send verification email
          await sendEmailVerification(userCredential.user);
          
          showSuccess(isEn
            ? `Registration completed successfully! We have sent a verification email to <b>${email}</b>. Please verify it before logging in.`
            : `¡Registro completado con éxito! Hemos enviado un correo de verificación a <b>${email}</b>. Por favor, verifícalo antes de iniciar sesión.`
          );
          
          // Reset form fields
          nameInput.value = '';
          emailInput.value = '';
          passwordInput.value = '';
          confirmPasswordInput.value = '';
          if (termsCheckbox) termsCheckbox.checked = false;
          
          // Immediately sign out from client auth so they aren't logged in with unverified email
          const { signOut } = await import('firebase/auth');
          await signOut(auth);

          submitBtn.innerHTML = originalText;
          updateButtonsState();
        } catch (error: any) {
          console.error('Email sign up error:', error);
          submitBtn.innerHTML = originalText;
          updateButtonsState();
          
          let translatedMessage = isEn ? 'An error occurred during account creation.' : 'Ocurrió un error al crear la cuenta.';
          if (error.code === 'auth/email-already-in-use') {
            translatedMessage = isEn ? 'The email address is already registered.' : 'El correo electrónico ya está registrado.';
          } else if (error.code === 'auth/invalid-email') {
            translatedMessage = isEn ? 'The email format is invalid.' : 'El formato del correo electrónico no es válido.';
          } else if (error.code === 'auth/weak-password') {
            translatedMessage = isEn ? 'The password is too weak.' : 'La contraseña es demasiado débil.';
          }
          showError(translatedMessage);
        }
      });

      // Google Sign-in/Signup
      googleBtn?.addEventListener('click', async () => {
        hideError();
        googleBtn.disabled = true;
        const originalContent = googleBtn.innerHTML;
        const isEn = getIsEn();
        googleBtn.innerHTML = `<span>${isEn ? 'Connecting Google...' : 'Conectando con Google...'}</span>`;

        try {
          const userCredential = await signInWithPopup(auth, googleProvider);
          await createSession(userCredential.user);
        } catch (error: any) {
          console.error('Google sign in error:', error);
          googleBtn.innerHTML = originalContent;
          updateButtonsState();
          
          if (error.code !== 'auth/popup-closed-by-user') {
            showError(isEn 
              ? 'Error connecting with Google: ' + (error.message || error.code)
              : 'Error al conectar con Google: ' + (error.message || error.code)
            );
          }
        }
      });

      // Terms and Conditions checkbox validation
      function updateButtonsState() {
        const isChecked = termsCheckbox ? termsCheckbox.checked : false;
        if (submitBtn) submitBtn.disabled = !isChecked;
        if (googleBtn) googleBtn.disabled = !isChecked;
      }

      termsCheckbox?.addEventListener('change', updateButtonsState);

      // Call once initially to establish disabled state on load
      updateButtonsState();
    </script>
  </body>
</html>
