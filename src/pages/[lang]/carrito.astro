---
import SEO from '../../components/SEO.astro';
import { CartList } from '../../components/CartList';
import { getGeneralSettings } from '../../lib/settings';

export const prerender = false; // Dynamic page

const { lang } = Astro.params;
const isEn = lang === 'en';

const settings = await getGeneralSettings();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={isEn ? "Your Shopping Cart" : "Tu Carrito de Compra"}
      description={isEn ? "Review items in your shopping cart and proceed to secure checkout via Stripe at FlexForm Fitness." : "Revisa los productos en tu carrito de compra y procede al pago seguro con Stripe en FlexForm Fitness."}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-between">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100 py-4 px-6">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <a href={`/${lang}`} class="flex items-center gap-2 group">
          {settings.logoUrl ? (
            <img src={settings.logoUrl} alt="FLEX FORM FITNESS" class="h-6 sm:h-8 md:h-10 w-auto object-contain" />
          ) : (
            <div class="flex flex-col">
              <span class="text-base sm:text-2xl md:text-3xl font-black italic tracking-tighter text-slate-955 uppercase leading-none">
                FLEX <span class="text-rose-600">FORM</span>
              </span>
              <span class="text-[7.5px] sm:text-[9px] md:text-[10px] font-extrabold tracking-[0.18em] sm:tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5 group-hover:text-red-600 transition-colors">
                FITNESS
              </span>
            </div>
          )}
        </a>
        <a href={`/${lang}`} class="text-sm font-semibold text-slate-600 hover:text-brand-600 transition-colors">
          {isEn ? "Shop" : "Tienda"}
        </a>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16 flex-grow w-full">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-950 tracking-tight mb-10 flex items-center gap-3">
        {isEn ? "Your Shopping Cart" : "Tu Carrito de Compra"}
      </h1>
      <CartList client:load lang={lang} shippingPrice={settings.shippingPrice} freeShippingMin={settings.freeShippingMin} />
    </main>

    <!-- Footer (Full Width) -->
    <footer id="contacto" class="w-full bg-slate-900 text-slate-400 py-16 px-4 md:px-8 border-t border-slate-850 mt-20">
      <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <!-- Logo and info -->
        <div class="flex flex-col gap-4 col-span-2 md:col-span-1">
          <a href={`/${lang}`} class="flex flex-col">
            <span class="text-xl md:text-2xl font-black italic tracking-tighter text-white uppercase leading-none">
              FLEX <span class="text-red-550">FORM</span>
            </span>
            <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-500 uppercase leading-none mt-0.5">
              FITNESS
            </span>
          </a>
          <p class="text-xs text-slate-500 leading-relaxed">
            {isEn ? "High-performance sportswear and premium accessories designed for dedicated athletes." : "Ropa deportiva de alto rendimiento y accesorios premium diseñados para atletas dedicados."}
          </p>
        </div>

        <!-- Links Colecciones -->
        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "COLLECTIONS" : "COLECCIONES"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "New Arrivals" : "Novedades"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Men" : "Hombre"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Women" : "Mujer"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Bestsellers" : "Más Vendidos"}</a></li>
          </ul>
        </div>

        <!-- Links Ayuda -->
        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "SUPPORT" : "SOPORTE"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Shipping & Deliveries" : "Envíos y Entregas"}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Returns" : "Devoluciones"}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Size Guide" : "Guía de Tallas"}</a></li>
            <li><a href="/admin/login" class="hover:text-white transition-colors">{isEn ? "Admin Login" : "Acceso de Administrador"}</a></li>
          </ul>
        </div>

        <!-- Contact/Newsletter -->
        <div class="flex flex-col gap-3 col-span-2 md:col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">NEWSLETTER</h4>
          <p class="text-xs text-slate-550 leading-relaxed">{isEn ? "Subscribe to receive a 10% discount on your first order and exclusive deals." : "Suscríbete para recibir un 10% de descuento en tu primer pedido y ofertas exclusivas."}</p>
          <div class="flex gap-2 mt-1">
            <input type="email" id="newsletter-email" placeholder={isEn ? "Your email" : "Tu email"} class="bg-slate-800 text-white placeholder-slate-500 border border-slate-700 px-3 py-2 text-xs focus:outline-none focus:border-white w-full" />
            <button id="newsletter-submit-btn" class="bg-white text-slate-900 px-4 py-2 text-xs font-bold uppercase hover:bg-red-600 hover:text-white transition-colors">OK</button>
          </div>
        </div>
      </div>

      <div class="w-full pt-8 border-t border-slate-850 flex flex-col md:flex-row justify-between items-center gap-4 text-3xs md:text-2xs text-slate-550">
        <p>&copy; {new Date().getFullYear()} FLEX FORM FITNESS. {isEn ? "All rights reserved." : "Todos los derechos reservados."}</p>
        <div class="flex items-center gap-6">
          <a href={`/${lang}/condiciones`} class="hover:text-white transition-colors">Condiciones de Uso</a>
          <a href={`/${lang}/privacidad`} class="hover:text-white transition-colors">Política de Privacidad</a>
          <a href={`/${lang}/cookies`} class="hover:text-white transition-colors">Cookies</a>
        </div>
      </div>
    </footer>

    <script>
      import { actions } from 'astro:actions';

      function getIsEn() {
        return window.location.pathname.startsWith('/en');
      }

      // Newsletter sign up logic
      const newsletterEmailInput = document.getElementById('newsletter-email') as HTMLInputElement;
      const newsletterSubmitBtn = document.getElementById('newsletter-submit-btn') as HTMLButtonElement;

      newsletterSubmitBtn?.addEventListener('click', async () => {
        const email = newsletterEmailInput.value.trim();
        const isEn = getIsEn();
        if (!email) {
          alert(isEn ? 'Please enter an email address.' : 'Por favor, introduce un correo electrónico.');
          return;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
          alert(isEn ? 'Please enter a valid email address.' : 'Por favor, introduce un correo electrónico válido.');
          return;
        }

        newsletterSubmitBtn.disabled = true;
        const originalText = newsletterSubmitBtn.innerText;
        newsletterSubmitBtn.innerText = '...';

        try {
          const { error } = await actions.saveMarketingConsent({
            email,
            consent: true,
          });
          if (error) throw error;
          alert(isEn ? 'Thank you for subscribing to our newsletter!' : '¡Gracias por suscribirte a nuestra newsletter!');
          newsletterEmailInput.value = '';
        } catch (err: any) {
          console.error(err);
          alert(isEn ? 'An error occurred during subscription: ' + (err.message || 'Unknown error') : 'Ocurrió un error al suscribirte: ' + (err.message || 'Error desconocido'));
        } finally {
          newsletterSubmitBtn.disabled = false;
          newsletterSubmitBtn.innerText = originalText;
        }
      });
    </script>
  </body>
</html>
