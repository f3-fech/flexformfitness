---
import { db } from '../../../lib/firebase';
import type { Product, ProductCollection } from '../../../types';
import SEO from '../../../components/SEO.astro';
import Navbar from '../../../components/Navbar.astro';
import { mockProducts } from '../../../lib/mockData';

export const prerender = true;

// Static path builder fetching collections at build time
export async function getStaticPaths() {
  try {
    const snap = await db.collection('collections').get();
    
    if (snap.empty) {
      const fallbackCol = {
        id: 'default',
        title: 'Colección de Muestra',
        slug: 'default-coleccion',
        description: 'Esta es una colección de demostración creada automáticamente.',
        productIds: [],
        seo: {
          title: 'Colección de Muestra | FLEX FORM FITNESS',
          description: 'Esta es una colección de demostración.',
          keywords: ['deporte', 'fitness']
        },
        createdAt: new Date(),
        updatedAt: new Date()
      } as ProductCollection;
      return [
        { params: { lang: 'es', slug: 'default-coleccion' }, props: { collection: fallbackCol } },
        { params: { lang: 'en', slug: 'default-coleccion' }, props: { collection: fallbackCol } }
      ];
    }

    const collections = snap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as ProductCollection);

    return collections.flatMap((collection) => {
      const finalCollection = { ...collection };
      
      if (collection.slug === 'hombre' || collection.slug === 'mujer') {
        const isHombre = collection.slug === 'hombre';
        const targetCategoryName = isHombre ? 'Hombre' : 'Mujer';
        
        // Find sub-collections
        const subCollections = collections.filter((c) => {
          if (c.slug === 'hombre' || c.slug === 'mujer') return false;
          
          if (c.parentCategory) {
            return c.parentCategory === targetCategoryName;
          }
          
          const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
          const isWomen = c.slug.includes('mujer') || c.title.toLowerCase().includes('mujer') || c.title.toLowerCase().includes('women');
          
          if (isHombre) return isMen;
          return isWomen && !isMen;
        });
        
        // Aggregate all product IDs
        const allProductIds = new Set<string>(collection.productIds || []);
        subCollections.forEach((subCol) => {
          (subCol.productIds || []).forEach((id) => allProductIds.add(id));
        });
        
        finalCollection.productIds = Array.from(allProductIds);
      }

      return [
        {
          params: { lang: 'es', slug: collection.slug },
          props: { collection: finalCollection },
        },
        {
          params: { lang: 'en', slug: collection.slug },
          props: { collection: finalCollection },
        }
      ];
    });
  } catch (error) {
    console.error('Error fetching static paths for collections:', error);
    return [];
  }
}

interface Props {
  collection: ProductCollection;
}

const { collection } = Astro.props;

if (!collection) {
  return Astro.redirect('/404');
}

const { lang } = Astro.params;
const isEn = lang === 'en';

// Fetch sub-collections and products
let products: Product[] = [];
let subCollections: ProductCollection[] = [];
try {
  if (collection.slug === 'hombre' || collection.slug === 'mujer') {
    const snap = await db.collection('collections').get();
    const allCols = snap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as ProductCollection);
    
    const isHombre = collection.slug === 'hombre';
    const targetCategoryName = isHombre ? 'Hombre' : 'Mujer';
    
    subCollections = allCols.filter((c) => {
      if (c.slug === 'hombre' || c.slug === 'mujer') return false;
      
      if (c.parentCategory) {
        return c.parentCategory === targetCategoryName;
      }
      
      const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
      const isWomen = c.slug.includes('mujer') || c.title.toLowerCase().includes('mujer') || c.title.toLowerCase().includes('women');
      
      if (isHombre) return isMen;
      return isWomen && !isMen;
    }).sort((a, b) => (a.indexOrder ?? 999) - (b.indexOrder ?? 999));

    const allProductIds = new Set<string>(collection.productIds || []);
    subCollections.forEach((subCol) => {
      (subCol.productIds || []).forEach((id) => allProductIds.add(id));
    });
    collection.productIds = Array.from(allProductIds);
  }

  if (collection.productIds && collection.productIds.length > 0) {
    const productsSnap = await db.collection('products').get();
    if (!productsSnap.empty) {
      const allProducts = productsSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as Product);
      products = allProducts.filter((p) => collection.productIds.includes(p.id));

      // Sort products by their sub-collection order, then by their position in that sub-collection
      if (collection.slug === 'hombre' || collection.slug === 'mujer') {
        products.sort((a, b) => {
          const subColA = subCollections.find((col) => (col.productIds || []).includes(a.id));
          const subColB = subCollections.find((col) => (col.productIds || []).includes(b.id));
          
          const orderA = subColA ? (subColA.indexOrder ?? 999) : 999;
          const orderB = subColB ? (subColB.indexOrder ?? 999) : 999;
          
          if (orderA !== orderB) {
            return orderA - orderB;
          }
          
          const idxA = subColA ? subColA.productIds.indexOf(a.id) : 0;
          const idxB = subColB ? subColB.productIds.indexOf(b.id) : 0;
          return idxA - idxB;
        });
      }
    }
  }
} catch (error) {
  console.error('Error fetching products for collection:', error);
}

const getProductCollectionIds = (prodId: string) => {
  const ids = [];
  subCollections.forEach((subCol) => {
    if ((subCol.productIds || []).includes(prodId)) {
      ids.push(subCol.id);
    }
  });
  if ((collection.productIds || []).includes(prodId)) {
    ids.push(collection.id);
  }
  return ids.join(' ');
};

const getObjectPosition = (url: string | undefined): string => {
  if (!url) return 'center';
  const match = url.match(/#pos=([a-zA-Z0-9%_-]+)/);
  if (match && match[1]) {
    return match[1].replace('_', ' ');
  }
  return 'center';
};

const getColorHex = (colorName: string): string => {
  const name = colorName.toLowerCase().trim();
  const colorMap: Record<string, string> = {
    'negro': '#0f172a',
    'black': '#0f172a',
    'gris': '#94a3b8',
    'grey': '#94a3b8',
    'gray': '#94a3b8',
    'gris-oscuro': '#4b5563',
    'rosa': '#db2777',
    'pink': '#db2777',
    'amarillo': '#fbbf24',
    'yellow': '#fbbf24',
    'azul-metalizado': '#475569',
    'azul-marino': '#1e3a8a',
    'navy': '#1e3a8a',
    'azul-claro': '#a5f3fc',
    'blanco': '#ffffff',
    'white': '#ffffff',
    'rojo': '#dc2626',
    'red': '#dc2626',
    'verde': '#16a34a',
    'green': '#16a34a',
    'naranja': '#ea580c',
    'orange': '#ea580c',
  };

  for (const key in colorMap) {
    if (name.includes(key)) {
      return colorMap[key];
    }
  }
  return '#64748b';
};

interface SwatchColor {
  name: string;
  hex: string;
  image: string | null;
}

const getUniqueColors = (product: Product): SwatchColor[] => {
  if (!product.variants || product.variants.length === 0) return [];
  const colorMap = new Map<string, SwatchColor>();
  
  product.variants.forEach((v) => {
    const parts = v.name.split('/').map((p) => p.trim());
    const name = parts[0] || 'Base';
    
    if (!colorMap.has(name)) {
      const hex = v.colorHex || getColorHex(name);
      colorMap.set(name, {
        name: name,
        hex: hex,
        image: v.image || null
      });
    }
  });
  
  return Array.from(colorMap.values());
};

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://flexformfitness.vercel.app';
const canonicalUrl = `${siteUrl}/${lang}/colecciones/${collection.slug}`;

const collectionTitle = isEn ? (collection.title_en || collection.title) : collection.title;
const collectionDescription = isEn ? (collection.description_en || collection.description) : collection.description;
const collectionDetailedDescription = isEn ? (collection.detailedDescription_en || collection.detailedDescription) : collection.detailedDescription;

const seoTitle = isEn ? (collection.seo_en?.title || collection.seo?.title || `${collectionTitle} | FLEX FORM FITNESS`) : (collection.seo?.title || `${collectionTitle} | FLEX FORM FITNESS`);
const seoDescription = isEn ? (collection.seo_en?.description || collection.seo?.description || collectionDescription) : (collection.seo?.description || collectionDescription);

// Helper to remove gender suffixes from filter titles
const cleanFilterTitle = (title: string): string => {
  return title
    .replace(/\s*(?:de|para|of|for)?\s*[-–—]?\s*(hombre|mujer|men|women)$/i, '')
    .trim();
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <SEO
      title={seoTitle}
      description={seoDescription}
      canonicalUrl={canonicalUrl}
      ogType="website"
    />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-between w-full overflow-x-hidden">
    
    <Navbar />

    <!-- Collection Hero Header Section -->
    <section class="w-full bg-slate-950 text-white py-16 px-4 md:px-8 relative overflow-hidden">
      <!-- Ambient red/orange glow background -->
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-rose-600 rounded-full blur-3xl opacity-10"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-650 rounded-full blur-3xl opacity-10"></div>
      
      <div class="relative max-w-4xl mx-auto text-center flex flex-col items-center gap-4">
        <!-- Breadcrumb -->
        <nav class="text-slate-500 text-3xs font-extrabold tracking-widest uppercase flex items-center gap-2 mb-2">
          <a href={`/${lang}`} class="hover:text-red-500 transition-colors">{isEn ? "Home" : "Inicio"}</a>
          <span>/</span>
          <a href={`/${lang}#catalogo`} class="hover:text-red-500 transition-colors">{isEn ? "Collections" : "Colecciones"}</a>
          <span>/</span>
          <span class="text-white">{collectionTitle}</span>
        </nav>

        <h1 class="text-3xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">
          {collectionTitle}
        </h1>
        
        {collectionDescription && (
          <p class="text-slate-400 text-sm md:text-base max-w-2xl leading-relaxed mt-2" set:html={collectionDescription}>
          </p>
        )}
        
        <span id="products-count-badge" class="text-3xs text-slate-550 font-bold uppercase tracking-widest mt-4">
          {products.length} {products.length === 1 ? (isEn ? 'Product Found' : 'Producto Encontrado') : (isEn ? 'Products Found' : 'Productos Encontrados')}
        </span>
      </div>
    </section>

    {subCollections.length > 0 && (
      <section class="w-full bg-slate-50 border-t border-b border-slate-100 py-6 px-4 md:px-8 shadow-3xs">
        {/* Full-Width Integrated Filter Panel (Gordito de panel, fino de filtros) */}
        <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-center gap-x-6 gap-y-3.5">
          <!-- Filtro Ver todo -->
          <button
            type="button"
            class="category-filter-btn group flex items-center gap-1.5 text-[10.5px] md:text-xs font-semibold uppercase tracking-[0.18em] transition-all duration-200 select-none bg-transparent py-1 border-b border-slate-950 text-slate-950 cursor-pointer"
            data-collection-id="all"
            data-active="true"
          >
            <span>{isEn ? "View All" : "Ver todo"}</span>
            <svg class="w-2.5 h-2.5 transform group-hover:translate-x-0.5 transition-all text-slate-950" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>

          <!-- Filtros de Subcolecciones -->
          {subCollections.map((subCol) => {
            const subTitle = isEn ? (subCol.title_en || subCol.title) : subCol.title;
            return (
              <>
                <!-- Separador adaptativo (oculto en móvil) -->
                <span class="category-separator hidden md:inline-block w-[1px] h-3.5 bg-slate-300/40 mx-2 shrink-0"></span>
                
                <button
                  type="button"
                  class="category-filter-btn group flex items-center gap-1.5 text-[10.5px] md:text-xs font-semibold uppercase tracking-[0.18em] transition-all duration-200 select-none bg-transparent py-1 border-b border-transparent text-slate-400 hover:text-slate-800 cursor-pointer"
                  data-collection-id={subCol.id}
                  data-active="false"
                >
                  <span>{cleanFilterTitle(subTitle)}</span>
                  <svg class="w-2.5 h-2.5 transform group-hover:translate-x-0.5 transition-all text-slate-300 group-hover:text-slate-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </button>
              </>
            );
          })}
        </div>
      </section>
    )}

    <!-- Products Catalog Grid -->
    <main class="w-full px-2 sm:px-4 md:px-8 py-12 flex-grow">
      <div class="w-full flex flex-col gap-6">
        {products.length > 0 ? (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 sm:gap-3 md:gap-6">
            {products.map((product) => (
              <div class="product-card group flex flex-col justify-between w-full" data-collections={getProductCollectionIds(product.id)}>
                {/* Product Image */}
              <div class="relative aspect-[3/4] w-full bg-slate-50 border border-slate-100 overflow-hidden group/slider" style="aspect-ratio: 3/4; overflow: hidden;">
                <!-- Swipeable Images Container -->
                <div class="product-images-slider flex w-full h-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-none" style="scrollbar-width: none; -ms-overflow-style: none;">
                  {product.images.map((imgUrl, imgIdx) => (
                    <a
                      href={`/${lang}/productos/${product.slug}`}
                      class="block w-full h-full shrink-0 snap-start snap-always relative overflow-hidden"
                      data-index={imgIdx}
                      style="aspect-ratio: 3/4;"
                    >
                      <img
                        src={imgUrl}
                        alt={`${isEn ? (product.title_en || product.title) : product.title} - Vista ${imgIdx + 1}`}
                        class="w-full h-full object-cover group-hover:scale-[1.01] transition-opacity duration-300 opacity-0"
                        style={`object-position: ${getObjectPosition(imgUrl)}`}
                        loading={imgIdx === 0 ? "eager" : "lazy"}
                        onload="this.classList.remove('opacity-0')"
                      />
                    </a>
                  ))}
                </div>

                <!-- Hover Navigation Arrows (Desktop only) -->
                <button
                  type="button"
                  class="slider-arrow-left absolute left-2 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-slate-800 flex items-center justify-center shadow-md opacity-0 group-hover/slider:opacity-100 transition-opacity active:scale-90 z-10 cursor-pointer hidden md:flex"
                  title={isEn ? "Previous image" : "Imagen anterior"}
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="slider-arrow-right absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-slate-800 flex items-center justify-center shadow-md opacity-0 group-hover/slider:opacity-100 transition-opacity active:scale-90 z-10 cursor-pointer hidden md:flex"
                  title={isEn ? "Next image" : "Siguiente imagen"}
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </button>

                {product.stock <= 5 && (
                  <span class="absolute top-3 left-3 px-2 py-1 bg-rose-600 text-white text-[9px] font-bold uppercase tracking-wider z-10">
                    {isEn ? "LAST ITEMS" : "ÚLTIMAS UNIDADES"}
                  </span>
                )}
              </div>

              {/* Product Details (Title, Description, and Price) */}
              <div class="mt-3 flex flex-col gap-1 w-full">
                <span class="text-slate-400 text-[9px] font-bold uppercase tracking-widest">FLEX FORM</span>
                <a href={`/${lang}/productos/${product.slug}`} class="text-sm font-bold text-slate-900 hover:text-rose-600 transition-colors line-clamp-1">
                  {isEn ? (product.title_en || product.title) : product.title}
                </a>
                <p class="text-slate-500 text-xs line-clamp-1">
                  {isEn ? (product.description_en || product.description) : product.description}
                </p>
                
                {/* Clickable Swatches */}
                {getUniqueColors(product).length > 0 && (
                  <div class="flex items-center gap-1.5 mt-1">
                    {getUniqueColors(product).map((color) => (
                      <button 
                        type="button"
                        class="color-swatch-btn w-4 h-4 rounded-full border border-slate-200/80 shadow-3xs hover:scale-110 active:scale-90 transition-transform cursor-pointer focus:outline-none" 
                        style={{ backgroundColor: color.hex }}
                        title={color.name}
                        data-variant-image={color.image}
                      />
                    ))}
                  </div>
                )}

                  <div class="flex justify-between items-center mt-2 pt-1.5 border-t border-slate-100">
                    <span class="text-sm font-extrabold text-slate-950">
                      ${(product.price / 100).toFixed(2)}
                    </span>
                    <a href={`/${lang}/productos/${product.slug}`} class="text-[10px] font-bold text-rose-600 group-hover:underline hover:text-rose-700 uppercase tracking-wider">
                      {isEn ? "View details" : "Ver más"}
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 flex flex-col items-center gap-4 bg-slate-50 rounded-3xl border border-slate-100 p-8 max-w-md mx-auto">
            <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18a2.25 2.25 0 012.25 2.25v4.25A2.25 2.25 0 0118 21.75H6a2.25 2.25 0 01-2.25-2.25V15.75a2.25 2.25 0 012.25-2.25z" />
            </svg>
            <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider">{isEn ? "No products" : "Sin productos"}</h3>
            <p class="text-xs text-slate-500">{isEn ? "No products are linked to this collection yet." : "No hay productos vinculados a esta colección todavía."}</p>
            <a href={`/${lang}`} class="mt-2 text-xs font-bold text-rose-600 hover:underline uppercase tracking-wider">{isEn ? "Back home" : "Volver al inicio"}</a>
          </div>
        )}
      </div>
    </main>

    <!-- Additional SEO / Detailed content block -->
    {collectionDetailedDescription && (
      <section class="w-full bg-slate-50 border-t border-b border-slate-100 py-16 px-4 md:px-8">
        <div class="max-w-4xl mx-auto text-slate-700 text-sm md:text-base leading-relaxed font-normal">
          <div set:html={collectionDetailedDescription} class="seo-detailed-content flex flex-col"></div>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer id="contacto" class="w-full bg-slate-900 text-slate-400 py-16 px-4 md:px-8 border-t border-slate-850">
      <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <div class="flex flex-col gap-4 col-span-2 md:col-span-1">
          <a href={`/${lang}`} class="flex flex-col">
            <span class="text-xl md:text-2xl font-black italic tracking-tighter text-white uppercase leading-none">
              FLEX <span class="text-red-550">FORM</span>
            </span>
            <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-500 uppercase leading-none mt-0.5">
              FITNESS
            </span>
          </a>
          <p class="text-xs text-slate-500 leading-relaxed">
            {isEn ? "High-performance sportswear and premium accessories designed for dedicated athletes." : "Ropa deportiva de alto rendimiento y accesorios premium diseñados para atletas dedicados."}
          </p>
        </div>

        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "COLLECTIONS" : "COLECCIONES"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Men" : "Hombre"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Women" : "Mujer"}</a></li>
            <li><a href={`/${lang}`} class="hover:text-white transition-colors">{isEn ? "View all" : "Ver Todo"}</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "SUPPORT" : "SOPORTE"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Shipping & Deliveries" : "Envíos y Entregas"}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Returns" : "Devoluciones"}</a></li>
            <li><a href="/admin/login" class="hover:text-white transition-colors">{isEn ? "Admin Login" : "Acceso de Administrador"}</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-3 col-span-2 md:col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">NEWSLETTER</h4>
          <p class="text-xs text-slate-500 leading-relaxed">Suscríbete para recibir un 10% de descuento en tu primer pedido y ofertas exclusivas.</p>
        </div>
      </div>

      <div class="w-full pt-8 border-t border-slate-850 flex flex-col md:flex-row justify-between items-center gap-4 text-3xs md:text-2xs text-slate-550">
        <p>&copy; {new Date().getFullYear()} FLEX FORM FITNESS. Todos los derechos reservados.</p>
        <div class="flex items-center gap-6">
          <a href={`/${lang}/condiciones`} class="hover:text-white transition-colors">Condiciones de Uso</a>
          <a href={`/${lang}/privacidad`} class="hover:text-white transition-colors">Política de Privacidad</a>
          <a href={`/${lang}/cookies`} class="hover:text-white transition-colors">Cookies</a>
        </div>
      </div>
    </footer>

    <script>
      import { cartStore } from '../../../stores/cart';

      // Update cart count badge in navbar dynamically
      cartStore.subscribe((cart) => {
        const count = Object.values(cart).reduce((sum, item) => sum + item.quantity, 0);
        const badge = document.getElementById('cart-badge');
        if (badge) {
          badge.textContent = String(count);
          if (count === 0) {
            badge.classList.add('hidden');
          } else {
            badge.classList.remove('hidden');
          }
        }
      });

      // Listen to product card images slider arrows & swatches click events
      document.querySelectorAll('.product-card').forEach((card) => {
        const slider = card.querySelector('.product-images-slider') as HTMLDivElement;
        const arrowLeft = card.querySelector('.slider-arrow-left') as HTMLButtonElement;
        const arrowRight = card.querySelector('.slider-arrow-right') as HTMLButtonElement;
        const swatches = card.querySelectorAll('.color-swatch-btn') as NodeListOf<HTMLButtonElement>;

        if (slider && arrowLeft && arrowRight) {
          arrowLeft.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            slider.scrollLeft -= slider.clientWidth;
          });

          arrowRight.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            slider.scrollLeft += slider.clientWidth;
          });
        }

        swatches.forEach((swatch) => {
          swatch.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();

            const imgUrl = swatch.dataset.variantImage;
            if (!imgUrl || !slider) return;

            // Find if this image URL exists in the slides
            const slides = Array.from(slider.querySelectorAll('img'));
            const matchedIndex = slides.findIndex((img) => {
              const src = img.getAttribute('src') || '';
              return src === imgUrl || img.src === imgUrl;
            });

            if (matchedIndex !== -1) {
              slider.scrollLeft = matchedIndex * slider.clientWidth;
            } else {
              // If not found in slider, swap the first slide's image source to show it!
              const firstImg = slides[0];
              if (firstImg) {
                firstImg.src = imgUrl;
                slider.scrollLeft = 0; // Go to first slide
              }
            }
          });
        });
      });

      // Integrated Filter Panel logic
      const categoryFilterBtns = document.querySelectorAll('.category-filter-btn');
      const productCards = document.querySelectorAll('.product-card');
      const countBadge = document.getElementById('products-count-badge');

      // Handle category selection
      categoryFilterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const selectedId = btn.getAttribute('data-collection-id') || 'all';

          // Reset active classes on all filter buttons
          categoryFilterBtns.forEach((b) => {
            b.setAttribute('data-active', 'false');
            b.classList.remove('border-slate-950', 'text-slate-950');
            b.classList.add('border-transparent', 'text-slate-400', 'hover:text-slate-800');
            
            const arrow = b.querySelector('svg');
            if (arrow) {
              arrow.classList.remove('text-slate-950');
              arrow.classList.add('text-slate-300', 'group-hover:text-slate-500');
            }
          });

          // Set active classes to selected button
          btn.setAttribute('data-active', 'true');
          btn.classList.remove('border-transparent', 'text-slate-400', 'hover:text-slate-800');
          btn.classList.add('border-slate-950', 'text-slate-950');

          const arrow = btn.querySelector('svg');
          if (arrow) {
            arrow.classList.remove('text-slate-300', 'group-hover:text-slate-500');
            arrow.classList.add('text-slate-950');
          }

          // Filter actual product list
          let visibleCount = 0;
          productCards.forEach((card) => {
            const assocIds = card.getAttribute('data-collections') || '';
            if (selectedId === 'all' || assocIds.split(' ').includes(selectedId)) {
              (card as HTMLElement).style.display = 'flex';
              visibleCount++;
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });

          // Update count badge
          if (countBadge) {
            const isEnPage = window.location.pathname.includes('/en');
            const labelText = isEnPage
              ? `${visibleCount} ${visibleCount === 1 ? 'Product Found' : 'Products Found'}`
              : `${visibleCount} ${visibleCount === 1 ? 'Producto Encontrado' : 'Productos Encontrados'}`;
            countBadge.textContent = labelText;
          }
        });
      });
    </script>
