---
export const prerender = false;

import { db } from '../../lib/firebase';
import SEO from '../../components/SEO.astro';
import Navbar from '../../components/Navbar.astro';

const { lang } = Astro.params;
const isEn = lang === 'en';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/${lang}/login`);
}

// Fetch user orders
let orders: any[] = [];
try {
  const ordersSnap = await db.collection('orders')
    .where('customerDetails.email', '==', user.email)
    .get();
  
  if (!ordersSnap.empty) {
    orders = ordersSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }));
    // Sort orders by date descending
    orders.sort((a, b) => {
      const dateA = a.createdAt?.toDate ? a.createdAt.toDate() : new Date(a.createdAt);
      const dateB = b.createdAt?.toDate ? b.createdAt.toDate() : new Date(b.createdAt);
      return dateB.getTime() - dateA.getTime();
    });
  }
} catch (e) {
  console.error('Error fetching orders for user:', e);
}

// Fetch customer profile
let customerProfile: any = {};
try {
  const customerDoc = await db.collection('customers').doc(user.uid).get();
  if (customerDoc.exists) {
    customerProfile = customerDoc.data() || {};
  }
} catch (e) {
  console.error('Error fetching customer profile:', e);
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://flexformfitness.vercel.app';
const canonicalUrl = `${siteUrl}/${lang}/mi-cuenta`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <SEO
      title={isEn ? "My Account | FLEX FORM FITNESS" : "Mi Cuenta | FLEX FORM FITNESS"}
      description={isEn ? "Manage your profile details, shipping addresses and view your order history." : "Gestiona tus datos de perfil, direcciones de envío y consulta el historial de tus pedidos."}
      canonicalUrl={canonicalUrl}
      ogType="website"
    />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-between w-full overflow-x-hidden">
    
    <Navbar />

    <!-- Hero Header -->
    <section class="w-full bg-slate-955 text-white py-14 px-4 md:px-8 relative overflow-hidden">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-rose-600 rounded-full blur-3xl opacity-10"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-rose-650 rounded-full blur-3xl opacity-10"></div>
      
      <div class="relative max-w-7xl mx-auto text-left flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">
            {isEn ? "My Account" : "Mi Cuenta"}
          </h1>
          <p class="text-slate-400 text-xs md:text-sm mt-2.5 font-medium tracking-wide">
            {isEn ? "Welcome, " : "Bienvenido, "}<span class="text-white font-bold">{user.name}</span> ({user.email})
          </p>
        </div>
        
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-550/10 border border-green-500/20 text-green-400 text-[10px] font-black tracking-widest uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            {isEn ? "Verified Account" : "Cuenta Verificada"}
          </span>
        </div>
      </div>
    </section>

    <!-- Main Content Grid -->
    <main class="w-full max-w-7xl mx-auto px-4 py-12 flex-grow">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Sidebar Navigation (3 cols) -->
        <aside class="lg:col-span-3 flex flex-row lg:flex-col overflow-x-auto lg:overflow-x-visible gap-2 bg-white border border-slate-100 shadow-md rounded-3xl p-4 sm:p-5 w-full shrink-0 scrollbar-none lg:min-h-[520px]">
          <button 
            type="button" 
            class="tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap bg-rose-50 text-rose-600 border border-rose-100 select-none cursor-pointer" 
            data-tab="tab-shipping"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
            <span>{isEn ? "Shipping Info" : "Datos de Envío"}</span>
          </button>
          
          <button 
            type="button" 
            class="tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap text-slate-500 hover:bg-slate-50 hover:text-slate-900 border border-transparent select-none cursor-pointer" 
            data-tab="tab-orders"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"></path></svg>
            <span>{isEn ? "Orders" : "Mis Pedidos"}</span>
          </button>

          <button 
            type="button" 
            class="tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap text-slate-500 hover:bg-slate-50 hover:text-slate-900 border border-transparent select-none cursor-pointer" 
            data-tab="tab-newsletter"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"></path></svg>
            <span>{isEn ? "Newsletter" : "Suscripción"}</span>
          </button>

          <button 
            type="button" 
            class="tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap text-slate-500 hover:bg-slate-50 hover:text-slate-900 border border-transparent select-none cursor-pointer" 
            data-tab="tab-security"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path></svg>
            <span>{isEn ? "Security" : "Seguridad"}</span>
          </button>
        </aside>

        <!-- Right Side: Active Panel Container (9 cols) -->
        <div class="lg:col-span-9 w-full flex flex-col gap-6">
          
          <!-- Alert boxes -->
          <div id="error-box" class="hidden p-3.5 rounded-xl bg-red-50 border border-red-100 text-red-700 text-xs font-semibold text-center leading-relaxed"></div>
          <div id="success-box" class="hidden p-3.5 rounded-xl bg-green-50 border border-green-100 text-green-700 text-xs font-semibold text-center leading-relaxed"></div>

          <!-- PANEL 1: SHIPPING DETAILS -->
          <div id="tab-shipping" class="tab-panel bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6 lg:min-h-[520px]">
            <div class="border-b border-slate-100 pb-3">
              <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
                {isEn ? "My Shipping Info" : "Mis Datos de Envío"}
              </h2>
              <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">
                {isEn ? "Will auto-fill during checkout" : "Se auto-rellenarán al finalizar tu compra"}
              </p>
            </div>

            <form id="profile-form" class="flex flex-col gap-4">
              <div>
                <label for="form-name" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Full Name" : "Nombre Completo"}</label>
                <input type="text" id="form-name" value={customerProfile.name || user.name || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-bold" required />
              </div>

              <div>
                <label for="form-phone" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Contact Phone" : "Teléfono de Contacto"}</label>
                <input type="tel" id="form-phone" value={customerProfile.phone || ''} placeholder={isEn ? "e.g. +34 600 000 000" : "Ej: +34 600 000 000"} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-mono" />
              </div>

              <div>
                <label for="form-address-1" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Shipping Address" : "Dirección de Envío"}</label>
                <input type="text" id="form-address-1" value={customerProfile.address?.line1 || ''} placeholder={isEn ? "Street, number, floor..." : "Calle, número, piso..."} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
              </div>

              <div>
                <label for="form-address-2" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Building, floor, etc. (Optional)" : "Portal, escalera, etc. (Opcional)"}</label>
                <input type="text" id="form-address-2" value={customerProfile.address?.line2 || ''} placeholder={isEn ? "e.g. Staircase B, 3rd C" : "Ej: Escalera B, 3º C"} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="form-city" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "City" : "Ciudad"}</label>
                  <input type="text" id="form-city" value={customerProfile.address?.city || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
                </div>
                <div>
                  <label for="form-state" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "State / Region" : "Provincia / Región"}</label>
                  <input type="text" id="form-state" value={customerProfile.address?.state || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="form-zip" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Postal Code" : "Código Postal"}</label>
                  <input type="text" id="form-zip" value={customerProfile.address?.postal_code || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-mono" />
                </div>
                <div>
                  <label for="form-country" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">{isEn ? "Country" : "País"}</label>
                  <input type="text" id="form-country" value={customerProfile.address?.country || (isEn ? 'Spain' : 'España')} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
                </div>
              </div>

              <button type="submit" id="save-btn" class="mt-2 w-full py-3 px-4 rounded-xl bg-slate-950 hover:bg-rose-600 text-white font-bold text-xs tracking-widest uppercase transition-colors flex items-center justify-center gap-2 active:scale-98 shadow-xs cursor-pointer">
                <span>{isEn ? "Save Changes" : "Guardar Cambios"}</span>
              </button>
            </form>
          </div>

          <!-- PANEL 2: ORDER HISTORY -->
          <div id="tab-orders" class="tab-panel hidden bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6 lg:min-h-[520px]">
            <div class="border-b border-slate-100 pb-3">
              <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
                {isEn ? "Order History" : "Historial de Pedidos"}
              </h2>
              <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">
                {isEn ? "Check your purchases and delivery tracking status" : "Consulta tus compras y detalles de envío"}
              </p>
            </div>

            {orders.length > 0 ? (
              <div class="flex flex-col gap-5 max-h-[75vh] overflow-y-auto pr-1">
                {orders.map((order) => {
                  const date = order.createdAt?.toDate ? order.createdAt.toDate() : new Date(order.createdAt);
                  const dateString = date.toLocaleDateString(isEn ? 'en-US' : 'es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
                  
                  return (
                    <div class="border border-slate-150 rounded-2xl overflow-hidden shadow-2xs">
                      <!-- Order Header -->
                      <div class="bg-slate-50 px-4 py-3 border-b border-slate-150 flex flex-wrap justify-between items-center gap-3">
                        <div class="flex flex-col gap-0.5">
                          <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">{isEn ? "ORDER ID" : "ID PEDIDO"}</span>
                          <span class="text-xs font-mono font-bold text-slate-950 truncate max-w-[180px]" title={order.id}>{order.id}</span>
                        </div>
                        <div class="flex flex-col gap-0.5 text-right sm:text-left">
                          <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">{isEn ? "DATE" : "FECHA"}</span>
                          <span class="text-xs font-bold text-slate-800">{dateString}</span>
                        </div>
                        <div class="flex flex-col gap-0.5 text-right">
                          <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">TOTAL</span>
                          <span class="text-xs font-black text-rose-600">${(order.amountTotal / 100).toFixed(2)}</span>
                        </div>
                      </div>

                      <!-- Order Content -->
                      <div class="p-4 flex flex-col gap-4">
                        <!-- Products list inside the order -->
                        <div class="flex flex-col gap-3">
                          {order.items && order.items.map((item: any) => (
                            <div class="flex items-center gap-3">
                              <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-100 overflow-hidden shrink-0">
                                <img src={item.image || '/images/placeholder.jpg'} alt={item.name} class="w-full h-full object-cover" />
                              </div>
                              <div class="flex-grow min-w-0">
                                <span class="text-xs font-bold text-slate-900 block truncate leading-tight">{item.name}</span>
                                <span class="text-3xs text-slate-500 font-medium tracking-wide">
                                  {isEn ? `Qty: ${item.quantity} · Price: $${(item.price / 100).toFixed(2)}` : `Cantidad: ${item.quantity} · Precio: $${(item.price / 100).toFixed(2)}`}
                                </span>
                              </div>
                            </div>
                          ))}
                        </div>

                        <!-- Delivery status & tracking -->
                        <div class="pt-3 border-t border-slate-100 flex flex-col gap-3">
                          <div class="flex flex-wrap justify-between items-center gap-2">
                            <div class="flex items-center gap-2">
                              <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-wider">{isEn ? "STATUS:" : "ESTADO:"}</span>
                              <span class={`px-2 py-0.5 rounded-full text-[9px] font-black tracking-widest uppercase ${
                                (order.shippingStatus || order.status) === 'shipped'
                                  ? 'bg-blue-50 text-blue-700'
                                  : (order.shippingStatus || order.status) === 'delivered' || (order.shippingStatus || order.status) === 'completed' || (order.shippingStatus || order.status) === 'paid'
                                  ? 'bg-emerald-50 text-emerald-700'
                                  : (order.shippingStatus || order.status) === 'returned'
                                  ? 'bg-amber-50 text-amber-700'
                                  : (order.shippingStatus || order.status) === 'cancelled'
                                  ? 'bg-red-50 text-red-700'
                                  : 'bg-yellow-50 text-yellow-700'
                              }`}>
                                {(order.shippingStatus || order.status) === 'shipped' 
                                  ? (isEn ? 'Shipped' : 'Enviado') 
                                  : (order.shippingStatus || order.status) === 'delivered' || (order.shippingStatus || order.status) === 'completed' || (order.shippingStatus || order.status) === 'paid'
                                  ? (isEn ? 'Delivered' : 'Entregado')
                                  : (order.shippingStatus || order.status) === 'returned'
                                  ? (isEn ? 'Returned' : 'Devuelto')
                                  : (order.shippingStatus || order.status) === 'cancelled'
                                  ? (isEn ? 'Cancelled' : 'Cancelado')
                                  : (isEn ? 'Pending' : 'Pendiente')}
                              </span>
                              
                              {order.returnRequest && (
                                <span class={`px-2 py-0.5 rounded-full text-[9px] font-black tracking-widest uppercase ${
                                  order.returnRequest.status === 'pending'
                                    ? 'bg-amber-500/10 border border-amber-500/20 text-amber-600'
                                    : order.returnRequest.status === 'approved'
                                    ? 'bg-green-500/10 border border-green-500/20 text-green-600'
                                    : 'bg-red-500/10 border border-red-500/20 text-red-600'
                                }`}>
                                  {isEn ? `Return: ${order.returnRequest.status}` : `Devolución: ${
                                    order.returnRequest.status === 'pending' ? 'Solicitada' :
                                    order.returnRequest.status === 'approved' ? 'Aprobada' : 'Rechazada'
                                  }`}
                                </span>
                              )}
                            </div>

                            {!order.returnRequest && ((order.shippingStatus || order.status) === 'delivered' || (order.shippingStatus || order.status) === 'completed' || (order.shippingStatus || order.status) === 'paid') && (
                              <button
                                type="button"
                                class="request-return-btn px-2.5 py-1 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-lg text-3xs font-extrabold uppercase tracking-wider transition-colors cursor-pointer active:scale-95 border-none"
                                data-order-id={order.id}
                              >
                                {isEn ? "Request Return" : "Solicitar Devolución"}
                              </button>
                            )}
                          </div>

                          {order.trackingNumber && (
                            <div class="text-3xs font-bold text-slate-600">
                              <span class="text-slate-400 uppercase tracking-wider">{isEn ? "TRACKING NO:" : "Nº SEGUIMIENTO:"}</span>
                              <span class="font-mono bg-slate-100 px-1.5 py-0.5 rounded text-slate-800 ml-1">{order.trackingNumber}</span>
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="text-center py-16 flex flex-col items-center gap-4 bg-slate-50 rounded-3xl border border-slate-100 p-8 max-w-sm mx-auto">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <h3 class="text-xs font-extrabold text-slate-800 uppercase tracking-widest">{isEn ? "No purchases" : "Sin compras"}</h3>
                <p class="text-2xs text-slate-500 leading-relaxed">{isEn ? "You have not placed any orders in our shop yet." : "Todavía no has realizado ningún pedido en la tienda."}</p>
                <a href={`/${lang}#catalogo`} class="mt-1.5 text-xs font-bold text-rose-600 hover:underline uppercase tracking-wider">{isEn ? "Explore Catalog" : "Explorar Catálogo"}</a>
              </div>
            )}
          </div>

          <!-- PANEL 3: NEWSLETTER / OFFERS -->
          <div id="tab-newsletter" class="tab-panel hidden bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6 lg:min-h-[520px]">
            <div class="border-b border-slate-100 pb-3">
              <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
                {isEn ? "Offers & Subscriptions" : "Ofertas y Suscripciones"}
              </h2>
              <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">
                {isEn ? "Manage your subscription preference for commercial newsletters" : "Gestiona tu suscripción a correos promocionales y boletines"}
              </p>
            </div>

            <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100">
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-bold text-slate-800">{isEn ? "Marketing emails" : "Correos comerciales"}</span>
                <span class="text-3xs text-slate-400 font-medium" id="subscription-status">
                  {customerProfile.marketingConsent 
                    ? (isEn ? "Subscribed to offers" : "Suscrito a las ofertas") 
                    : (isEn ? "Not subscribed" : "No suscrito")}
                </span>
              </div>
              <button 
                type="button" 
                id="toggle-subscription-btn" 
                class={`px-4 py-2 rounded-xl text-3xs font-extrabold uppercase tracking-wider transition-colors cursor-pointer active:scale-95 border ${
                  customerProfile.marketingConsent 
                    ? 'bg-red-50 hover:bg-red-100 text-red-650 border-red-200' 
                    : 'bg-rose-50 hover:bg-rose-100 text-rose-650 border-rose-200'
                }`}
                data-subscribed={customerProfile.marketingConsent ? "true" : "false"}
              >
                {customerProfile.marketingConsent 
                  ? (isEn ? "Unsubscribe" : "Darse de baja") 
                  : (isEn ? "Subscribe" : "Suscribirse")}
              </button>
            </div>
          </div>

          <!-- PANEL 4: SECURITY -->
          <div id="tab-security" class="tab-panel hidden bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6 lg:min-h-[520px]">
            <div class="border-b border-slate-100 pb-3">
              <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
                {isEn ? "Security & Session" : "Seguridad y Sesión"}
              </h2>
              <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">
                {isEn ? "Manage your account password and active session" : "Gestiona tu contraseña de acceso y sesión activa"}
              </p>
            </div>

            <p class="text-2xs text-slate-500 leading-relaxed">
              {isEn ? "Do you want to reset your password or sign out from your account?" : "¿Quieres cambiar tu contraseña de acceso o cerrar tu sesión activa?"}
            </p>
            
            <div class="flex flex-col sm:flex-row gap-3">
              <button type="button" id="reset-password-btn" class="flex-1 py-3 px-4 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 hover:text-slate-900 text-3xs font-extrabold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 cursor-pointer active:scale-98">
                <span>{isEn ? "Reset Password" : "Restablecer Contraseña"}</span>
              </button>
              
              <a href="/api/auth/logout" class="flex-1 py-3 px-4 rounded-xl border border-red-200 bg-white hover:bg-red-50 text-red-650 hover:text-red-700 text-3xs font-extrabold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 cursor-pointer active:scale-98 text-center no-underline">
                <span>{isEn ? "Sign Out" : "Cerrar Sesión"}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer (Full Width) -->
    <footer id="contacto" class="w-full bg-slate-900 text-slate-400 py-16 px-4 md:px-8 border-t border-slate-850">
      <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <!-- Logo and info -->
        <div class="flex flex-col gap-4 col-span-2 md:col-span-1">
          <a href={`/${lang}`} class="flex flex-col">
            <span class="text-xl md:text-2xl font-black italic tracking-tighter text-white uppercase leading-none">
              FLEX <span class="text-red-550">FORM</span>
            </span>
            <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-500 uppercase leading-none mt-0.5">
              FITNESS
            </span>
          </a>
          <p class="text-xs text-slate-500 leading-relaxed">
            {isEn ? "High-performance sportswear and premium accessories designed for dedicated athletes." : "Ropa deportiva de alto rendimiento y accesorios premium diseñados para atletas dedicados."}
          </p>
        </div>

        <!-- Links Colecciones -->
        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "COLLECTIONS" : "COLECCIONES"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "New Arrivals" : "Novedades"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Men" : "Hombre"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Women" : "Mujer"}</a></li>
            <li><a href={`/${lang}#catalogo`} class="hover:text-white transition-colors">{isEn ? "Bestsellers" : "Más Vendidos"}</a></li>
          </ul>
        </div>

        <!-- Links Ayuda -->
        <div class="flex flex-col gap-3 col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">{isEn ? "SUPPORT" : "SOPORTE"}</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Shipping & Deliveries" : "Envíos y Entregas"}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Returns" : "Devoluciones"}</a></li>
            <li><a href="#" class="hover:text-white transition-colors">{isEn ? "Size Guide" : "Guía de Tallas"}</a></li>
            <li><a href="/admin/login" class="hover:text-white transition-colors">{isEn ? "Admin Login" : "Acceso de Administrador"}</a></li>
          </ul>
        </div>

        <!-- Contact/Newsletter -->
        <div class="flex flex-col gap-3 col-span-2 md:col-span-1">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">NEWSLETTER</h4>
          <p class="text-xs text-slate-550 leading-relaxed">{isEn ? "Subscribe to receive a 10% discount on your first order and exclusive deals." : "Suscríbete para recibir un 10% de descuento en tu primer pedido y ofertas exclusivas."}</p>
          <div class="flex gap-2 mt-1">
            <input type="email" id="newsletter-email" placeholder={isEn ? "Your email" : "Tu email"} class="bg-slate-800 text-white placeholder-slate-500 border border-slate-700 px-3 py-2 text-xs focus:outline-none focus:border-white w-full" />
            <button id="newsletter-submit-btn" class="bg-white text-slate-900 px-4 py-2 text-xs font-bold uppercase hover:bg-red-600 hover:text-white transition-colors">OK</button>
          </div>
        </div>
      </div>

      <div class="w-full pt-8 border-t border-slate-850 flex flex-col md:flex-row justify-between items-center gap-4 text-3xs md:text-2xs text-slate-550">
        <p>&copy; {new Date().getFullYear()} FLEX FORM FITNESS. {isEn ? "All rights reserved." : "Todos los derechos reservados."}</p>
        <div class="flex items-center gap-6">
          <a href={`/${lang}/condiciones`} class="hover:text-white transition-colors">Condiciones de Uso</a>
          <a href={`/${lang}/privacidad`} class="hover:text-white transition-colors">Política de Privacidad</a>
          <a href={`/${lang}/cookies`} class="hover:text-white transition-colors">Cookies</a>
        </div>
      </div>
    </footer>

    <!-- MODAL: REQUEST RETURN -->
    <div id="return-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
      <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-md shadow-2xl overflow-hidden flex flex-col animate-fade-in">
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex justify-between items-center select-none shrink-0">
          <span class="text-xs font-black tracking-widest text-slate-800 uppercase font-mono">{isEn ? "Request Return" : "Solicitar Devolución"}</span>
          <button type="button" id="close-return-modal" class="text-slate-400 hover:text-slate-700 text-lg font-bold">×</button>
        </div>
        
        <form id="return-form" class="p-6 flex flex-col gap-4 text-xs">
          <input type="hidden" id="return-order-id" />

          <div>
            <label for="return-reason" class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
              {isEn ? "Reason for Return" : "Motivo de la Devolución"}
            </label>
            <textarea id="return-reason" required rows="4" placeholder={isEn ? "Describe why you want to return the product(s)..." : "Describe el motivo de la devolución (producto defectuoso, talla incorrecta, etc.)..."} class="w-full px-3.5 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:border-rose-600 font-semibold"></textarea>
          </div>

          <div>
            <label class="block text-3xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
              {isEn ? "Images (optional)" : "Imágenes de Prueba (opcional)"}
            </label>
            <div class="flex flex-col gap-2">
              <input type="file" id="return-file-input" accept="image/*" multiple class="w-full px-3 py-2 border border-slate-200 rounded-xl text-slate-650" />
              <div id="return-images-preview" class="grid grid-cols-4 gap-2 mt-2">
                <!-- Previews of selected return images -->
              </div>
            </div>
          </div>

          <div class="pt-4 border-t border-slate-200 flex justify-end gap-3 shrink-0">
            <button type="button" id="cancel-return-modal" class="px-4 py-2 bg-slate-50 hover:bg-slate-100 text-slate-600 rounded-xl text-xs font-bold uppercase transition-colors active:scale-95">
              {isEn ? "Cancel" : "Cancelar"}
            </button>
            <button type="submit" id="submit-return-btn" class="px-5 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs active:scale-95">
              {isEn ? "Submit Request" : "Enviar Solicitud"}
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Client Script -->
    <script>
      import { actions } from 'astro:actions';
      import { auth } from '../../lib/firebaseClient';
      import { sendPasswordResetEmail } from 'firebase/auth';

      const profileForm = document.getElementById('profile-form') as HTMLFormElement;
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
      const resetPasswordBtn = document.getElementById('reset-password-btn') as HTMLButtonElement;
      
      const errorBox = document.getElementById('error-box') as HTMLDivElement;
      const successBox = document.getElementById('success-box') as HTMLDivElement;

      // Tab switcher logic
      const tabButtons = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetTabId = btn.getAttribute('data-tab');
          if (!targetTabId) return;

          // Clear existing feedback boxes
          errorBox.textContent = '';
          errorBox.classList.add('hidden');
          successBox.textContent = '';
          successBox.classList.add('hidden');

          // Hide all panels, show target panel
          tabPanels.forEach(panel => {
            if (panel.id === targetTabId) {
              panel.classList.remove('hidden');
            } else {
              panel.classList.add('hidden');
            }
          });

          // Reset buttons styles, set active style
          tabButtons.forEach(b => {
            b.className = "tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap text-slate-500 hover:bg-slate-50 hover:text-slate-900 border border-transparent select-none cursor-pointer";
          });

          btn.className = "tab-btn px-4 py-2.5 lg:py-3 rounded-2xl flex items-center gap-3 transition-all duration-200 text-left text-xs font-bold uppercase tracking-wider whitespace-nowrap bg-rose-50 text-rose-600 border border-rose-100 select-none cursor-pointer";
        });
      });

      function getIsEn() {
        return window.location.pathname.startsWith('/en');
      }

      function showError(message: string) {
        errorBox.textContent = message;
        errorBox.classList.remove('hidden');
        successBox.classList.add('hidden');
      }

      function showSuccess(message: string) {
        successBox.textContent = message;
        successBox.classList.remove('hidden');
        errorBox.classList.add('hidden');
      }

      function clearBoxes() {
        errorBox.textContent = '';
        errorBox.classList.add('hidden');
        successBox.textContent = '';
        successBox.classList.add('hidden');
      }

      // Handle Profile update form submission
      profileForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearBoxes();

        saveBtn.disabled = true;
        const originalText = saveBtn.innerHTML;
        const isEn = getIsEn();
        saveBtn.innerHTML = `<span>${isEn ? 'Saving...' : 'Guardando...'}</span>`;

        const name = (document.getElementById('form-name') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('form-phone') as HTMLInputElement).value.trim();
        const line1 = (document.getElementById('form-address-1') as HTMLInputElement).value.trim();
        const line2 = (document.getElementById('form-address-2') as HTMLInputElement).value.trim();
        const city = (document.getElementById('form-city') as HTMLInputElement).value.trim();
        const state = (document.getElementById('form-state') as HTMLInputElement).value.trim();
        const postal_code = (document.getElementById('form-zip') as HTMLInputElement).value.trim();
        const country = (document.getElementById('form-country') as HTMLInputElement).value.trim();

        try {
          const { error } = await actions.saveUserProfile({
            name,
            phone,
            address: {
              line1,
              line2: line2 || null,
              city,
              state,
              postal_code,
              country
            }
          });

          if (error) {
            showError(error.message || (isEn ? 'Error saving profile details.' : 'Error al guardar los datos de tu perfil.'));
          } else {
            showSuccess(isEn ? 'Your shipping details have been saved successfully!' : '¡Tus datos de envío se han guardado correctamente!');
          }
        } catch (err: any) {
          console.error('Error saving profile:', err);
          showError((isEn ? 'Unexpected error saving changes: ' : 'Error inesperado al guardar los cambios: ') + err.message);
        } finally {
          saveBtn.disabled = false;
          saveBtn.innerHTML = originalText;
        }
      });

      // Handle Toggle newsletter subscription
      const toggleSubscriptionBtn = document.getElementById('toggle-subscription-btn') as HTMLButtonElement;
      const subscriptionStatus = document.getElementById('subscription-status') as HTMLSpanElement;

      toggleSubscriptionBtn?.addEventListener('click', async () => {
        clearBoxes();
        const isEn = getIsEn();
        const isCurrentlySubscribed = toggleSubscriptionBtn.dataset.subscribed === "true";
        const newConsent = !isCurrentlySubscribed;

        toggleSubscriptionBtn.disabled = true;
        const originalText = toggleSubscriptionBtn.innerText;
        toggleSubscriptionBtn.innerText = '...';

        try {
          const { error } = await actions.saveMarketingConsent({
            email: auth.currentUser?.email || '',
            consent: newConsent,
            name: auth.currentUser?.displayName || '',
            userId: auth.currentUser?.uid,
          });

          if (error) throw error;

          toggleSubscriptionBtn.dataset.subscribed = newConsent ? "true" : "false";
          toggleSubscriptionBtn.innerText = newConsent 
            ? (isEn ? "Unsubscribe" : "Darse de baja") 
            : (isEn ? "Subscribe" : "Suscribirse");
          
          if (newConsent) {
            toggleSubscriptionBtn.className = "px-3 py-1.5 rounded-lg text-3xs font-extrabold uppercase tracking-wider transition-colors cursor-pointer active:scale-95 border bg-red-50 hover:bg-red-100 text-red-650 border-red-200";
            subscriptionStatus.textContent = isEn ? "Subscribed to offers" : "Suscrito a las ofertas";
            showSuccess(isEn ? "You have subscribed to our offers successfully!" : "¡Te has suscrito a nuestras ofertas correctamente!");
          } else {
            toggleSubscriptionBtn.className = "px-3 py-1.5 rounded-lg text-3xs font-extrabold uppercase tracking-wider transition-colors cursor-pointer active:scale-95 border bg-rose-50 hover:bg-rose-100 text-rose-650 border-rose-200";
            subscriptionStatus.textContent = isEn ? "Not subscribed" : "No suscrito";
            showSuccess(isEn ? "You have unsubscribed from our offers." : "Te has dado de baja de nuestras ofertas.");
          }
        } catch (err: any) {
          console.error('Error toggling subscription:', err);
          toggleSubscriptionBtn.innerText = originalText;
          showError((isEn ? 'Error updating subscription preferences: ' : 'Error al actualizar las preferencias de suscripción: ') + (err.message || 'Error'));
        } finally {
          toggleSubscriptionBtn.disabled = false;
        }
      });

      // Handle Firebase password reset email request
      resetPasswordBtn?.addEventListener('click', async () => {
        clearBoxes();
        const isEn = getIsEn();
        
        const user = auth.currentUser;
        const userEmail = user?.email;
        if (!user || !userEmail) {
          showError(isEn ? 'Could not verify active user email.' : 'No se pudo verificar el correo electrónico del usuario activo.');
          return;
        }

        const isGoogleUser = user.providerData.some(p => p.providerId === 'google.com');
        if (isGoogleUser) {
          showError(isEn ? 'This account is linked with Google. Password is managed by Google.' : 'Esta cuenta está vinculada a Google. La contraseña es gestionada por Google.');
          return;
        }

        resetPasswordBtn.disabled = true;
        const originalContent = resetPasswordBtn.innerHTML;
        resetPasswordBtn.innerHTML = `<span>${isEn ? 'Sending email...' : 'Enviando correo...'}</span>`;

        try {
          await sendPasswordResetEmail(auth, userEmail);
          showSuccess(isEn ? 'Sent! Check your inbox to reset your password.' : '¡Enviado! Revisa tu bandeja de entrada para restablecer tu contraseña.');
        } catch (err: any) {
          console.error('Error sending password reset email:', err);
          showError((isEn ? 'Error sending reset email: ' : 'Error al enviar el correo de restablecimiento: ') + (err.message || err.code));
        } finally {
          resetPasswordBtn.disabled = false;
          resetPasswordBtn.innerHTML = originalContent;
        }
      });

      // Disable password reset on load if user is authenticated with Google
      auth.onAuthStateChanged((user) => {
        if (user) {
          const isGoogleUser = user.providerData.some(p => p.providerId === 'google.com');
          if (isGoogleUser && resetPasswordBtn) {
            resetPasswordBtn.disabled = true;
            resetPasswordBtn.classList.add('opacity-50', 'cursor-not-allowed');
            resetPasswordBtn.innerHTML = `<span>${getIsEn() ? 'Password managed by Google' : 'Contraseña gestionada por Google'}</span>`;
          }
        }
      });

      // Return Modal Toggling & Uploading
      const returnModal = document.getElementById('return-modal') as HTMLDivElement;
      const closeReturnModal = document.getElementById('close-return-modal') as HTMLButtonElement;
      const cancelReturnModal = document.getElementById('cancel-return-modal') as HTMLButtonElement;
      const returnForm = document.getElementById('return-form') as HTMLFormElement;
      const submitReturnBtn = document.getElementById('submit-return-btn') as HTMLButtonElement;
      const returnFileInput = document.getElementById('return-file-input') as HTMLInputElement;
      const returnImagesPreview = document.getElementById('return-images-preview') as HTMLDivElement;
      const returnOrderIdInput = document.getElementById('return-order-id') as HTMLInputElement;
      const returnReasonInput = document.getElementById('return-reason') as HTMLTextAreaElement;

      function toggleModal(el: HTMLDivElement | null, show: boolean) {
        if (!el) return;
        if (show) {
          el.classList.remove('hidden');
          el.classList.add('flex');
        } else {
          el.classList.remove('flex');
          el.classList.add('hidden');
        }
      }

      function blobToBase64(blob: Blob): Promise<string> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onloadend = () => resolve(reader.result as string);
          reader.onerror = reject;
          reader.readAsDataURL(blob);
        });
      }

      function compressAndBase64(file: File): Promise<string> {
        return new Promise((resolve) => {
          const img = new Image();
          img.src = URL.createObjectURL(file);
          img.onload = () => {
            const canvas = document.createElement('canvas');
            const max = 1600; // max size for return proof images
            let w = img.width;
            let h = img.height;
            if (w > max || h > max) {
              if (w > h) {
                h = Math.round((h * max) / w);
                w = max;
              } else {
                w = Math.round((w * max) / h);
                h = max;
              }
            }
            canvas.width = w;
            canvas.height = h;
            const ctx = canvas.getContext('2d');
            ctx?.drawImage(img, 0, 0, w, h);
            canvas.toBlob((blob) => {
              if (blob) {
                blobToBase64(blob).then(resolve);
              } else {
                blobToBase64(file).then(resolve);
              }
            }, 'image/jpeg', 0.9);
          };
        });
      }

      // Bind opening return modal on buttons
      document.querySelectorAll('.request-return-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const orderId = target.dataset.orderId || '';
          returnOrderIdInput.value = orderId;
          returnReasonInput.value = '';
          if (returnFileInput) returnFileInput.value = '';
          if (returnImagesPreview) returnImagesPreview.innerHTML = '';
          toggleModal(returnModal, true);
        });
      });

      closeReturnModal?.addEventListener('click', () => toggleModal(returnModal, false));
      cancelReturnModal?.addEventListener('click', () => toggleModal(returnModal, false));

      // Preview selected local images
      returnFileInput?.addEventListener('change', () => {
        returnImagesPreview.innerHTML = '';
        const files = Array.from(returnFileInput.files || []);
        files.forEach((file) => {
          const url = URL.createObjectURL(file);
          const img = document.createElement('img');
          img.src = url;
          img.className = "w-full aspect-square object-cover rounded-lg border border-slate-200";
          returnImagesPreview.appendChild(img);
        });
      });

      // Submit return request
      returnForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const isEn = getIsEn();
        submitReturnBtn.disabled = true;
        const originalText = submitReturnBtn.innerHTML;
        submitReturnBtn.innerHTML = `<span>${isEn ? 'Submitting...' : 'Enviando...'}</span>`;

        const orderId = returnOrderIdInput.value;
        const reason = returnReasonInput.value.trim();
        const files = Array.from(returnFileInput?.files || []);

        try {
          const uploadedUrls: string[] = [];
          
          for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const base64Data = await compressAndBase64(file);
            const { data, error: uploadError } = await actions.uploadReturnImage({
              base64Data,
              fileName: file.name
            });
            if (uploadError || !data?.success || !data?.url) {
              throw new Error(uploadError?.message || (isEn ? 'Error uploading returns image.' : 'Error al subir la imagen del pedido.'));
            }
            uploadedUrls.push(data.url);
          }

          const { error } = await actions.requestOrderReturn({
            orderId,
            reason,
            images: uploadedUrls
          });

          if (error) throw error;

          alert(isEn ? 'Return request submitted successfully!' : '¡Solicitud de devolución enviada con éxito!');
          window.location.reload();
        } catch (err: any) {
          console.error('Error submitting return request:', err);
          alert((isEn ? 'Error submitting request: ' : 'Error al enviar la solicitud: ') + (err.message || err.code));
          submitReturnBtn.disabled = false;
          submitReturnBtn.innerHTML = originalText;
        }
      });

      // Newsletter sign up logic
      const newsletterEmailInput = document.getElementById('newsletter-email') as HTMLInputElement;
      const newsletterSubmitBtn = document.getElementById('newsletter-submit-btn') as HTMLButtonElement;

      newsletterSubmitBtn?.addEventListener('click', async () => {
        const email = newsletterEmailInput.value.trim();
        const isEn = getIsEn();
        if (!email) {
          alert(isEn ? 'Please enter an email address.' : 'Por favor, introduce un correo electrónico.');
          return;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
          alert(isEn ? 'Please enter a valid email address.' : 'Por favor, introduce un correo electrónico válido.');
          return;
        }

        newsletterSubmitBtn.disabled = true;
        const originalText = newsletterSubmitBtn.innerText;
        newsletterSubmitBtn.innerText = '...';

        try {
          const { error } = await actions.saveMarketingConsent({
            email,
            consent: true,
          });
          if (error) throw error;
          alert(isEn ? 'Thank you for subscribing to our newsletter!' : '¡Gracias por suscribirte a nuestra newsletter!');
          newsletterEmailInput.value = '';
        } catch (err: any) {
          console.error(err);
          alert(isEn ? 'An error occurred during subscription: ' + (err.message || 'Unknown error') : 'Ocurrió un error al suscribirte: ' + (err.message || 'Error desconocido'));
        } finally {
          newsletterSubmitBtn.disabled = false;
          newsletterSubmitBtn.innerText = originalText;
        }
      });
    </script>
  </body>
</html>
