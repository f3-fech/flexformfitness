---
export const prerender = false;

import { db } from "../lib/firebase";
import SEO from "../components/SEO.astro";

const email = Astro.url.searchParams.get("email");
let status = "pending";

if (email) {
  try {
    const formattedEmail = email.toLowerCase().trim();
    
    // 1. Update global marketing consent
    await db.collection("marketing_consents").doc(formattedEmail).set({
      email: formattedEmail,
      consent: false,
      updatedAt: new Date(),
    }, { merge: true });

    // 2. Find customer document with this email and update
    const customersSnap = await db.collection("customers").where("email", "==", formattedEmail).get();
    if (!customersSnap.empty) {
      const batch = db.batch();
      customersSnap.docs.forEach((doc) => {
        batch.update(doc.ref, { 
          marketingConsent: false,
          updatedAt: new Date() 
        });
      });
      await batch.commit();
    }
    
    status = "success";
  } catch (err) {
    console.error("Error unsubscribing user:", err);
    status = "error";
  }
} else {
  status = "missing";
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://flexformfitness.vercel.app";
---

