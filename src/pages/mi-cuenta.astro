---
export const prerender = false;

import { db } from '../lib/firebase';
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

// Fetch user orders
let orders: any[] = [];
try {
  const ordersSnap = await db.collection('orders')
    .where('customerDetails.email', '==', user.email)
    .get();
  
  if (!ordersSnap.empty) {
    orders = ordersSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }));
    // Sort orders by date descending
    orders.sort((a, b) => {
      const dateA = a.createdAt?.toDate ? a.createdAt.toDate() : new Date(a.createdAt);
      const dateB = b.createdAt?.toDate ? b.createdAt.toDate() : new Date(b.createdAt);
      return dateB.getTime() - dateA.getTime();
    });
  }
} catch (e) {
  console.error('Error fetching orders for user:', e);
}

// Fetch customer profile
let customerProfile: any = {};
try {
  const customerDoc = await db.collection('customers').doc(user.uid).get();
  if (customerDoc.exists) {
    customerProfile = customerDoc.data() || {};
  }
} catch (e) {
  console.error('Error fetching customer profile:', e);
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://flexformfitness.vercel.app';
const canonicalUrl = `${siteUrl}/mi-cuenta`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <SEO
      title="Mi Cuenta | FLEX FORM FITNESS"
      description="Gestiona tus datos de perfil, direcciones de envío y consulta el historial de tus pedidos."
      canonicalUrl={canonicalUrl}
      ogType="website"
    />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-between w-full overflow-x-hidden">
    
    <Navbar />

    <!-- Hero Header -->
    <section class="w-full bg-slate-955 text-white py-14 px-4 md:px-8 relative overflow-hidden">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-rose-600 rounded-full blur-3xl opacity-10"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-rose-650 rounded-full blur-3xl opacity-10"></div>
      
      <div class="relative max-w-6xl mx-auto text-left flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">
            Mi Cuenta
          </h1>
          <p class="text-slate-400 text-xs md:text-sm mt-2.5 font-medium tracking-wide">
            Bienvenido, <span class="text-white font-bold">{user.name}</span> ({user.email})
          </p>
        </div>
        
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-550/10 border border-green-500/20 text-green-400 text-[10px] font-black tracking-widest uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            Cuenta Verificada
          </span>
        </div>
      </div>
    </section>

    <!-- Main Content Grid -->
    <main class="w-full max-w-6xl mx-auto px-4 py-12 flex-grow">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Left Column: User Profile Form (8 cols) -->
        <div class="lg:col-span-5 bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6">
          <div class="border-b border-slate-100 pb-3">
            <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
              Mis Datos de Envío
            </h2>
            <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">Se auto-rellenarán al finalizar tu compra</p>
          </div>

          <!-- Alert boxes -->
          <div id="error-box" class="hidden p-3.5 rounded-xl bg-red-50 border border-red-100 text-red-700 text-xs font-semibold text-center leading-relaxed"></div>
          <div id="success-box" class="hidden p-3.5 rounded-xl bg-green-50 border border-green-100 text-green-700 text-xs font-semibold text-center leading-relaxed"></div>

          <form id="profile-form" class="flex flex-col gap-4">
            <div>
              <label for="form-name" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Nombre Completo</label>
              <input type="text" id="form-name" value={customerProfile.name || user.name || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-bold" required />
            </div>

            <div>
              <label for="form-phone" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Teléfono de Contacto</label>
              <input type="tel" id="form-phone" value={customerProfile.phone || ''} placeholder="Ej: +34 600 000 000" class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-mono" />
            </div>

            <div>
              <label for="form-address-1" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Dirección de Envío</label>
              <input type="text" id="form-address-1" value={customerProfile.address?.line1 || ''} placeholder="Calle, número, piso..." class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
            </div>

            <div>
              <label for="form-address-2" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Portal, escalera, etc. (Opcional)</label>
              <input type="text" id="form-address-2" value={customerProfile.address?.line2 || ''} placeholder="Ej: Escalera B, 3º C" class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="form-city" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Ciudad</label>
                <input type="text" id="form-city" value={customerProfile.address?.city || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
              </div>
              <div>
                <label for="form-state" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Provincia / Región</label>
                <input type="text" id="form-state" value={customerProfile.address?.state || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="form-zip" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Código Postal</label>
                <input type="text" id="form-zip" value={customerProfile.address?.postal_code || ''} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs font-mono" />
              </div>
              <div>
                <label for="form-country" class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest">País</label>
                <input type="text" id="form-country" value={customerProfile.address?.country || 'España'} class="mt-1.5 w-full px-3.5 py-2.5 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-xs" />
              </div>
            </div>

            <button type="submit" id="save-btn" class="mt-2 w-full py-3 px-4 rounded-xl bg-slate-950 hover:bg-rose-600 text-white font-bold text-xs tracking-widest uppercase transition-colors flex items-center justify-center gap-2 active:scale-98 shadow-xs cursor-pointer">
              <span>Guardar Cambios</span>
            </button>
          </form>

          <!-- Security segment -->
          <div class="border-t border-slate-100 pt-5 flex flex-col gap-3">
            <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider">Seguridad y Sesión</h3>
            <p class="text-3xs text-slate-500 leading-relaxed">¿Quieres cambiar tu contraseña o cerrar tu sesión activa?</p>
            
            <div class="flex flex-col gap-2">
              <button type="button" id="reset-password-btn" class="w-full py-2.5 px-4 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 hover:text-slate-900 text-3xs font-extrabold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 cursor-pointer active:scale-98">
                <span>Restablecer Contraseña</span>
              </button>
              
              <a href="/api/auth/logout" class="w-full py-2.5 px-4 rounded-xl border border-red-200 bg-white hover:bg-red-50 text-red-650 hover:text-red-700 text-3xs font-extrabold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 cursor-pointer active:scale-98 text-center no-underline">
                <span>Cerrar Sesión</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Right Column: Order History (7 cols) -->
        <div class="lg:col-span-7 bg-white border border-slate-100 shadow-xl rounded-3xl p-6 sm:p-8 flex flex-col gap-6">
          <div class="border-b border-slate-100 pb-3">
            <h2 class="text-base font-extrabold text-slate-900 uppercase tracking-widest">
              Historial de Pedidos
            </h2>
            <p class="text-3xs text-slate-400 uppercase tracking-wider mt-1">Consulta tus compras y detalles de envío</p>
          </div>

          {orders.length > 0 ? (
            <div class="flex flex-col gap-5 max-h-[75vh] overflow-y-auto pr-1">
              {orders.map((order) => {
                const date = order.createdAt?.toDate ? order.createdAt.toDate() : new Date(order.createdAt);
                const dateString = date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
                
                return (
                  <div class="border border-slate-150 rounded-2xl overflow-hidden shadow-2xs">
                    <!-- Order Header -->
                    <div class="bg-slate-50 px-4 py-3 border-b border-slate-150 flex flex-wrap justify-between items-center gap-3">
                      <div class="flex flex-col gap-0.5">
                        <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">ID PEDIDO</span>
                        <span class="text-xs font-mono font-bold text-slate-950 truncate max-w-[180px]" title={order.id}>{order.id}</span>
                      </div>
                      <div class="flex flex-col gap-0.5 text-right sm:text-left">
                        <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">FECHA</span>
                        <span class="text-xs font-bold text-slate-800">{dateString}</span>
                      </div>
                      <div class="flex flex-col gap-0.5 text-right">
                        <span class="text-3xs font-bold text-slate-400 uppercase tracking-wider">TOTAL</span>
                        <span class="text-xs font-black text-rose-600">${(order.amountTotal / 100).toFixed(2)}</span>
                      </div>
                    </div>

                    <!-- Order Content -->
                    <div class="p-4 flex flex-col gap-4">
                      <!-- Products list inside the order -->
                      <div class="flex flex-col gap-3">
                        {order.items && order.items.map((item: any) => (
                          <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-100 overflow-hidden shrink-0">
                              <img src={item.image || '/images/placeholder.jpg'} alt={item.name} class="w-full h-full object-cover" />
                            </div>
                            <div class="flex-grow min-w-0">
                              <span class="text-xs font-bold text-slate-900 block truncate leading-tight">{item.name}</span>
                              <span class="text-3xs text-slate-500 font-medium tracking-wide">Cantidad: {item.quantity} · Precio: ${(item.price / 100).toFixed(2)}</span>
                            </div>
                          </div>
                        ))}
                      </div>

                      <!-- Delivery status & tracking -->
                      <div class="pt-3 border-t border-slate-100 flex flex-wrap justify-between items-center gap-2">
                        <div class="flex items-center gap-2">
                          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-wider">ESTADO:</span>
                          <span class={`px-2 py-0.5 rounded-full text-[9px] font-black tracking-widest uppercase ${
                            order.status === 'completed' || order.status === 'paid'
                              ? 'bg-green-50 text-green-700' 
                              : order.status === 'shipped'
                              ? 'bg-blue-50 text-blue-700'
                              : 'bg-yellow-50 text-yellow-700'
                          }`}>
                            {order.status === 'completed' || order.status === 'paid' ? 'Pagado' : order.status === 'shipped' ? 'Enviado' : order.status}
                          </span>
                        </div>

                        {order.trackingNumber && (
                          <div class="text-3xs font-bold text-slate-600">
                            <span class="text-slate-400 uppercase tracking-wider">Nº SEGUIMIENTO:</span>
                            <span class="font-mono bg-slate-100 px-1.5 py-0.5 rounded text-slate-800 ml-1">{order.trackingNumber}</span>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="text-center py-16 flex flex-col items-center gap-4 bg-slate-50 rounded-3xl border border-slate-100 p-8 max-w-sm mx-auto">
              <svg class="w-12 h-12 text-slate-350" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
              <h3 class="text-xs font-extrabold text-slate-800 uppercase tracking-widest">Sin compras</h3>
              <p class="text-2xs text-slate-500 leading-relaxed">Todavía no has realizado ningún pedido en la tienda.</p>
              <a href="/#catalogo" class="mt-1.5 text-xs font-bold text-rose-600 hover:underline uppercase tracking-wider">Explorar Catálogo</a>
            </div>
          )}
        </div>

      </div>
    </main>

    <!-- Footer -->
    <footer id="contacto" class="w-full bg-slate-900 text-slate-400 py-16 px-4 md:px-8 border-t border-slate-850">
      <div class="w-full grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
        <div class="flex flex-col gap-4">
          <a href="/" class="flex flex-col">
            <span class="text-xl md:text-2xl font-black italic tracking-tighter text-white uppercase leading-none">
              FLEX <span class="text-red-550">FORM</span>
            </span>
            <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-500 uppercase leading-none mt-0.5">
              FITNESS
            </span>
          </a>
          <p class="text-xs text-slate-550 leading-relaxed">
            Ropa deportiva de alto rendimiento y accesorios premium diseñados para atletas dedicados.
          </p>
        </div>

        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">COLECCIONES</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href="/#catalogo" class="hover:text-white transition-colors">Hombre</a></li>
            <li><a href="/#catalogo" class="hover:text-white transition-colors">Mujer</a></li>
            <li><a href="/" class="hover:text-white transition-colors">Ver Todo</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">SOPORTE</h4>
          <ul class="text-xs flex flex-col gap-2">
            <li><a href="#" class="hover:text-white transition-colors">Envíos y Entregas</a></li>
            <li><a href="#" class="hover:text-white transition-colors">Devoluciones</a></li>
            <li><a href="/admin/login" class="hover:text-white transition-colors">Acceso de Administrador</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-bold text-white tracking-widest uppercase">NEWSLETTER</h4>
          <p class="text-xs text-slate-550 leading-relaxed">Suscríbete para recibir un 10% de descuento en tu primer pedido y ofertas exclusivas.</p>
        </div>
      </div>

      <div class="w-full pt-8 border-t border-slate-850 flex flex-col md:flex-row justify-between items-center gap-4 text-3xs md:text-2xs text-slate-550">
        <p>&copy; {new Date().getFullYear()} FLEX FORM FITNESS. Todos los derechos reservados.</p>
      </div>
    </footer>

    <!-- Client Script -->
    <script>
      import { actions } from 'astro:actions';
      import { auth } from '../lib/firebaseClient';
      import { sendPasswordResetEmail } from 'firebase/auth';

      const profileForm = document.getElementById('profile-form') as HTMLFormElement;
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
      const resetPasswordBtn = document.getElementById('reset-password-btn') as HTMLButtonElement;
      
      const errorBox = document.getElementById('error-box') as HTMLDivElement;
      const successBox = document.getElementById('success-box') as HTMLDivElement;

      function showError(message: string) {
        errorBox.textContent = message;
        errorBox.classList.remove('hidden');
        successBox.classList.add('hidden');
      }

      function showSuccess(message: string) {
        successBox.textContent = message;
        successBox.classList.remove('hidden');
        errorBox.classList.add('hidden');
      }

      function clearBoxes() {
        errorBox.textContent = '';
        errorBox.classList.add('hidden');
        successBox.textContent = '';
        successBox.classList.add('hidden');
      }

      // Handle Profile update form submission
      profileForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearBoxes();

        saveBtn.disabled = true;
        const originalText = saveBtn.innerHTML;
        saveBtn.innerHTML = '<span>Guardando...</span>';

        const name = (document.getElementById('form-name') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('form-phone') as HTMLInputElement).value.trim();
        const line1 = (document.getElementById('form-address-1') as HTMLInputElement).value.trim();
        const line2 = (document.getElementById('form-address-2') as HTMLInputElement).value.trim();
        const city = (document.getElementById('form-city') as HTMLInputElement).value.trim();
        const state = (document.getElementById('form-state') as HTMLInputElement).value.trim();
        const postal_code = (document.getElementById('form-zip') as HTMLInputElement).value.trim();
        const country = (document.getElementById('form-country') as HTMLInputElement).value.trim();

        try {
          const { error } = await actions.saveUserProfile({
            name,
            phone,
            address: {
              line1,
              line2: line2 || null,
              city,
              state,
              postal_code,
              country
            }
          });

          if (error) {
            showError(error.message || 'Error al guardar los datos de tu perfil.');
          } else {
            showSuccess('¡Tus datos de envío se han guardado correctamente!');
          }
        } catch (err: any) {
          console.error('Error saving profile:', err);
          showError('Error inesperado al guardar los cambios: ' + err.message);
        } finally {
          saveBtn.disabled = false;
          saveBtn.innerHTML = originalText;
        }
      });

      // Handle Firebase password reset email request
      resetPasswordBtn?.addEventListener('click', async () => {
        clearBoxes();
        
        const userEmail = auth.currentUser?.email;
        if (!userEmail) {
          showError('No se pudo verificar el correo electrónico del usuario activo.');
          return;
        }

        resetPasswordBtn.disabled = true;
        const originalContent = resetPasswordBtn.innerHTML;
        resetPasswordBtn.innerHTML = '<span>Enviando correo...</span>';

        try {
          await sendPasswordResetEmail(auth, userEmail);
          showSuccess('¡Enviado! Revisa tu bandeja de entrada para restablecer tu contraseña.');
        } catch (err: any) {
          console.error('Error sending password reset email:', err);
          showError('Error al enviar el correo de restablecimiento: ' + (err.message || err.code));
        } finally {
          resetPasswordBtn.disabled = false;
          resetPasswordBtn.innerHTML = originalContent;
        }
      });
    </script>
  </body>
</html>
