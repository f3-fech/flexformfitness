---
import SEO from '../components/SEO.astro';
import { CartList } from '../components/CartList';
import { getGeneralSettings } from '../lib/settings';

export const prerender = false; // Dynamic page

const settings = await getGeneralSettings();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title="Tu Carrito de Compra"
      description="Revisa los productos en tu carrito de compra y procede al pago seguro con Stripe en FlexForm Fitness."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-between">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100 py-4 px-6">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-brand-900 tracking-tight flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-extrabold text-sm">F</span>
          FlexForm <span class="text-brand-600">Fitness</span>
        </a>
        <a href="/" class="text-sm font-semibold text-slate-600 hover:text-brand-600 transition-colors">
          Tienda
        </a>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12 lg:py-16 flex-grow w-full">
      <h1 class="text-3xl lg:text-4xl font-extrabold text-slate-950 tracking-tight mb-8">
        Tu Carrito de Compra
      </h1>
      <CartList client:load shippingPrice={settings.shippingPrice} freeShippingMin={settings.freeShippingMin} />
    </main>

    <footer class="bg-white border-t border-slate-100 py-8 px-6 text-center text-sm text-slate-400 mt-20">
      <p>&copy; {new Date().getFullYear()} FlexForm Fitness. Todos los derechos reservados.</p>
    </footer>
  </body>
</html>
