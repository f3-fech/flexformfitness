                        </button>
                      </div>
                    </div>
                    
                    <!-- Visual Work Area -->
                    <div id="container-visual-order" class="w-full h-[700px] relative">
                      <iframe id="iframe-editor-order" class="w-full h-full border-none bg-white"></iframe>
                    </div>
                    
