                        <button type="button" data-cmd="bold" data-target="iframe-editor-abandoned" title="Negrita" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.75h4.5a3.75 3.75 0 1 1 0 7.5h-4.5M6.75 11.25h6a3.75 3.75 0 1 1 0 7.5h-6v-15Z"></path></svg>
                        </button>
                        <button type="button" data-cmd="italic" data-target="iframe-editor-abandoned" title="Cursiva" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
