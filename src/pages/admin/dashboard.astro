---
import { db } from '../../lib/firebase';
import type { Product, Order, ProductCollection } from '../../types';
import { getGeneralSettings } from '../../lib/settings';
import { getEmailSettings } from '../../lib/emailSettings';
import Stripe from 'stripe';
import AdminHeader from '../../components/admin/AdminHeader.astro';
import AdminMetrics from '../../components/admin/AdminMetrics.astro';
import SettingsTab from '../../components/admin/SettingsTab.astro';
import CollectionModal from '../../components/admin/CollectionModal.astro';
import ProductModal from '../../components/admin/ProductModal.astro';
import OrderModals from '../../components/admin/OrderModals.astro';
import { getObjectPosition } from '../../lib/utils';

export const prerender = false; // Server-rendered to check auth and fetch live data

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY || '', {
  apiVersion: '2024-06-20' as any,
});

const [settings, emailSettings, promoResult, productsSnap, ordersSnap, collectionsSnap] = await Promise.all([
  getGeneralSettings(true),
  getEmailSettings(),
  stripe.promotionCodes.list({ active: true, limit: 100, expand: ['data.coupon'] }).catch((err) => {
    console.error('Error fetching Stripe promotion codes for dashboard:', err);
    return { data: [] };
  }),
  db.collection('products').orderBy('createdAt', 'desc').get().catch((err) => {
    console.error('Error fetching products for dashboard:', err);
    return { docs: [] };
  }),
  db.collection('orders').orderBy('createdAt', 'desc').get().catch((err) => {
    console.error('Error fetching orders for dashboard:', err);
    return { docs: [] };
  }),
  db.collection('collections').orderBy('createdAt', 'desc').get().catch((err) => {
    console.error('Error fetching collections for dashboard:', err);
    return { docs: [] };
  }),
]);


const promotionCodes: Stripe.PromotionCode[] = promoResult.data as Stripe.PromotionCode[];
const products: Product[] = (productsSnap.docs as any[]).map((doc: any) => ({ id: doc.id, ...doc.data() }) as Product);
const orders: Order[] = (ordersSnap.docs as any[]).map((doc: any) => ({ id: doc.id, ...doc.data() }) as Order);
const collections: ProductCollection[] = (collectionsSnap.docs as any[]).map((doc: any) => ({ id: doc.id, ...doc.data() }) as ProductCollection);

const menCollection = collections.find((c) => c.slug === 'hombre');
const womenCollection = collections.find((c) => c.slug === 'mujer');

const getProductGender = (productId: string): string => {
  const isMen = menCollection?.productIds?.includes(productId);
  const isWomen = womenCollection?.productIds?.includes(productId);
  if (isMen && isWomen) return 'unisex';
  if (isMen) return 'hombre';
  if (isWomen) return 'mujer';
  return 'sin género';
};

// Fetch custom categories list from settings
let rawCategories: string[] = ['Hombre', 'Mujer'];
try {
  const catDoc = await db.collection('settings').doc('collectionCategories').get();
  if (catDoc.exists) {
    rawCategories = catDoc.data()?.categories || ['Hombre', 'Mujer'];
  }
} catch (error) {
  console.error('Error fetching collection categories:', error);
}

// Normalize and remove case-insensitive duplicates, keeping Hombre and Mujer at the top
const categoriesList: string[] = ['Hombre', 'Mujer'];
const seen = new Set<string>(['hombre', 'mujer']);

for (const cat of rawCategories) {
  const trimmed = cat.trim();
  if (trimmed && !seen.has(trimmed.toLowerCase())) {
    categoriesList.push(trimmed);
    seen.add(trimmed.toLowerCase());
  }
}

if (!seen.has('general')) {
  categoriesList.push('General');
}

// Pre-calculate unique products count for each category
const categoryProductCounts: Record<string, number> = {};
for (const catName of categoriesList) {
  const colInCat = collections.filter((c) => {
    if (c.slug === 'hombre' || c.slug === 'mujer') return false;
    
    if (c.parentCategory) {
      return c.parentCategory === catName;
    }
    
    const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
    const isWomen = c.slug.includes('mujer') || c.title.toLowerCase().includes('mujer') || c.title.toLowerCase().includes('women');
    
    if (isMen) return catName === 'Hombre';
    if (isWomen) return catName === 'Mujer';
    return catName === 'General';
  });

  const mainCol = (catName === 'Hombre') 
    ? collections.find(c => c.slug === 'hombre') 
    : (catName === 'Mujer') 
      ? collections.find(c => c.slug === 'mujer') 
      : null;

  const uniqueProductIds = new Set<string>();
  if (mainCol && mainCol.productIds) {
    mainCol.productIds.forEach((id) => uniqueProductIds.add(id));
  }
  colInCat.forEach((col) => {
    if (col.productIds) {
      col.productIds.forEach((id) => uniqueProductIds.add(id));
    }
  });
  categoryProductCounts[catName] = uniqueProductIds.size;
}

// Metrics and general dashboard logic below

// Calculate metrics for dashboard analytics
const paidOrders = orders.filter((o) => o.paymentStatus === 'paid');
const totalRevenue = paidOrders.reduce((sum, o) => sum + o.totalAmount, 0);
const pendingShipmentsCount = paidOrders.filter((o) => o.shippingStatus === 'pending').length;
const averageOrderValue = paidOrders.length > 0 ? Math.round(totalRevenue / paidOrders.length) : 0;
const returnedOrdersCount = orders.filter((o) => o.shippingStatus === 'returned').length;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Administración | FLEX FORM FITNESS</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Cropper.js CDN for photoshop-style visual image cropping -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <style is:global>
      /* Modern & thin custom scrollbar styles */
      * {
        scrollbar-width: thin;
        scrollbar-color: #cbd5e1 transparent;
      }

      /* Webkit browsers (Chrome, Safari, Edge, Opera) */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 9999px;
        border: 2px solid transparent;
        background-clip: padding-box;
      }

      ::-webkit-scrollbar-thumb:hover {
        background-color: #94a3b8;
        border: 2px solid transparent;
        background-clip: padding-box;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen font-sans antialiased flex flex-col w-full">
    
    <AdminHeader logoUrl={settings.logoUrl} adminEmail={Astro.locals.user?.email} />

    <!-- Main Container -->
    <main class="w-full flex-grow p-6 md:p-8 max-w-full px-6 md:px-10">
      
      <!-- Top Overview Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
          <h1 class="text-3xl font-black italic tracking-tight text-slate-950 uppercase">
            Panel de Control
          </h1>
          <p class="text-slate-500 text-sm mt-1">Administra el catálogo de productos y gestiona los pedidos de la tienda.</p>
        </div>
      </div>

      <AdminMetrics
        totalRevenue={totalRevenue}
        paidOrdersCount={paidOrders.length}
        pendingShipmentsCount={pendingShipmentsCount}
        averageOrderValue={averageOrderValue}
        returnedOrdersCount={returnedOrdersCount}
      />

      <!-- Tab Buttons Navigation -->
      <div class="flex border-b border-slate-200 mb-8 gap-6 text-sm font-bold tracking-wider">
        <button
          type="button"
          id="tab-products-btn"
          class="pb-4 px-2 border-b-2 border-rose-600 text-rose-600 uppercase focus:outline-none transition-all"
        >
          Productos
        </button>
        <button
          type="button"
          id="tab-collections-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Colecciones
        </button>
        <button
          type="button"
          id="tab-orders-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Pedidos
        </button>
        <button
          type="button"
          id="tab-emails-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Emails
        </button>
        <button
          type="button"
          id="tab-users-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Usuarios
        </button>
        <button
          type="button"
          id="tab-settings-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Configuración
        </button>
      </div>

      <!-- TAB: PRODUCTS SECTION -->
      <section id="section-products" class="w-full">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Catálogo de Artículos</h2>
          <div class="flex items-center gap-3 w-full sm:w-auto">
            <input
              type="text"
              id="search-products"
              placeholder="Buscar por título o slug..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-64 shadow-2xs"
            />
            <button
              type="button"
              id="open-new-product-modal"
              class="px-4 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md shrink-0"
            >
              <span>+ Nuevo Producto</span>
            </button>
          </div>
        </div>

        <!-- Products Table -->
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-2xs font-extrabold tracking-widest uppercase border-b border-slate-200">
                  <th class="p-4 pl-6">Imagen</th>
                  <th class="p-4">Producto</th>
                  <th class="p-4">Precio Base</th>
                  <th class="p-4">Stock General</th>
                  <th class="p-4">Variantes</th>
                  <th class="p-4 text-right pr-6">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
                {products.length === 0 ? (
                  <tr>
                    <td colspan="6" class="p-8 text-center text-slate-400 font-medium">
                      No hay productos registrados en la tienda.
                    </td>
                  </tr>
                ) : (
                  products.map((product) => (
                    <tr class="product-row hover:bg-slate-50 transition-colors" data-title={product.title.toLowerCase()} data-slug={product.slug.toLowerCase()}>
                      <td class="p-4 pl-6">
                        <div class="w-20 h-28 rounded-xl overflow-hidden bg-slate-100 border border-slate-200 shadow-3xs transition-all duration-300 hover:scale-[1.06] hover:shadow-xs">
                          <img src={product.images[0]} alt={product.title} class="w-full h-full object-cover" style={`object-position: ${getObjectPosition(product.images[0])}`} />
                        </div>
                      </td>
                      <td class="p-4">
                        <span class="block font-bold text-slate-900 text-sm leading-tight">{product.title}</span>
                        <span class="block text-slate-400 text-3xs font-mono uppercase tracking-wider mt-0.5">Slug: {product.slug}</span>
                      </td>
                      <td class="p-4 font-semibold text-slate-800">
                        ${(product.price / 100).toFixed(2)}
                      </td>
                      <td class="p-4 font-mono font-bold">
                        <span class={product.stock <= 5 ? "text-amber-600" : "text-slate-600"}>
                          {product.stock} uds
                        </span>
                      </td>
                      <td class="p-4">
                        {product.variants && product.variants.length > 0 ? (
                          <div class="flex flex-wrap gap-1">
                            {product.variants.map((v) => (
                              <span class="px-2 py-0.5 rounded bg-slate-50 text-[10px] text-slate-600 border border-slate-200 font-semibold shadow-3xs">
                                {v.name} (${(v.price / 100).toFixed(0)}) · {v.stock}
                              </span>
                            ))}
                          </div>
                        ) : (
                          <span class="text-slate-400 italic">Sin variantes</span>
                        )}
                      </td>
                      <td class="p-4 text-right pr-6 flex justify-end gap-2 items-center">
                        <button
                          type="button"
                          class="edit-product-btn px-3 py-1.5 bg-white hover:bg-slate-50 border border-slate-200 rounded-lg text-3xs font-bold text-slate-700 uppercase tracking-wider transition-colors shrink-0 shadow-3xs"
                          data-product={JSON.stringify(product)}
                        >
                          Editar
                        </button>
                        <button
                          type="button"
                          class="delete-product-btn px-3 py-1.5 bg-rose-50 hover:bg-rose-650 text-rose-650 hover:text-white border border-rose-100 hover:border-rose-600 rounded-lg text-3xs font-bold uppercase tracking-wider transition-colors shrink-0"
                          data-product-id={product.id}
                          data-product-title={product.title}
                        >
                          Eliminar
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- TAB: COLLECTIONS SECTION -->
      <section id="section-collections" class="w-full hidden flex flex-col gap-6">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-200 pb-4">
          <div>
            <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Escritorio de Colecciones</h2>
            <p class="text-3xs text-slate-400 uppercase tracking-widest mt-1">Arrastra productos de la barra lateral y suéltalos en las carpetas para clasificarlos.</p>
          </div>
          <div class="flex items-center gap-3 w-full sm:w-auto">
            <input
              type="text"
              id="search-collections"
              placeholder="Buscar carpeta..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-48 shadow-2xs"
            />
            <button
              type="button"
              id="create-new-category-btn"
              class="px-4 py-2.5 bg-slate-800 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md shrink-0"
            >
              <span>+ Nueva Categoría</span>
            </button>
            <button
              type="button"
              id="open-new-collection-modal"
              class="px-4 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md shrink-0"
            >
              <span>+ Nueva Carpeta</span>
            </button>
          </div>
        </div>

        <!-- Workspace Workspace (Split layout) -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          
          <!-- LEFT AREA: Windows Desktop Grid (Col span 8) -->
          <div class="lg:col-span-8 bg-white border border-slate-200 rounded-3xl p-6 min-h-[55vh] relative flex flex-col gap-6 shadow-sm">
            <!-- Panel Toolbar -->
            <div class="flex justify-between items-center pb-4 border-b border-slate-100 shrink-0 select-none">
              <span class="text-3xs font-black text-slate-400 uppercase tracking-widest font-mono">Organizador de Categorías</span>
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  id="reorder-collections-btn"
                  class="px-3.5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-3xs font-black uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-2xs select-none cursor-pointer"
                >
                  <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25ZM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25Z" /></svg>
                  <span>Reorganizar</span>
                </button>
                <button
                  type="button"
                  id="save-reorder-btn"
                  class="px-3.5 py-2 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-3xs font-black uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md hidden select-none animate-pulse cursor-pointer"
                >
                  <span>Guardar Organización</span>
                </button>
              </div>
            </div>
            <!-- Divided collection lists -->
            <div class="flex flex-col gap-8 w-full animate-fade-in" id="collections-desktop">
              {categoriesList.map((catName) => {
                // Filter collections that belong to this category
                const colInCat = collections.filter((c) => {
                  // Exclude the pinned main collections from the draggable grid
                  if (c.slug === 'hombre' || c.slug === 'mujer') return false;
                  
                  // If parentCategory is explicitly set, use it directly
                  if (c.parentCategory) {
                    return c.parentCategory === catName;
                  }
                  
                  // Default assignment based on keywords if no category is assigned yet
                  const isMen = c.slug.includes('hombre') || c.title.toLowerCase().includes('hombre') || c.title.toLowerCase().includes('men');
                  const isWomen = c.slug.includes('mujer') || c.title.toLowerCase().includes('mujer') || c.title.toLowerCase().includes('women');
                  
                  if (isMen) {
                    return catName === 'Hombre';
                  }
                  if (isWomen) {
                    return catName === 'Mujer';
                  }
                  
                  // Otherwise defaults to General
                  return catName === 'General';
                }).sort((a, b) => (a.indexOrder ?? 999) - (b.indexOrder ?? 999));

                // Find the main folder pinned for this category
                const mainCol = (catName === 'Hombre') 
                  ? collections.find(c => c.slug === 'hombre') 
                  : (catName === 'Mujer') 
                    ? collections.find(c => c.slug === 'mujer') 
                    : null;

                const totalProducts = categoryProductCounts[catName] || 0;

                return (
                  <div 
                    class="dropzone-category flex flex-col gap-4 bg-slate-50/40 hover:bg-slate-50/70 border border-slate-100/80 p-4 rounded-2xl transition-colors duration-200" 
                    data-category={catName}
                  >
                    <div class="flex justify-between items-center border-b border-slate-200/60 pb-2 select-none">
                      <div class="flex items-center gap-2.5">
                        <span class={`w-1.5 h-1.5 rounded-full ${catName === 'Hombre' ? 'bg-blue-500' : catName === 'Mujer' ? 'bg-rose-500' : 'bg-slate-400'}`}></span>
                        <h3 class="text-[10px] font-black text-slate-800 uppercase tracking-widest">
                          {catName}
                          <span class="text-[9px] text-slate-400 font-mono font-normal normal-case ml-1.5 select-none">
                            ({totalProducts} {totalProducts === 1 ? 'producto' : 'productos'})
                          </span>
                        </h3>
                        
                        {mainCol && (
                          <div 
                            class="collection-folder inline-flex items-center gap-1.5 px-2.5 py-1 bg-amber-500/10 hover:bg-amber-500/20 text-amber-600 rounded-lg border border-amber-500/20 cursor-pointer transition-all duration-200 text-[10px] font-bold uppercase ml-4"
                            data-id={mainCol.id}
                            data-collection-slug={mainCol.slug}
                            data-collection-json={JSON.stringify(mainCol)}
                            data-title={mainCol.title.toLowerCase()}
                            data-slug={mainCol.slug.toLowerCase()}
                          >
                            <svg class="w-3 h-3 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"></path></svg>
                            <span>Fijada: {mainCol.title}</span>
                          </div>
                        )}
                      </div>
                      
                      {catName !== 'Hombre' && catName !== 'Mujer' && catName !== 'General' && (
                        <button 
                          type="button" 
                          class="text-[9px] font-black text-rose-655 hover:text-rose-700 uppercase tracking-wider transition-colors delete-category-btn" 
                          data-category={catName}
                          title={`Eliminar categoría "${catName}"`}
                        >
                          Eliminar
                        </button>
                      )}
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 min-h-[90px] p-2 bg-white/45 rounded-xl border border-dashed border-slate-200/50">
                      {colInCat.map((col) => (
                        <div 
                          class="collection-folder draggable-folder group flex flex-col items-center justify-center p-3 rounded-xl border border-transparent hover:border-slate-200 hover:bg-white cursor-grab active:cursor-grabbing transition-all duration-200 select-none text-center bg-white shadow-3xs"
                          data-id={col.id}
                          data-collection-slug={col.slug}
                          data-collection-json={JSON.stringify(col)}
                          data-title={col.title.toLowerCase()}
                          data-slug={col.slug.toLowerCase()}
                          draggable="true"
                        >
                          <div class="w-14 h-10 relative flex items-end justify-center shrink-0">
                            <div class="absolute inset-0 bg-amber-500 rounded-lg shadow-sm border border-amber-600"></div>
                            <div class="absolute -top-0.5 left-1.5 w-5 h-1 bg-amber-600 rounded-t"></div>
                            <div class="absolute inset-0 bg-amber-400 rounded-lg origin-bottom transform group-hover:-rotate-x-12 transition-transform duration-300 shadow-sm border border-amber-300"></div>
                            <div class="w-8 h-6 bg-white border border-slate-200 absolute -top-1.5 left-2.5 rotate-3 rounded group-hover:-translate-y-1 transition-transform flex items-center justify-center text-[9px] font-black text-slate-800 font-mono shadow-sm">
                              {col.productIds ? col.productIds.length : 0}
                            </div>
                          </div>
                          
                          <span class="mt-2.5 text-[11px] font-bold text-slate-800 group-hover:text-amber-600 transition-colors line-clamp-1 max-w-[110px] leading-tight flex items-center gap-1 justify-center">
                            {col.title}
                            {col.showOnIndex && (
                              <span class="px-1 py-0.2 rounded bg-rose-600 text-white text-[7px] font-black shadow-3xs" title={`Portada #${col.indexOrder || 0}`}>
                                #{col.indexOrder || 0}
                              </span>
                            )}
                          </span>
                          
                          <span class="text-[8px] text-slate-400 font-mono truncate max-w-[90px]">
                            /{col.slug}
                          </span>
                        </div>
                      ))}
                      {colInCat.length === 0 && (
                        <div class="col-span-full py-6 flex items-center justify-center text-slate-400 text-[10px] font-bold uppercase tracking-wider select-none empty-placeholder">
                          Arrastra carpetas aquí
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            
            {collections.length === 0 && (
              <div class="flex-grow flex flex-col items-center justify-center text-center p-8 gap-3 text-slate-400">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                </svg>
                <span class="text-xs font-bold uppercase tracking-wider">Escritorio vacío</span>
                <span class="text-3xs text-slate-400 max-w-xs">Crea una nueva carpeta de colección para empezar a organizar tus productos.</span>
              </div>
            )}
          </div>

          <!-- RIGHT AREA: Catalog Sidebar Drawer (Col span 4) -->
          <div class="lg:col-span-4 bg-white border border-slate-200 rounded-3xl p-5 shadow-sm flex flex-col gap-4 max-h-[60vh]">
            <div class="flex justify-between items-center border-b border-slate-200 pb-2">
              <span class="text-2xs font-extrabold text-slate-400 uppercase tracking-widest">Catálogo de Artículos</span>
              <span class="text-[10px] text-slate-500 font-mono">{products.length} productos</span>
            </div>
            
            <!-- Draggable Products List -->
            <div class="flex flex-col gap-2.5 overflow-y-auto pr-1 flex-grow" id="catalog-draggable-container">
              {products.map((p) => (
                <div
                  class="product-draggable bg-slate-50 hover:bg-slate-100/80 border border-slate-200 p-2.5 rounded-2xl flex items-center gap-3 cursor-grab active:cursor-grabbing select-none transition-all duration-200 group"
                  draggable="true"
                  data-id={p.id}
                  data-title={p.title}
                  data-image={p.images[0]}
                  data-sku={p.variants[0]?.sku || 'BASE'}
                  data-gender={getProductGender(p.id)}
                >
                  <!-- Drag Indicator -->
                  <div class="text-slate-400 group-hover:text-slate-650 cursor-grab shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
                    </svg>
                  </div>
                  
                  <!-- Tiny Image (Enlarged) -->
                  <div class="w-14 h-18 rounded overflow-hidden bg-white shrink-0 border border-slate-200">
                    <img src={p.images[0]} class="w-full h-full object-cover" style={`object-position: ${getObjectPosition(p.images[0])}`} />
                  </div>
                  
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center flex-wrap gap-1.5 mb-0.5">
                      <span class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest font-mono">
                        SKU: {p.variants[0]?.sku || 'BASE'}
                      </span>
                      <span class={`px-1.5 py-0.5 text-[8px] font-black uppercase rounded tracking-wider border ${
                        getProductGender(p.id) === 'hombre' ? 'bg-blue-50 text-blue-600 border-blue-100' :
                        getProductGender(p.id) === 'mujer' ? 'bg-pink-50 text-pink-600 border-pink-100' :
                        getProductGender(p.id) === 'unisex' ? 'bg-purple-50 text-purple-600 border-purple-100' :
                        'bg-slate-100 text-slate-500 border-slate-200'
                      }`}>
                        {getProductGender(p.id) === 'hombre' ? 'Hombre' : getProductGender(p.id) === 'mujer' ? 'Mujer' : getProductGender(p.id) === 'unisex' ? 'Unisex' : 'Sin género'}
                      </span>
                    </div>
                    <span class="block text-xs font-bold text-slate-800 truncate leading-tight">
                      {p.title}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
        </div>
      </section>

      <!-- TAB: ORDERS SECTION -->
      <section id="section-orders" class="w-full hidden">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Listado de Pedidos</h2>
          <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto">
            <input
              type="text"
              id="search-orders"
              placeholder="Buscar por cliente, email o ID..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-60 shadow-2xs"
            />
            <select
              id="filter-payment-status"
              class="px-3 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-700 text-xs focus:outline-none focus:border-rose-600 font-semibold shadow-3xs"
            >
              <option value="">Todos los Pagos</option>
              <option value="paid">Pagado</option>
              <option value="pending">Pendiente</option>
              <option value="failed">Fallido</option>
            </select>
            <select
              id="filter-shipping-status"
              class="px-3 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-700 text-xs focus:outline-none focus:border-rose-600 font-semibold shadow-3xs"
            >
              <option value="">Todos los Estados</option>
              <option value="pending">Envío: Pendiente</option>
              <option value="shipped">Envío: Enviado</option>
              <option value="delivered">Envío: Entregado</option>
              <option value="cancelled">Envío: Cancelado</option>
              <option value="returned">Envío: Devuelto</option>
              <option value="return_pending">Devolución: Solicitada</option>
            </select>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-2xs font-extrabold tracking-widest uppercase border-b border-slate-200">
                  <th class="p-4 pl-6">ID Pedido / Fecha</th>
                  <th class="p-4">Cliente</th>
                  <th class="p-4">Importe Total</th>
                  <th class="p-4">Artículos</th>
                  <th class="p-4">Estados</th>
                  <th class="p-4 text-right pr-6">Acciones</th>
                </tr>
              </thead>
              <tbody id="orders-table-body" class="divide-y divide-slate-100 text-xs text-slate-700">
                <tr>
                  <td colspan="6" class="p-8 text-center text-slate-400 font-medium">
                    Cargando lista de pedidos...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Pagination Buttons -->
          <div class="flex justify-between items-center p-4 border-t border-slate-100">
            <span class="text-3xs text-slate-400 font-bold uppercase tracking-wider" id="orders-page-info">Página 1</span>
            <div class="flex gap-2">
              <button
                type="button"
                id="orders-prev-btn"
                disabled
                class="px-3.5 py-2 bg-slate-100 hover:bg-slate-200 disabled:opacity-50 disabled:hover:bg-slate-100 text-slate-700 text-3xs font-extrabold uppercase tracking-wider rounded-xl transition-all cursor-pointer disabled:cursor-not-allowed"
              >
                Anterior
              </button>
              <button
                type="button"
                id="orders-next-btn"
                disabled
                class="px-3.5 py-2 bg-slate-100 hover:bg-slate-200 disabled:opacity-50 disabled:hover:bg-slate-100 text-slate-700 text-3xs font-extrabold uppercase tracking-wider rounded-xl transition-all cursor-pointer disabled:cursor-not-allowed"
              >
                Siguiente
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- TAB: EMAILS SECTION -->
      <section id="section-emails" class="w-full hidden">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Gestión de Emails y Marketing</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Left Side: Sub-navigation sidebar menu -->
          <div class="md:col-span-1 flex flex-col gap-1 bg-white border border-slate-200 p-4 rounded-2xl shadow-sm h-fit">
            <button
              type="button"
              id="subtab-templates-btn"
