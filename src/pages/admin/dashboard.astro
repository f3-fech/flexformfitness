              // Delete the old cropped image file from Storage to prevent orphaned file accumulation
              const oldCroppedUrl = currentCropUrl.split('#')[0];
              if (oldCroppedUrl.includes('/crop_')) {
                try {
                  // Call deleteImage silently so that even if it fails, it doesn't block saving the new crop
                  await actions.deleteImage({ url: oldCroppedUrl });
                } catch (delErr) {
                  console.warn("Failed to delete old cropped image file:", delErr);
                }
              }

              // Get original uncropped image URL
              const originalUrl = getOriginalUrl(currentCropUrl);
              // Combine: cropped image url + original image url reference in hash
