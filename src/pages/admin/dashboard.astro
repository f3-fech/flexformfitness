                        <button type="button" data-cmd="underline" data-target="iframe-editor-order" title="Subrayado" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75v1.5a5.25 5.25 0 1 1-10.5 0v-1.5m1.5 10.5h7.5"></path></svg>
                        </button>
                        <span class="w-px h-4 bg-slate-300 mx-1"></span>
                        <button type="button" data-cmd="justifyLeft" data-target="iframe-editor-order" title="Alinear izquierda" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"></path></svg>
                        </button>
                        <button type="button" data-cmd="justifyCenter" data-target="iframe-editor-order" title="Centrar" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path></svg>
                        </button>
                        <button type="button" data-cmd="insertUnorderedList" data-target="iframe-editor-order" title="Lista" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-3.75 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"></path></svg>
                        </button>
                        <span class="w-px h-4 bg-slate-300 mx-1"></span>
                        <button type="button" id="btn-insert-var-order" title="Insertar Variable" class="p-1.5 rounded hover:bg-rose-100 text-rose-600 font-bold text-3xs uppercase tracking-wider flex items-center gap-1 transition-all focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"></path></svg>
