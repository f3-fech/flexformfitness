                      </label>
                      <!-- Italy -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="IT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('IT')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇮🇹 Italia (IT)</span>
                      </label>
                      <!-- Portugal -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="PT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('PT')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇵🇹 Portugal (PT)</span>
                      </label>
                      <!-- United Kingdom -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="GB" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('GB')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇬🇧 Reino Unido (GB)</span>
                      </label>
                      <!-- United States -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="US" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('US')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇺🇸 EE.UU. (US)</span>
