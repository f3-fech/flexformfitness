                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75v1.5a5.25 5.25 0 1 1-10.5 0v-1.5m1.5 10.5h7.5"></path></svg>
                        </button>
                        <span class="w-px h-4 bg-slate-300 mx-1"></span>
                        <button type="button" data-cmd="justifyLeft" data-target="iframe-editor-abandoned" title="Alinear izquierda" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"></path></svg>
                        </button>
                        <button type="button" data-cmd="justifyCenter" data-target="iframe-editor-abandoned" title="Centrar" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
