                <div class="flex flex-col gap-1">
                  <label for="email-order-subject" class="block font-semibold text-slate-500 uppercase tracking-wider text-3xs">Asunto del Correo</label>
                  <input
                    type="text"
                    id="email-order-subject"
                    name="orderSubject"
                    value={emailSettings.orderSubject}
                    class="px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-xs focus:outline-none focus:border-rose-600 focus:bg-white w-full"
                    required
                  />
                <div class="flex flex-col gap-2">
                  <label class="block font-semibold text-slate-500 uppercase tracking-wider text-3xs">Cuerpo del Correo</label>
                  
                  <!-- Editor Container -->
                  <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-2xs bg-white">
                    <!-- Tab Selector & Toolbar -->
                    <div class="flex flex-wrap items-center justify-between bg-slate-50 border-b border-slate-200 p-2 gap-2">
                      <!-- Editor Modes -->
                      <div class="flex bg-slate-200/80 p-0.5 rounded-lg text-4xs font-bold uppercase tracking-wider">
                        <button type="button" id="btn-mode-visual-order" class="px-3 py-1.5 rounded-md bg-white text-rose-600 shadow-3xs transition-all focus:outline-none">Vista Visual</button>
                        <button type="button" id="btn-mode-html-order" class="px-3 py-1.5 rounded-md text-slate-500 hover:text-slate-900 transition-all focus:outline-none">Código HTML</button>
                      </div>
                      
                      <!-- Visual Toolbar (Only shown in Visual Mode) -->
                      <div id="toolbar-visual-order" class="flex items-center gap-1">
                        <button type="button" data-cmd="bold" data-target="iframe-editor-order" title="Negrita" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.75h4.5a3.75 3.75 0 1 1 0 7.5h-4.5M6.75 11.25h6a3.75 3.75 0 1 1 0 7.5h-6v-15Z"></path></svg>
                        </button>
                        <button type="button" data-cmd="italic" data-target="iframe-editor-order" title="Cursiva" class="p-1.5 rounded hover:bg-slate-200 text-slate-600 hover:text-slate-950 transition-colors focus:outline-none">
