---
import { db } from '../../lib/firebase';
import type { Product, Order, ProductCollection } from '../../types';
import { getGeneralSettings } from '../../lib/settings';
import Stripe from 'stripe';

export const prerender = false; // Server-rendered to check auth and fetch live data

const settings = await getGeneralSettings();
const popularCountries = ['ES', 'FR', 'DE', 'IT', 'PT', 'GB', 'US', 'CA', 'MX'];
const otherCountries = settings.markets.filter((c) => !popularCountries.includes(c));

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY || '', {
  apiVersion: '2024-06-20' as any,
});

let promotionCodes: Stripe.PromotionCode[] = [];
try {
  const promoCodesSnap = await stripe.promotionCodes.list({ active: true, limit: 100, expand: ['data.coupon'] });
  promotionCodes = promoCodesSnap.data;
} catch (err) {
  console.error('Error fetching Stripe promotion codes for dashboard:', err);
}

// Fetch all products
let products: Product[] = [];
try {
  const productsSnap = await db.collection('products').orderBy('createdAt', 'desc').get();
  products = productsSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as Product);
} catch (err) {
  console.error('Error fetching products for dashboard:', err);
}

// Fetch all orders
let orders: Order[] = [];
try {
  const ordersSnap = await db.collection('orders').orderBy('createdAt', 'desc').get();
  orders = ordersSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as Order);
} catch (err) {
  console.error('Error fetching orders for dashboard:', err);
}

// Fetch all collections
let collections: ProductCollection[] = [];
try {
  const collectionsSnap = await db.collection('collections').orderBy('createdAt', 'desc').get();
  collections = collectionsSnap.docs.map((doc) => ({ id: doc.id, ...doc.data() }) as ProductCollection);
} catch (err) {
  console.error('Error fetching collections for dashboard:', err);
}

// Calculate metrics for dashboard analytics
const paidOrders = orders.filter((o) => o.paymentStatus === 'paid');
const totalRevenue = paidOrders.reduce((sum, o) => sum + o.totalAmount, 0);
const pendingShipmentsCount = paidOrders.filter((o) => o.shippingStatus === 'pending').length;
const averageOrderValue = paidOrders.length > 0 ? Math.round(totalRevenue / paidOrders.length) : 0;

function getObjectPosition(url: string | undefined): string {
  if (!url) return 'center';
  const match = url.match(/#pos=([a-zA-Z0-9%_-]+)/);
  if (match && match[1]) {
    return match[1].replace('_', ' ');
  }
  return 'center';
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Administración | FLEX FORM FITNESS</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Cropper.js CDN for photoshop-style visual image cropping -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen font-sans antialiased flex flex-col w-full">
    
    <!-- Navbar -->
    <header class="w-full bg-white border-b border-slate-200 py-4 px-6 md:px-8">
      <div class="w-full flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          {settings.logoUrl ? (
            <img src={settings.logoUrl} alt="FLEX FORM FITNESS" class="h-8 w-auto object-contain" />
          ) : (
            <div class="flex flex-col">
              <span class="text-xl md:text-2xl font-black italic tracking-tighter text-slate-950 uppercase leading-none">
                FLEX <span class="text-rose-600">FORM</span>
              </span>
              <span class="text-[8px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-0.5">
                FITNESS · ADMIN
              </span>
            </div>
          )}
        </a>

        <!-- Logged in user info & logout -->
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-500 font-semibold hidden sm:inline mr-1">
            Admin: {Astro.locals.user?.email || 'Activo'}
          </span>
          <button
            type="button"
            id="publish-changes-btn"
            class="px-4 py-2 border rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-3xs flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full transition-all" id="publish-badge"></span>
            <span id="publish-btn-text">Publicado</span>
          </button>
          <a
            href="/admin/logout"
            class="px-4 py-2 bg-white border border-slate-200 hover:bg-rose-600 hover:border-rose-600 hover:text-white text-slate-700 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 shadow-3xs"
          >
            Cerrar Sesión
          </a>
        </div>
      </div>
    </header>

    <!-- Main Container -->
    <main class="w-full flex-grow p-6 md:p-8 max-w-full px-6 md:px-10">
      
      <!-- Top Overview Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
          <h1 class="text-3xl font-black italic tracking-tight text-slate-950 uppercase">
            Panel de Control
          </h1>
          <p class="text-slate-500 text-sm mt-1">Administra el catálogo de productos y gestiona los pedidos de la tienda.</p>
        </div>
      </div>

      <!-- Metrics Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white border border-slate-200 p-5 rounded-2xl flex flex-col gap-1 shadow-sm">
          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Ingresos Totales</span>
          <span class="text-xl sm:text-2xl font-bold tracking-tight text-emerald-600 font-mono">
            ${(totalRevenue / 100).toFixed(2)}
          </span>
        </div>
        <div class="bg-white border border-slate-200 p-5 rounded-2xl flex flex-col gap-1 shadow-sm">
          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Pedidos Pagados</span>
          <span class="text-xl sm:text-2xl font-bold tracking-tight text-slate-950">
            {paidOrders.length}
          </span>
        </div>
        <div class="bg-white border border-slate-200 p-5 rounded-2xl flex flex-col gap-1 shadow-sm">
          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Pedidos por Enviar</span>
          <span class="text-xl sm:text-2xl font-bold tracking-tight text-amber-600">
            {pendingShipmentsCount}
          </span>
        </div>
        <div class="bg-white border border-slate-200 p-5 rounded-2xl flex flex-col gap-1 shadow-sm">
          <span class="text-3xs font-extrabold text-slate-400 uppercase tracking-widest">Ticket Medio</span>
          <span class="text-xl sm:text-2xl font-bold tracking-tight text-slate-950 font-mono">
            ${(averageOrderValue / 100).toFixed(2)}
          </span>
        </div>
      </div>

      <!-- Tab Buttons Navigation -->
      <div class="flex border-b border-slate-200 mb-8 gap-6 text-sm font-bold tracking-wider">
        <button
          type="button"
          id="tab-products-btn"
          class="pb-4 px-2 border-b-2 border-rose-600 text-rose-600 uppercase focus:outline-none transition-all"
        >
          Productos
        </button>
        <button
          type="button"
          id="tab-collections-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Colecciones
        </button>
        <button
          type="button"
          id="tab-orders-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Pedidos
        </button>
        <button
          type="button"
          id="tab-settings-btn"
          class="pb-4 px-2 border-b-2 border-transparent text-slate-400 hover:text-slate-900 uppercase focus:outline-none transition-all"
        >
          Configuración
        </button>
      </div>

      <!-- TAB: PRODUCTS SECTION -->
      <section id="section-products" class="w-full">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Catálogo de Artículos</h2>
          <div class="flex items-center gap-3 w-full sm:w-auto">
            <input
              type="text"
              id="search-products"
              placeholder="Buscar por título o slug..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-64 shadow-2xs"
            />
            <button
              type="button"
              id="open-new-product-modal"
              class="px-4 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md shrink-0"
            >
              <span>+ Nuevo Producto</span>
            </button>
          </div>
        </div>

        <!-- Products Table -->
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-2xs font-extrabold tracking-widest uppercase border-b border-slate-200">
                  <th class="p-4 pl-6">Imagen</th>
                  <th class="p-4">Producto</th>
                  <th class="p-4">Precio Base</th>
                  <th class="p-4">Stock General</th>
                  <th class="p-4">Variantes</th>
                  <th class="p-4 text-right pr-6">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
                {products.length === 0 ? (
                  <tr>
                    <td colspan="6" class="p-8 text-center text-slate-400 font-medium">
                      No hay productos registrados en la tienda.
                    </td>
                  </tr>
                ) : (
                  products.map((product) => (
                    <tr class="product-row hover:bg-slate-50 transition-colors" data-title={product.title.toLowerCase()} data-slug={product.slug.toLowerCase()}>
                      <td class="p-4 pl-6">
                        <div class="w-20 h-28 rounded-xl overflow-hidden bg-slate-100 border border-slate-200 shadow-3xs transition-all duration-300 hover:scale-[1.06] hover:shadow-xs">
                          <img src={product.images[0]} alt={product.title} class="w-full h-full object-cover" style={`object-position: ${getObjectPosition(product.images[0])}`} />
                        </div>
                      </td>
                      <td class="p-4">
                        <span class="block font-bold text-slate-900 text-sm leading-tight">{product.title}</span>
                        <span class="block text-slate-400 text-3xs font-mono uppercase tracking-wider mt-0.5">Slug: {product.slug}</span>
                      </td>
                      <td class="p-4 font-semibold text-slate-800">
                        ${(product.price / 100).toFixed(2)}
                      </td>
                      <td class="p-4 font-mono font-bold">
                        <span class={product.stock <= 5 ? "text-amber-600" : "text-slate-600"}>
                          {product.stock} uds
                        </span>
                      </td>
                      <td class="p-4">
                        {product.variants && product.variants.length > 0 ? (
                          <div class="flex flex-wrap gap-1">
                            {product.variants.map((v) => (
                              <span class="px-2 py-0.5 rounded bg-slate-50 text-[10px] text-slate-600 border border-slate-200 font-semibold shadow-3xs">
                                {v.name} (${(v.price / 100).toFixed(0)}) · {v.stock}
                              </span>
                            ))}
                          </div>
                        ) : (
                          <span class="text-slate-400 italic">Sin variantes</span>
                        )}
                      </td>
                      <td class="p-4 text-right pr-6 flex justify-end gap-2 items-center">
                        <button
                          type="button"
                          class="edit-product-btn px-3 py-1.5 bg-white hover:bg-slate-50 border border-slate-200 rounded-lg text-3xs font-bold text-slate-700 uppercase tracking-wider transition-colors shrink-0 shadow-3xs"
                          data-product={JSON.stringify(product)}
                        >
                          Editar
                        </button>
                        <button
                          type="button"
                          class="delete-product-btn px-3 py-1.5 bg-rose-50 hover:bg-rose-650 text-rose-650 hover:text-white border border-rose-100 hover:border-rose-600 rounded-lg text-3xs font-bold uppercase tracking-wider transition-colors shrink-0"
                          data-product-id={product.id}
                          data-product-title={product.title}
                        >
                          Eliminar
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- TAB: COLLECTIONS SECTION -->
      <section id="section-collections" class="w-full hidden flex flex-col gap-6">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-200 pb-4">
          <div>
            <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Escritorio de Colecciones</h2>
            <p class="text-3xs text-slate-400 uppercase tracking-widest mt-1">Arrastra productos de la barra lateral y suéltalos en las carpetas para clasificarlos.</p>
          </div>
          <div class="flex items-center gap-3 w-full sm:w-auto">
            <input
              type="text"
              id="search-collections"
              placeholder="Buscar carpeta..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-48 shadow-2xs"
            />
            <button
              type="button"
              id="open-new-collection-modal"
              class="px-4 py-2.5 bg-rose-600 hover:bg-red-700 text-white rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-200 active:scale-95 flex items-center gap-1.5 shadow-md shrink-0"
            >
              <span>+ Nueva Carpeta</span>
            </button>
          </div>
        </div>

        <!-- Workspace Workspace (Split layout) -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          
          <!-- LEFT AREA: Windows Desktop Grid (Col span 8) -->
          <div class="lg:col-span-8 bg-white border border-slate-200 rounded-3xl p-6 min-h-[55vh] relative flex flex-col gap-6 shadow-sm">
            <!-- Grid of amber folders -->
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6" id="collections-desktop">
              {collections.map((col) => (
                <div 
                  class="collection-folder group flex flex-col items-center justify-center p-4 rounded-2xl border border-transparent hover:border-slate-200/80 hover:bg-slate-50/50 cursor-pointer transition-all duration-200 select-none text-center"
                  data-id={col.id}
                  data-collection-slug={col.slug}
                  data-collection-json={JSON.stringify(col)}
                  data-title={col.title.toLowerCase()}
                  data-slug={col.slug.toLowerCase()}
                >
                  <!-- Windows 11 style Amber Folder Shape -->
                  <div class="w-16 h-12 relative flex items-end justify-center shrink-0">
                    <!-- Back folder layer -->
                    <div class="absolute inset-0 bg-amber-500 rounded-lg shadow-sm border border-amber-600"></div>
                    <!-- Tab of folder -->
                    <div class="absolute -top-1 left-2 w-6 h-1 bg-amber-600 rounded-t"></div>
                    <!-- Front leaf of folder -->
                    <div class="absolute inset-0 bg-amber-400 rounded-lg origin-bottom transform group-hover:-rotate-x-12 transition-transform duration-300 shadow-sm border border-amber-300"></div>
                    <!-- File item inside folder showing count -->
                    <div class="w-10 h-8 bg-white border border-slate-200 absolute -top-2 left-3 rotate-3 rounded group-hover:-translate-y-1.5 transition-transform flex items-center justify-center text-[10px] font-black text-slate-800 font-mono shadow-sm">
                      {col.productIds ? col.productIds.length : 0}
                    </div>
                  </div>
                  
                  <span class="mt-3 text-xs font-bold text-slate-800 group-hover:text-amber-600 transition-colors line-clamp-2 max-w-[120px] leading-tight">
                    {col.title}
                  </span>
                  
                  <span class="text-[9px] text-slate-400 font-mono mt-0.5 truncate max-w-[100px]">
                    /{col.slug}
                  </span>
                </div>
              ))}
            </div>
            
            {collections.length === 0 && (
              <div class="flex-grow flex flex-col items-center justify-center text-center p-8 gap-3 text-slate-400">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
                </svg>
                <span class="text-xs font-bold uppercase tracking-wider">Escritorio vacío</span>
                <span class="text-3xs text-slate-400 max-w-xs">Crea una nueva carpeta de colección para empezar a organizar tus productos.</span>
              </div>
            )}
          </div>

          <!-- RIGHT AREA: Catalog Sidebar Drawer (Col span 4) -->
          <div class="lg:col-span-4 bg-white border border-slate-200 rounded-3xl p-5 shadow-sm flex flex-col gap-4 max-h-[60vh]">
            <div class="flex justify-between items-center border-b border-slate-200 pb-2">
              <span class="text-2xs font-extrabold text-slate-400 uppercase tracking-widest">Catálogo de Artículos</span>
              <span class="text-[10px] text-slate-500 font-mono">{products.length} productos</span>
            </div>
            
            <!-- Draggable Products List -->
            <div class="flex flex-col gap-2.5 overflow-y-auto pr-1 flex-grow" id="catalog-draggable-container">
              {products.map((p) => (
                <div
                  class="product-draggable bg-slate-50 hover:bg-slate-100/80 border border-slate-200 p-2.5 rounded-2xl flex items-center gap-3 cursor-grab active:cursor-grabbing select-none transition-all duration-200 group"
                  draggable="true"
                  data-id={p.id}
                  data-title={p.title}
                  data-image={p.images[0]}
                  data-sku={p.variants[0]?.sku || 'BASE'}
                >
                  <!-- Drag Indicator -->
                  <div class="text-slate-400 group-hover:text-slate-650 cursor-grab shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
                    </svg>
                  </div>
                  
                  <!-- Tiny Image -->
                  <div class="w-9 h-12 rounded overflow-hidden bg-white shrink-0 border border-slate-200">
                    <img src={p.images[0]} class="w-full h-full object-cover" style={`object-position: ${getObjectPosition(p.images[0])}`} />
                  </div>
                  
                  <div class="flex-1 min-w-0">
                    <span class="block text-3xs font-extrabold text-slate-400 uppercase tracking-widest font-mono">
                      SKU: {p.variants[0]?.sku || 'BASE'}
                    </span>
                    <span class="block text-xs font-bold text-slate-800 truncate leading-tight">
                      {p.title}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
        </div>
      </section>

      <!-- TAB: ORDERS SECTION -->
      <section id="section-orders" class="w-full hidden">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Listado de Pedidos</h2>
          <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto">
            <input
              type="text"
              id="search-orders"
              placeholder="Buscar por cliente, email o ID..."
              class="px-4 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-900 text-xs placeholder-slate-400 focus:outline-none focus:border-rose-600 w-full sm:w-60 shadow-2xs"
            />
            <select
              id="filter-payment-status"
              class="px-3 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-700 text-xs focus:outline-none focus:border-rose-600 font-semibold shadow-3xs"
            >
              <option value="">Todos los Pagos</option>
              <option value="paid">Pagado</option>
              <option value="pending">Pendiente</option>
              <option value="failed">Fallido</option>
            </select>
            <select
              id="filter-shipping-status"
              class="px-3 py-2.5 rounded-xl bg-white border border-slate-200 text-slate-700 text-xs focus:outline-none focus:border-rose-600 font-semibold shadow-3xs"
            >
              <option value="">Todos los Envíos</option>
              <option value="pending">Pendiente</option>
              <option value="shipped">Enviado</option>
              <option value="delivered">Entregado</option>
              <option value="cancelled">Cancelado</option>
            </select>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-2xs font-extrabold tracking-widest uppercase border-b border-slate-200">
                  <th class="p-4 pl-6">ID Pedido / Fecha</th>
                  <th class="p-4">Cliente</th>
                  <th class="p-4">Importe Total</th>
                  <th class="p-4">Artículos</th>
                  <th class="p-4">Estados</th>
                  <th class="p-4 text-right pr-6">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
                {orders.length === 0 ? (
                  <tr>
                    <td colspan="6" class="p-8 text-center text-slate-400 font-medium">
                      No se han registrado pedidos en la tienda todavía.
                    </td>
                  </tr>
                ) : (
                  orders.map((order) => (
                    <tr class="order-row hover:bg-slate-50 transition-colors cursor-pointer"
                      data-id={order.id.toLowerCase()}
                      data-name={order.customerDetails.name.toLowerCase()}
                      data-email={order.customerDetails.email.toLowerCase()}
                      data-payment-status={order.paymentStatus}
                      data-shipping-status={order.shippingStatus}
                      data-order={JSON.stringify(order)}
                    >
                      <td class="p-4 pl-6">
                        <span class="block font-bold font-mono text-slate-900 text-xs">{order.id.slice(-8).toUpperCase()}...</span>
                        <span class="block text-slate-400 text-3xs mt-0.5">
                          {new Date(order.createdAt).toLocaleDateString()} {new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                        </span>
                      </td>
                      <td class="p-4">
                        <span class="block font-bold text-slate-900">{order.customerDetails.name}</span>
                        <span class="block text-slate-400 text-3xs font-mono">{order.customerDetails.email}</span>
                      </td>
                      <td class="p-4 font-mono font-bold text-emerald-600">
                        ${(order.totalAmount / 100).toFixed(2)}
                      </td>
                      <td class="p-4">
                        <div class="flex flex-col gap-1 max-w-[200px]">
                          {order.items.map((item) => (
                            <span class="text-3xs text-slate-500 truncate">
                              • {item.title} {item.variantName ? `(${item.variantName})` : ''} x{item.quantity}
                            </span>
                          ))}
                        </div>
                      </td>
                      <td class="p-4">
                        <div class="flex flex-col gap-1">
                          <span class={`px-2 py-0.5 rounded text-[10px] font-extrabold uppercase w-fit tracking-wider border ${
                            order.paymentStatus === 'paid' 
                              ? 'bg-emerald-50 border-emerald-200 text-emerald-700' 
                              : 'bg-amber-50 border-amber-200 text-amber-700'
                          }`}>
                            Pago: {order.paymentStatus}
                          </span>
                          <span class={`px-2 py-0.5 rounded text-[10px] font-extrabold uppercase w-fit tracking-wider border ${
                            order.shippingStatus === 'shipped' 
                              ? 'bg-blue-50 border-blue-200 text-blue-700' 
                              : order.shippingStatus === 'delivered'
                              ? 'bg-emerald-50 border-emerald-200 text-emerald-700'
                              : 'bg-slate-50 border-slate-200 text-slate-600'
                          }`}>
                            Envío: {order.shippingStatus}
                          </span>
                        </div>
                      </td>
                      <td class="p-4 text-right pr-6">
                        {order.shippingStatus === 'pending' && (
                          <button
                            type="button"
                            class="ship-order-btn px-3 py-1.5 bg-rose-600 hover:bg-red-700 text-white rounded-lg text-3xs font-bold uppercase tracking-wider transition-colors active:scale-95 shadow-2xs"
                            data-order-id={order.id}
                          >
                            Enviar
                          </button>
                        )}
                        {order.trackingNumber && (
                          <span class="block text-slate-500 text-3xs font-mono">
                            Seguimiento: <br/><strong class="text-slate-700">{order.trackingNumber}</strong>
                          </span>
                        )}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- TAB: SETTINGS SECTION -->
      <section id="section-settings" class="w-full hidden">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wider">Configuración General</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Left Side: Sub-navigation sidebar menu -->
          <div class="md:col-span-1 flex flex-col gap-1 bg-white border border-slate-200 p-4 rounded-2xl shadow-sm h-fit">
            <button
              type="button"
              id="subtab-shipping-btn"
              class="w-full text-left px-4 py-3 rounded-xl font-bold text-xs uppercase tracking-wider transition-all focus:outline-none flex items-center gap-2.5 bg-red-50 text-rose-600"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.75a1.125 1.125 0 0 1-1.125-1.125V15h9.75M8.25 18.75a1.5 1.5 0 0 0 3 0M12 18.75a1.5 1.5 0 0 0-3 0m3 0h3.75a1.125 1.125 0 0 0 1.125-1.125V18m-4.875-13.5v10.125c0 .621.504 1.125 1.125 1.125H18M15 4.5V15h4.5M19.5 18a2.25 2.25 0 0 0-2.25-2.25h-1.5A2.25 2.25 0 0 0 13.5 18m6 0a2.25 2.25 0 0 1-2.25 2.25h-1.5A2.25 2.25 0 0 1 13.5 18" /></svg>
              Envíos y Mercados
            </button>
            <button
              type="button"
              id="subtab-admins-btn"
              class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm-3.75 7.875c0-1.242 1.343-2.25 3-2.25s3 1.008 3 2.25H6.75Z" /></svg>
              Administradores
            </button>
            <button
              type="button"
              id="subtab-branding-btn"
              class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 3.395-1.622m-3.395 1.622a15.999 15.999 0 0 1-1.622-3.395m3.42-3.42L15 4.5M10.97 8.53 4.5 15" /></svg>
              Identidad de Marca
            </button>
            <button
              type="button"
              id="subtab-coupons-btn"
              class="w-full text-left px-4 py-3 rounded-xl font-semibold text-xs uppercase tracking-wider text-slate-500 hover:bg-slate-50 hover:text-slate-900 transition-all focus:outline-none flex items-center gap-2.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a2.25 2.25 0 0 0 3.181 0l5.178-5.178a2.25 2.25 0 0 0 0-3.181l-9.58-9.581A2.25 2.25 0 0 0 9.568 3Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" /></svg>
              Códigos Descuento
            </button>
          </div>

          <!-- Right Side: Forms/Content Panel -->
          <div class="md:col-span-3 flex flex-col gap-6 text-xs text-slate-705">
            
            <!-- SUBSECTION: SHIPPING & MARKETS -->
            <form id="form-sub-shipping" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Envíos y Mercados</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal">Configura el costo de los envíos estándar, el umbral para envío gratuito y los códigos de país habilitados en Stripe.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="settings-shipping-price" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Envío Estándar ($/€, Ej: 4.99)</label>
                  <input
                    type="number"
                    step="0.01"
                    id="settings-shipping-price"
                    value={(settings.shippingPrice / 100).toFixed(2)}
                    required
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
                <div>
                  <label for="settings-free-shipping-min" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Límite Envío Gratis ($/€, Ej: 50.00)</label>
                  <input
                    type="number"
                    step="0.01"
                    id="settings-free-shipping-min"
                    value={(settings.freeShippingMin / 100).toFixed(2)}
                    required
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
                <div class="md:col-span-2 flex flex-col gap-4">
                  <div>
                    <span class="block font-semibold mb-2 text-slate-500 uppercase tracking-wider">Selección de Países (Mercados de Stripe)</span>
                    
                    <!-- Regional Quick Select Buttons -->
                    <div class="flex flex-wrap gap-2 mb-3">
                      <button
                        type="button"
                        id="preset-europe-btn"
                        class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 hover:text-slate-900 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-slate-200 cursor-pointer"
                      >
                        🇪🇺 Europa (UE)
                      </button>
                      <button
                        type="button"
                        id="preset-northamerica-btn"
                        class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 hover:text-slate-900 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-slate-200 cursor-pointer"
                      >
                        🌎 Norteamérica (US, CA, MX)
                      </button>
                      <button
                        type="button"
                        id="preset-clear-btn"
                        class="px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 hover:text-rose-700 rounded-xl text-3xs font-black uppercase tracking-wider transition-colors border border-rose-100 cursor-pointer"
                      >
                        ✕ Deseleccionar Todo
                      </button>
                    </div>

                    <!-- Checklist of Common Countries -->
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-200/80 mb-3">
                      <!-- Spain -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="ES" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('ES')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇪🇸 España (ES)</span>
                      </label>
                      <!-- France -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="FR" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('FR')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇫🇷 Francia (FR)</span>
                      </label>
                      <!-- Germany -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="DE" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('DE')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇩🇪 Alemania (DE)</span>
                      </label>
                      <!-- Italy -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="IT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('IT')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇮🇹 Italia (IT)</span>
                      </label>
                      <!-- Portugal -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="PT" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('PT')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇵🇹 Portugal (PT)</span>
                      </label>
                      <!-- United Kingdom -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="GB" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('GB')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇬🇧 Reino Unido (GB)</span>
                      </label>
                      <!-- United States -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="US" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('US')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇺🇸 EE.UU. (US)</span>
                      </label>
                      <!-- Canada -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="CA" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('CA')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇨🇦 Canadá (CA)</span>
                      </label>
                      <!-- Mexico -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="MX" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('MX')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇲🇽 México (MX)</span>
                      </label>
                    </div>

                    <!-- Auxiliary manual input for other countries -->
                    <div>
                      <label for="settings-other-markets" class="block font-semibold mb-1 text-slate-400 uppercase tracking-wider text-3xs">Otros Países Adicionales (Separados por comas, ej: JP, AU, CH)</label>
                      <input
                        type="text"
                        id="settings-other-markets"
                        value={otherCountries.join(', ')}
                        placeholder="Ej: JP, AU, CH"
                        class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                      />
                    </div>
                  </div>
                </div>
              </div>

              <div class="flex justify-end pt-4 border-t border-slate-100">
                <button
                  type="submit"
                  id="save-shipping-btn"
                  class="px-6 py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-2xs font-extrabold uppercase tracking-wider transition-all active:scale-95 shadow-sm"
                >
                  Guardar Envíos y Mercados
                </button>
              </div>
            </form>

            <!-- SUBSECTION: ADMINISTRATORS -->
            <form id="form-sub-admins" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Administradores del Sistema</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Delega o revoca permisos de acceso de administrador secundarios por correo electrónico.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="md:col-span-1 flex flex-col gap-3">
                  <label for="new-admin-email" class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Agregar Administrador</label>
                  <div class="flex gap-2">
                    <input
                      type="email"
                      id="new-admin-email"
                      placeholder="admin@flexform.com"
                      class="flex-1 px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 text-xs font-medium"
                    />
                    <button
                      type="button"
                      id="add-admin-btn"
                      class="px-4 py-2 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shrink-0"
                    >
                      Añadir
                    </button>
                  </div>
                  <p class="text-slate-400 text-3xs leading-normal font-medium">
                    Los administradores delegados podrán acceder a todo el panel usando su propia cuenta de Firebase Auth / Google.
                  </p>
                </div>

                <div class="md:col-span-2 flex flex-col gap-2">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Administradores Autorizados</span>
                  <div class="flex flex-col gap-2 max-h-[220px] overflow-y-auto pr-1" id="admins-list-container">
                    <!-- Super Admin (Read-only) -->
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200">
                      <div class="flex flex-col">
                        <span class="font-bold text-slate-800 font-mono">{import.meta.env.SUPERADMIN_EMAIL || process.env.SUPERADMIN_EMAIL || 'admin@flexform.com'}</span>
                        <span class="text-3xs text-rose-600 font-extrabold uppercase tracking-wider mt-0.5">Superadministrador Principal (.env)</span>
                      </div>
                      <span class="text-2xs text-slate-400 italic px-2">Solo lectura</span>
                    </div>

                    <!-- Dynamic Admins list -->
                    {settings.admins && settings.admins.map((adminEmail) => (
                      <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-colors admin-row" data-email={adminEmail}>
                        <span class="font-bold text-slate-800 font-mono">{adminEmail}</span>
                        <button
                          type="button"
                          class="remove-admin-btn text-rose-500 hover:text-rose-600 hover:bg-rose-50 p-2.5 rounded-xl transition-colors font-bold text-base"
                          title="Eliminar administrador"
                        >
                          ×
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 text-3xs font-extrabold uppercase tracking-widest border border-emerald-100 select-none">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                  Autoguardado Activo
                </span>
              </div>
            </form>

            <!-- SUBSECTION: BRANDING (LOGO & FAVICON) -->
            <form id="form-sub-branding" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Identidad de Marca</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Introduce las URLs para el logotipo y el favicon de la pestaña del navegador.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="settings-logo" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Logotipo</label>
                  <input
                    type="text"
                    id="settings-logo"
                    value={settings.logoUrl || ''}
                    placeholder="Ej: /logo.png o https://..."
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
                <div>
                  <label for="settings-favicon" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Favicon</label>
                  <input
                    type="text"
                    id="settings-favicon"
                    value={settings.faviconUrl || ''}
                    placeholder="Ej: /favicon.ico o https://..."
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
              </div>

              <div class="flex justify-end pt-4 border-t border-slate-100">
                <button
                  type="submit"
                  id="save-branding-btn"
                  class="px-6 py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-2xs font-extrabold uppercase tracking-wider transition-all active:scale-95 shadow-sm"
                >
                  Guardar Imagen y Marca
                </button>
              </div>
            </form>

            <!-- SUBSECTION: STRIPE DISCOUNT CODES -->
            <div id="form-sub-coupons" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Códigos de Descuento (Stripe)</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Crea cupones activos de descuento en Stripe y desactiva los códigos existentes.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                <!-- Left side: create discount form -->
                <div class="md:col-span-1 flex flex-col gap-3">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Crear Nuevo Código</span>
                  
                  <div class="flex flex-col gap-3 bg-slate-50 p-4 rounded-xl border border-slate-200">
                    <div>
                      <label for="promo-code-name" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Nombre del Código</label>
                      <input
                        type="text"
                        id="promo-code-name"
                        placeholder="Ej: SUMMER20"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-bold uppercase text-xs"
                      />
                    </div>

                    <div>
                      <label for="promo-code-type" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Tipo de Descuento</label>
                      <select
                        id="promo-code-type"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-707 focus:outline-none focus:border-rose-600 font-semibold text-xs"
                      >
                        <option value="percent">Porcentaje (%)</option>
                        <option value="amount">Cantidad Fija (USD)</option>
                      </select>
                    </div>

                    <div>
                      <label for="promo-code-value" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Valor del Descuento</label>
                      <input
                        type="number"
                        step="0.01"
                        id="promo-code-value"
                        placeholder="Ej: 20 o 5.00"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-xs"
                      />
                    </div>

                    <button
                      type="button"
                      id="create-promo-btn"
                      class="w-full py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs"
                    >
                      Crear Código
                    </button>
                  </div>
                </div>
                
                <!-- Right side: active discount codes list -->
                <div class="md:col-span-2 flex flex-col gap-2">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Códigos Activos en Stripe</span>
                  
                  <div class="flex flex-col gap-2 max-h-[300px] overflow-y-auto pr-1" id="promos-list-container">
                    {promotionCodes.length === 0 ? (
                      <div class="p-6 text-center text-slate-400 border border-dashed border-slate-200 rounded-xl bg-slate-50/50">
                        No hay códigos de descuento activos.
                      </div>
                    ) : (
                      promotionCodes.map((promo) => {
                        const coupon = promo.coupon;
                        let discountStr = '';
                        if (coupon.percent_off) {
                          discountStr = `${coupon.percent_off}% de descuento`;
                        } else if (coupon.amount_off) {
                          discountStr = `$${(coupon.amount_off / 100).toFixed(2)} de descuento`;
                        }
                        
                        return (
                          <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-colors shadow-3xs" data-promo-id={promo.id}>
                            <div class="flex flex-col">
