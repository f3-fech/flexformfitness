      function toggleModal(modal: HTMLDivElement, open: boolean) {
        if (open) {
          modal.classList.remove('hidden');
          // Inline style overflow & height lock
          document.body.style.overflow = 'hidden';
          document.body.style.height = '100vh';
          document.documentElement.style.overflow = 'hidden';
          document.documentElement.style.height = '100vh';
        } else {
          modal.classList.add('hidden');
          // Check if any other modal is still open before unlocking scroll
          const anyOpen = Array.from(document.querySelectorAll('#collection-modal, #product-modal, #gallery-modal, #ship-modal, #crop-modal, #order-details-modal'))
            .some(m => !m.classList.contains('hidden'));
          if (!anyOpen) {
            document.body.style.overflow = '';
            document.body.style.height = '';
            document.documentElement.style.overflow = '';
            document.documentElement.style.height = '';
          }
        }
      }

