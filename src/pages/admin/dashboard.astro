                        class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                      />
                    </div>
                  </div>
                </div>
              </div>

              <div class="flex justify-end pt-4 border-t border-slate-100">
                <button
                  type="submit"
                  id="save-shipping-btn"
                  class="px-6 py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-2xs font-extrabold uppercase tracking-wider transition-all active:scale-95 shadow-sm"
                >
                  Guardar Envíos y Mercados
                </button>
              </div>
            </form>

            <!-- SUBSECTION: ADMINISTRATORS -->
            <form id="form-sub-admins" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Administradores del Sistema</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Delega o revoca permisos de acceso de administrador secundarios por correo electrónico.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="md:col-span-1 flex flex-col gap-3">
                  <label for="new-admin-email" class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Agregar Administrador</label>
                  <div class="flex gap-2">
                    <input
                      type="email"
                      id="new-admin-email"
                      placeholder="admin@flexform.com"
                      class="flex-1 px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 text-xs font-medium"
                    />
                    <button
                      type="button"
                      id="add-admin-btn"
                      class="px-4 py-2 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shrink-0"
                    >
                      Añadir
                    </button>
                  </div>
                  <p class="text-slate-400 text-3xs leading-normal font-medium">
                    Los administradores delegados podrán acceder a todo el panel usando su propia cuenta de Firebase Auth / Google.
                  </p>
                </div>

                <div class="md:col-span-2 flex flex-col gap-2">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Administradores Autorizados</span>
                  <div class="flex flex-col gap-2 max-h-[220px] overflow-y-auto pr-1" id="admins-list-container">
                    <!-- Super Admin (Read-only) -->
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200">
                      <div class="flex flex-col">
                        <span class="font-bold text-slate-800 font-mono">{import.meta.env.SUPERADMIN_EMAIL || process.env.SUPERADMIN_EMAIL || 'admin@flexform.com'}</span>
                        <span class="text-3xs text-rose-600 font-extrabold uppercase tracking-wider mt-0.5">Superadministrador Principal (.env)</span>
                      </div>
                      <span class="text-2xs text-slate-400 italic px-2">Solo lectura</span>
                    </div>

                    <!-- Dynamic Admins list -->
                    {settings.admins && settings.admins.map((adminEmail) => (
                      <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-colors admin-row" data-email={adminEmail}>
                        <span class="font-bold text-slate-800 font-mono">{adminEmail}</span>
                        <button
                          type="button"
                          class="remove-admin-btn text-rose-500 hover:text-rose-600 hover:bg-rose-50 p-2.5 rounded-xl transition-colors font-bold text-base"
                          title="Eliminar administrador"
                        >
                          ×
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 text-3xs font-extrabold uppercase tracking-widest border border-emerald-100 select-none">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                  Autoguardado Activo
                </span>
              </div>
            </form>

            <!-- SUBSECTION: BRANDING (LOGO & FAVICON & HERO VIDEO) -->
            <form id="form-sub-branding" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Identidad de Marca</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Introduce las URLs para el logotipo, el favicon y el video de portada de tu sitio.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="settings-logo" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Logotipo</label>
                  <input
                    type="text"
                    id="settings-logo"
                    value={settings.logoUrl || ''}
                    placeholder="Ej: /logo.png o https://..."
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
                <div>
                  <label for="settings-favicon" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Favicon</label>
                  <input
                    type="text"
                    id="settings-favicon"
                    value={settings.faviconUrl || ''}
                    placeholder="Ej: /favicon.ico o https://..."
                    class="w-full px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                  />
                </div>
              </div>

              <div class="border-t border-slate-100 pt-4 flex flex-col gap-4">
                <div>
                  <label for="settings-hero-video" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">URL del Video del Hero</label>
                  <div class="flex gap-2">
                    <input
                      type="text"
                      id="settings-hero-video"
                      value={settings.heroVideoUrl || ''}
                      placeholder="Ej: https://..."
                      class="flex-grow px-3 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-sm"
                    />
                    <button
                      type="button"
                      id="open-video-gallery-btn"
                      class="px-4 py-2.5 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shrink-0"
                    >
                      Seleccionar Video
                    </button>
                  </div>
                  
                  <!-- Preview of the current video -->
                  <div id="settings-hero-video-preview" class="mt-3 aspect-video max-w-sm rounded-xl overflow-hidden border border-slate-200 bg-slate-100 flex items-center justify-center">
                    {settings.heroVideoUrl ? (
                      <video src={settings.heroVideoUrl} autoplay loop muted playsinline class="w-full h-full object-cover" />
                    ) : (
                      <span class="text-3xs text-slate-400 font-bold uppercase tracking-widest">Sin Vista Previa</span>
                    )}
                  </div>
                </div>
              </div>

              <div class="flex justify-end pt-4 border-t border-slate-100">
                <button
                  type="submit"
                  id="save-branding-btn"
                  class="px-6 py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-2xs font-extrabold uppercase tracking-wider transition-all active:scale-95 shadow-sm"
                >
                  Guardar Imagen y Marca
                </button>
              </div>
            </form>

            <!-- SUBSECTION: STRIPE DISCOUNT CODES -->
            <div id="form-sub-coupons" class="bg-white border border-slate-200 p-6 rounded-2xl flex flex-col gap-6 shadow-sm hidden">
              <div class="border-b border-slate-100 pb-3 flex flex-col gap-1">
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-slate-900">Códigos de Descuento (Stripe)</h3>
                <p class="text-slate-400 text-3xs normal-case leading-normal font-medium">Crea cupones activos de descuento en Stripe y desactiva los códigos existentes.</p>
              </div>

              <!-- Configuration of Free Shipping threshold inside coupons tab -->
              <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl flex flex-col gap-3">
                <span class="block font-bold text-slate-900 uppercase tracking-wider text-3xs">Ajustes de Envío de la Tienda</span>
                <form id="form-sub-coupons-free-shipping" class="flex flex-col sm:flex-row items-end gap-3">
                  <div class="flex-1 w-full">
                    <label for="settings-coupons-free-shipping-min" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider font-sans">Monto Mínimo para Envío Gratis (USD)</label>
                    <input
                      type="number"
                      step="0.01"
                      id="settings-coupons-free-shipping-min"
                      value={(settings.freeShippingMin / 100).toFixed(2)}
                      placeholder="Ej: 50.00"
                      class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-xs"
                    />
                  </div>
                  <button
                    type="submit"
                    class="w-full sm:w-auto px-5 py-2.5 bg-slate-950 hover:bg-slate-900 text-white rounded-xl text-xs font-bold uppercase transition-colors shrink-0"
                  >
                    Guardar Envío
                  </button>
                </form>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                <!-- Left side: create discount form -->
                <div class="md:col-span-1 flex flex-col gap-3">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Crear Nuevo Código</span>
                  
                  <div class="flex flex-col gap-3 bg-slate-50 p-4 rounded-xl border border-slate-200">
                    <div>
                      <label for="promo-code-name" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Nombre del Código</label>
                      <input
                        type="text"
                        id="promo-code-name"
                        placeholder="Ej: SUMMER20"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-bold uppercase text-xs"
                      />
                    </div>

                    <div>
                      <label for="promo-code-type" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Tipo de Descuento</label>
                      <select
                        id="promo-code-type"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-707 focus:outline-none focus:border-rose-600 font-semibold text-xs"
                      >
                        <option value="percent">Porcentaje (%)</option>
                        <option value="amount">Cantidad Fija (USD)</option>
                      </select>
                    </div>

                    <div>
                      <label for="promo-code-value" class="block font-semibold mb-1 text-slate-500 uppercase tracking-wider">Valor del Descuento</label>
                      <input
                        type="number"
                        step="0.01"
                        id="promo-code-value"
                        placeholder="Ej: 20 o 5.00"
                        class="w-full px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-909 focus:outline-none focus:border-rose-600 font-mono text-xs"
                      />
                    </div>

                    <button
                      type="button"
                      id="create-promo-btn"
                      class="w-full py-2.5 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-xs font-bold uppercase transition-colors shadow-2xs"
                    >
                      Crear Código
                    </button>
                  </div>
                </div>
                
                <!-- Right side: active discount codes list -->
                <div class="md:col-span-2 flex flex-col gap-2">
                  <span class="block font-semibold text-slate-500 uppercase tracking-wider mb-1">Códigos Activos en Stripe</span>
                  
                  <div class="flex flex-col gap-2 max-h-[300px] overflow-y-auto pr-1" id="promos-list-container">
                    {promotionCodes.length === 0 ? (
                      <div class="p-6 text-center text-slate-400 border border-dashed border-slate-200 rounded-xl bg-slate-50/50">
                        No hay códigos de descuento activos.
                      </div>
                    ) : (
                      promotionCodes.map((promo) => {
                        const coupon = promo.coupon;
                        let discountStr = '';
                        if (coupon.percent_off) {
                          discountStr = `${coupon.percent_off}% de descuento`;
                        } else if (coupon.amount_off) {
                          discountStr = `$${(coupon.amount_off / 100).toFixed(2)} de descuento`;
                        }
                        
                        return (
                          <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-slate-100 hover:border-slate-200 transition-colors shadow-3xs" data-promo-id={promo.id}>
                            <div class="flex flex-col">
                              <span class="font-black text-slate-905 font-mono text-sm tracking-wide uppercase">{promo.code}</span>
                              <span class="text-3xs text-slate-400 font-semibold uppercase tracking-wider mt-0.5">{discountStr} · Permanente</span>
                            </div>
                            <button
                              type="button"
                              class="delete-promo-btn text-rose-500 hover:text-rose-600 hover:bg-rose-50 p-2.5 rounded-xl transition-colors font-bold text-base"
                              data-promo-id={promo.id}
                              title="Eliminar código de descuento"
                            >
                              ×
                            </button>
                          </div>
                        );
                      })
                    )}
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="bg-white text-slate-400 py-8 px-6 text-center text-xs border-t border-slate-200 mt-12 w-full">
      <p class="text-slate-400">&copy; {new Date().getFullYear()} FLEX FORM FITNESS. Panel de control exclusivo para administradores autorizados.</p>
    </footer>

    <!-- MODAL: COLLECTION FORM (CREATE / EDIT) -->
    <!-- MODAL: WINDOW FOLDER VIEW & EDIT -->
    <div id="collection-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden">
      <div class="bg-white border border-slate-200 rounded-3xl w-full max-w-[95vw] lg:max-w-[90vw] xl:max-w-[85vw] h-[92vh] max-h-[92vh] flex flex-col shadow-2xl overflow-hidden animate-fade-in">
        
        <!-- Window Title Bar (Windows-like layout) -->
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-200 flex justify-between items-center select-none shrink-0">
          <div class="flex items-center gap-2.5">
            <div class="w-5 h-5 bg-amber-500/10 text-amber-500 rounded flex items-center justify-center border border-amber-500/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9" />
              </svg>
            </div>
            <h3 id="collection-modal-title" class="text-xs font-extrabold tracking-widest text-slate-800 uppercase font-mono">
              Propiedades de Carpeta
            </h3>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
            <button type="button" id="close-collection-modal" class="w-5 h-5 flex items-center justify-center rounded bg-slate-100 hover:bg-rose-600 hover:text-white text-slate-500 text-xs font-bold transition-all" title="Cerrar Ventana">
              ×
            </button>
          </div>
        </div>
        
        <!-- Modal Tab Bar -->
        <div class="px-6 bg-slate-50 border-b border-slate-200 flex gap-4 shrink-0 select-none">
          <button type="button" id="coll-tab-info" class="py-3 px-1 border-b-2 border-rose-600 text-rose-600 font-extrabold text-xs uppercase tracking-wider focus:outline-none transition-all cursor-pointer">
            1. Propiedades y SEO
          </button>
          <button type="button" id="coll-tab-products" class="py-3 px-1 border-b-2 border-transparent text-slate-400 hover:text-slate-900 font-extrabold text-xs uppercase tracking-wider focus:outline-none transition-all cursor-pointer">
            2. Organizar Productos
          </button>
        </div>

        <form id="collection-form" class="flex-grow overflow-hidden flex flex-col text-xs bg-slate-50/35">
