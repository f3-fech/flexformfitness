                    Variables dinámicas: <code class="bg-slate-100 px-1 py-0.5 rounded text-rose-600 font-bold font-mono">{"{{customerName}}"}</code>, <code class="bg-slate-100 px-1 py-0.5 rounded text-rose-600 font-bold font-mono">{"{{orderId}}"}</code>, <code class="bg-slate-100 px-1 py-0.5 rounded text-rose-600 font-bold font-mono">{"{{orderItems}}"}</code>, <code class="bg-slate-100 px-1 py-0.5 rounded text-rose-600 font-bold font-mono">{"{{totalAmount}}"}</code>, <code class="bg-slate-100 px-1 py-0.5 rounded text-rose-600 font-bold font-mono">{"{{invoiceUrl}}"}</code>
                  </span>
                </div>
              </div>
              </div>

              <!-- Abandoned Cart Template -->
              <div class="border-t border-slate-100 pt-4 flex flex-col gap-4">
                <h4 class="text-xs font-bold uppercase tracking-wider text-rose-600">2. Recuperación de Carrito Abandonado</h4>
                
                <div class="flex flex-col gap-1">
                  <label for="email-abandoned-subject" class="block font-semibold text-slate-500 uppercase tracking-wider text-3xs">Asunto del Correo</label>
                  <input
                    type="text"
                    id="email-abandoned-subject"
                    name="abandonedSubject"
                    value={emailSettings.abandonedSubject}
                    class="px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-xs focus:outline-none focus:border-rose-600 focus:bg-white w-full"
                    required
                  />
                </div>

                <div class="flex flex-col gap-2">
                  <label class="block font-semibold text-slate-500 uppercase tracking-wider text-3xs">Cuerpo del Correo</label>
                  
                  <!-- Editor Container -->
                  <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-2xs bg-white">
                    <!-- Tab Selector & Toolbar -->
                    <div class="flex flex-wrap items-center justify-between bg-slate-50 border-b border-slate-200 p-2 gap-2">
                      <!-- Editor Modes -->
                      <div class="flex bg-slate-200/80 p-0.5 rounded-lg text-4xs font-bold uppercase tracking-wider">
                        <button type="button" id="btn-mode-visual-abandoned" class="px-3 py-1.5 rounded-md bg-white text-rose-600 shadow-3xs transition-all focus:outline-none">Vista Visual</button>
                        <button type="button" id="btn-mode-html-abandoned" class="px-3 py-1.5 rounded-md text-slate-500 hover:text-slate-900 transition-all focus:outline-none">Código HTML</button>
