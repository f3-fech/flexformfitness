        try {
          await signOut(auth);
        } catch (err) {
          console.error('Error al cerrar sesión client-side:', err);
        }
        window.location.href = '/admin/logout';
      });

      const tabProductsBtn = document.getElementById('tab-products-btn') as HTMLButtonElement;
