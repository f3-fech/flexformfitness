                      <!-- Canada -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="CA" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('CA')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇨🇦 Canadá (CA)</span>
                      </label>
                      <!-- Mexico -->
                      <label class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-slate-100 hover:border-slate-200 hover:shadow-3xs transition-all cursor-pointer">
                        <input type="checkbox" name="country-checkbox" value="MX" class="country-cb w-4 h-4 rounded text-rose-600 border-slate-300 focus:ring-rose-600" checked={settings.markets.includes('MX')} />
                        <span class="text-2xs font-extrabold uppercase text-slate-700">🇲🇽 México (MX)</span>
                      </label>
                    </div>

                    <!-- Auxiliary manual input for other countries -->
