---
import SEO from '../components/SEO.astro';

export const prerender = true; // Pre-rendered static shell, client-side dynamic login
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title="Iniciar Sesión | FLEX FORM FITNESS"
      description="Inicia sesión en tu cuenta de FLEX FORM FITNESS. Accede a tus pedidos, haz seguimiento de envíos y compra con rapidez."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;950&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans min-h-screen antialiased flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
      <!-- Logo -->
      <a href="/" class="inline-flex flex-col group mb-6">
        <span class="text-3xl font-black italic tracking-tighter text-slate-950 uppercase leading-none">
          FLEX <span class="text-rose-600">FORM</span>
        </span>
        <span class="text-[10px] font-extrabold tracking-[0.25em] text-slate-400 uppercase leading-none mt-1">
          FITNESS
        </span>
      </a>
      <h2 class="text-2xl font-extrabold text-slate-950 tracking-tight">
        Bienvenido de nuevo
      </h2>
      <p class="mt-1.5 text-sm text-slate-500">
        O <a href="/registro" class="font-bold text-rose-600 hover:underline">crea una cuenta nueva</a>
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-white py-8 px-4 border border-slate-100 shadow-xl rounded-3xl sm:px-10">
        
        <!-- Error notification box -->
        <div id="error-box" class="hidden mb-6 p-4 rounded-xl bg-red-50 border border-red-100 text-red-700 text-xs font-semibold text-center leading-relaxed">
        </div>

        <!-- Google Auth Button -->
        <div class="w-full">
          <button
            type="button"
            id="google-btn"
            class="w-full inline-flex justify-center items-center py-3.5 px-4 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-sm font-bold text-slate-700 hover:text-slate-905 shadow-sm active:scale-98 transition-all duration-200 gap-3"
          >
            <!-- Google logo vector -->
            <svg class="w-5 h-5" viewBox="0 0 24 24" width="24" height="24">
              <path fill="#EA4335" d="M12 5.04c1.74 0 3.3.6 4.53 1.78l3.39-3.39C17.84 1.54 15.11 1 12 1 7.24 1 3.2 3.73 1.24 7.72l3.96 3.07C6.18 7.73 8.84 5.04 12 5.04z" />
              <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.03 3.68-8.64z" />
              <path fill="#FBBC05" d="M5.2 13.91c-.24-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29L1.24 6.26C.44 7.98 0 9.89 0 11.9s.44 3.92 1.24 5.64l3.96-3.63z" />
              <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.91l-3.77-2.92c-1.11.75-2.53 1.19-4.19 1.19-3.16 0-5.82-2.69-6.8-5.75L1.24 16.2C3.2 20.27 7.24 23 12 23z" />
            </svg>
            <span>Continuar con Google</span>
          </button>
        </div>

        <!-- Separator -->
        <div class="mt-6 relative">
          <div class="absolute inset-0 flex items-center" aria-hidden="true">
            <div class="w-full border-t border-slate-100"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase font-extrabold tracking-widest text-slate-400">
            <span class="bg-white px-3">o usa tu correo</span>
          </div>
        </div>

        <!-- Credentials Form -->
        <form id="login-form" class="mt-6 flex flex-col gap-5">
          <div>
            <label for="email" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              Correo Electrónico
            </label>
            <div class="mt-1.5">
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="ejemplo@correo.com"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <div>
            <label for="password" class="block text-2xs font-extrabold text-slate-400 uppercase tracking-widest">
              Contraseña
            </label>
            <div class="mt-1.5">
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                placeholder="******"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white placeholder-slate-400 text-slate-900 focus:outline-none focus:border-rose-600 focus:ring-1 focus:ring-rose-600 transition-colors text-sm"
              />
            </div>
          </div>

          <div class="mt-2">
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-3.5 px-4 rounded-xl bg-slate-950 hover:bg-rose-600 text-white font-bold text-sm tracking-wider uppercase transition-colors duration-200 shadow-md active:scale-98 flex items-center justify-center gap-2"
            >
              <span>Acceder</span>
            </button>
          </div>
        </form>

      </div>
    </div>

    <!-- Client-side script handling Firebase Authentication and backend integration -->
    <script>
      import { auth, googleProvider } from '../lib/firebaseClient';
      import { signInWithPopup, signInWithEmailAndPassword } from 'firebase/auth';

      const loginForm = document.getElementById('login-form') as HTMLFormElement;
      const googleBtn = document.getElementById('google-btn') as HTMLButtonElement;
      const errorBox = document.getElementById('error-box') as HTMLDivElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      function showError(message: string) {
        errorBox.innerHTML = message;
        errorBox.classList.remove('hidden');
      }

      function hideError() {
        errorBox.innerHTML = '';
        errorBox.classList.add('hidden');
      }

      // Handle server-side session exchange
      async function createSession(user: any) {
        const idToken = await user.getIdToken();
        
        const response = await fetch('/api/auth/session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (!response.ok) {
          const result = await response.json();
          throw new Error(result.message || 'Error al iniciar sesión en el servidor');
        }

        // Redirect to homepage
        window.location.href = '/';
      }

      // Traditional email/password sign-in
      loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideError();
        
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        
        const email = emailInput.value;
        const password = passwordInput.value;
        
        // Disable inputs and show loading state
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span>Verificando...</span>';

        try {
          const userCredential = await signInWithEmailAndPassword(auth, email, password);
          
          // Verify if email has been verified
          if (!userCredential.user.emailVerified) {
            const { signOut } = await import('firebase/auth');
            await signOut(auth);
            
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
            
            showError('Tu correo electrónico no ha sido verificado. <a href="#" id="resend-verification-btn" class="font-bold underline ml-1 text-rose-600 hover:text-rose-700">Reenviar enlace de verificación</a>');
            
            const resendBtn = document.getElementById('resend-verification-btn');
            resendBtn?.addEventListener('click', async (event) => {
              event.preventDefault();
              try {
                const { sendEmailVerification } = await import('firebase/auth');
                await sendEmailVerification(userCredential.user);
                showError('<span class="text-green-600">¡Enlace de verificación reenviado! Revisa tu bandeja de entrada.</span>');
              } catch (resendErr: any) {
                console.error('Error resending email verification:', resendErr);
                showError('Error al reenviar el enlace: ' + (resendErr.message || resendErr.code));
              }
            });
            return;
          }

          await createSession(userCredential.user);
        } catch (error: any) {
          console.error('Email sign in error:', error);
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          
          let translatedMessage = 'Ocurrió un error al iniciar sesión. Comprueba tus credenciales.';
          if (error.code === 'auth/invalid-credential' || error.code === 'auth/wrong-password' || error.code === 'auth/user-not-found') {
            translatedMessage = 'El correo o la contraseña son incorrectos.';
          } else if (error.code === 'auth/invalid-email') {
            translatedMessage = 'El formato del correo electrónico no es válido.';
          }
          showError(translatedMessage);
        }
      });

      // Google Auth Sign-in
      googleBtn?.addEventListener('click', async () => {
        hideError();
        googleBtn.disabled = true;
        const originalContent = googleBtn.innerHTML;
        googleBtn.innerHTML = '<span>Conectando con Google...</span>';

        try {
          const userCredential = await signInWithPopup(auth, googleProvider);
          await createSession(userCredential.user);
        } catch (error: any) {
          console.error('Google sign in error:', error);
          googleBtn.disabled = false;
          googleBtn.innerHTML = originalContent;
          
          if (error.code !== 'auth/popup-closed-by-user') {
            showError('Error al conectar con Google: ' + (error.message || error.code));
          }
        }
      });
    </script>
  </body>
</html>
